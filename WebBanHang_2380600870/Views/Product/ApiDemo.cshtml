@* Views/Product/ApiDemo.cshtml — REDESIGNED *@
@{
    ViewData["Title"] = "Demo RESTful API";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActivePage"] = "ApiDemo";
    ViewData["Breadcrumb"] = "<a href='/Product'>Sản phẩm</a> <span class='material-symbols-outlined'>chevron_right</span> API Demo";
}

<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Be+Vietnam+Pro:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />

<style>
    /* ══════════════════════════════════════════════════
       CSS VARIABLES
    ══════════════════════════════════════════════════ */
    :root {
      /* ── Brand palette (matches _AdminLayout) ── */
      --bg:          #1e2a2b;       /* darkest — card bg, hero, ref */
      --surface:     #243234;       /* mid — card surface */
      --surface2:    #2c3a3b;       /* lighter — input bg, hover */
      --border:      rgba(162,123,92,0.18);   /* primary brown tint */
      --border-soft: rgba(162,123,92,0.08);
      --text:        #dcd7c9;       /* clr-neutral */
      --muted:       #8c9a9b;
      --accent:      #a27b5c;       /* clr-primary */
      --accent-glow: rgba(162,123,92,0.22);
      --green:       #10b981;
      --blue:        #3b82f6;
      --amber:       #f59e0b;
      --red:         #ef4444;
      --purple:      #8b5cf6;
      --teal:        #06b6d4;
      --mono:        'JetBrains Mono', monospace;
      --sans:        'Be Vietnam Pro', sans-serif;
      --radius:      12px;
      --radius-sm:   8px;
    }

    /* ══ RESET ══ */
    .api-demo * { box-sizing: border-box; }
    .api-demo { font-family: var(--sans); color: var(--text); }

    /* ══ HERO BANNER ══════════════════════════════════ */
    .ad-hero {
      position: relative;
      background: var(--bg);
      border-radius: 20px;
      padding: 2.5rem 2.5rem 2rem;
      margin-bottom: 1.5rem;
      overflow: hidden;
      border: 1px solid var(--border);
    }
    .ad-hero::before {
      content: '';
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 60% 80% at 0% 50%, rgba(162,123,92,.22) 0%, transparent 55%),
        radial-gradient(ellipse 40% 60% at 100% 20%, rgba(63,78,79,.35) 0%, transparent 50%);
      pointer-events: none;
    }
    .ad-hero-grid {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      align-items: center;
      position: relative; z-index: 1;
    }
    .ad-hero-eyebrow {
      display: inline-flex; align-items: center; gap: .5rem;
      font-size: .65rem; font-weight: 700; letter-spacing: .2em;
      text-transform: uppercase; color: var(--accent);
      margin-bottom: .75rem;
    }
    .ad-hero-eyebrow .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--green);
      box-shadow: 0 0 8px var(--green);
      animation: pulse 2s ease-in-out infinite;
    }
    @@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.6;transform:scale(.85)} }
    .ad-hero-title {
      font-family: var(--sans); font-size: 1.75rem; font-weight: 700;
      color: var(--text); line-height: 1.2; margin-bottom: .5rem;
    }
    .ad-hero-title span { color: var(--accent); }
    .ad-hero-sub {
      font-size: .875rem; color: var(--muted); line-height: 1.75; max-width: 520px;
    }
    .ad-hero-sub code {
      background: rgba(162,123,92,.15); color: var(--accent);
      padding: .15rem .5rem; border-radius: 5px; font-family: var(--mono);
      font-size: .78rem;
    }
    .ad-hero-actions { display: flex; gap: .625rem; flex-direction: column; align-items: flex-end; }
    .ad-btn-guide {
      display: inline-flex; align-items: center; gap: .45rem;
      padding: .65rem 1.25rem; border-radius: var(--radius-sm);
      background: var(--accent); color: #fff;
      border: none; cursor: pointer;
      font-family: var(--sans); font-size: .85rem; font-weight: 600;
      transition: opacity .15s, transform .12s;
      white-space: nowrap;
    }
    .ad-btn-guide:hover { opacity: .88; transform: translateY(-1px); }
    .ad-btn-guide .material-symbols-outlined { font-size: 17px; }
    .ad-btn-swagger {
      display: inline-flex; align-items: center; gap: .45rem;
      padding: .6rem 1.2rem; border-radius: var(--radius-sm);
      background: transparent; color: var(--muted);
      border: 1px solid var(--border); cursor: pointer;
      font-family: var(--sans); font-size: .82rem; font-weight: 500;
      text-decoration: none; transition: border-color .15s, color .15s;
    }
    .ad-btn-swagger:hover { border-color: rgba(162,123,92,.4); color: var(--accent); }
    .ad-btn-swagger .material-symbols-outlined { font-size: 14px; }

    /* ══ GUIDE PANEL ══════════════════════════════════ */
    .ad-guide {
      display: none;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 18px;
      margin-bottom: 1.5rem;
      overflow: hidden;
      animation: slideDown .3s cubic-bezier(.22,1,.36,1);
    }
    .ad-guide.open { display: block; }
    @@keyframes slideDown {
      from { opacity:0; transform:translateY(-10px); }
      to   { opacity:1; transform:translateY(0); }
    }
    .ad-guide-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.25rem 1.75rem;
      border-bottom: 1px solid var(--border);
      background: rgba(162,123,92,.05);
    }
    .ad-guide-title {
      display: flex; align-items: center; gap: .625rem;
      font-size: .95rem; font-weight: 700; color: var(--text);
    }
    .ad-guide-title .material-symbols-outlined { font-size: 20px; color: var(--accent); }
    .ad-guide-close {
      width: 30px; height: 30px; border-radius: 50%;
      border: 1px solid var(--border); background: none; cursor: pointer;
      color: var(--muted); display: flex; align-items: center; justify-content: center;
      transition: border-color .15s, color .15s;
    }
    .ad-guide-close:hover { border-color: var(--red); color: var(--red); }
    .ad-guide-close .material-symbols-outlined { font-size: 16px; }
    .ad-guide-body { padding: 1.75rem; }
    .ad-guide-intro {
      font-size: .875rem; color: var(--muted); line-height: 1.8; margin-bottom: 1.5rem;
      padding: 1rem 1.25rem;
      background: rgba(59,130,246,.06); border: 1px solid rgba(59,130,246,.15);
      border-radius: var(--radius-sm);
    }
    .ad-guide-intro strong { color: var(--text); }
    .ad-guide-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
    @@media(max-width:700px) { .ad-guide-grid { grid-template-columns: 1fr; } }
    .ad-guide-card {
      padding: 1.1rem 1.25rem;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      transition: border-color .2s;
    }
    .ad-guide-card:hover { border-color: rgba(162,123,92,.3); }
    .ad-guide-card-title {
      display: flex; align-items: center; gap: .5rem;
      font-size: .8rem; font-weight: 700; color: var(--text); margin-bottom: .5rem;
    }
    .ad-guide-card-title .material-symbols-outlined { font-size: 15px; color: var(--accent); }
    .ad-guide-card-desc { font-size: .78rem; color: var(--muted); line-height: 1.65; }
    .ad-guide-flow {
      display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
      margin-bottom: 1.5rem;
    }
    .ad-flow-step {
      display: flex; align-items: center; gap: .5rem;
      padding: .55rem .9rem; background: var(--surface2);
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      font-size: .78rem; color: var(--text);
    }
    .ad-flow-step .num {
      width: 20px; height: 20px; border-radius: 50%;
      background: var(--accent); color: #fff;
      font-size: .62rem; font-weight: 800;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .ad-flow-arrow { color: var(--muted); font-size: .75rem; }
    .ad-guide-methods { display: flex; flex-wrap: wrap; gap: .5rem; }
    .ad-method-pill {
      display: inline-flex; align-items: center; gap: .5rem;
      padding: .4rem .875rem; border-radius: 99px;
      font-size: .72rem; font-weight: 700; border: 1px solid;
    }
    .ad-method-pill.get    { background: rgba(59,130,246,.1);  color: #60a5fa; border-color: rgba(59,130,246,.25); }
    .ad-method-pill.post   { background: rgba(16,185,129,.1);  color: #34d399; border-color: rgba(16,185,129,.25); }
    .ad-method-pill.put    { background: rgba(245,158,11,.1);  color: #fbbf24; border-color: rgba(245,158,11,.25); }
    .ad-method-pill.delete { background: rgba(239,68,68,.1);   color: #f87171; border-color: rgba(239,68,68,.25); }
    .ad-method-pill .lock  { font-size: 11px; opacity: .7; }

    /* ══ ENDPOINT REFERENCE ══════════════════════════ */
    .ad-ref {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 18px;
      margin-bottom: 1.5rem;
      overflow: hidden;
    }
    .ad-ref-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: .875rem 1.5rem;
      border-bottom: 1px solid var(--border-soft);
    }
    .ad-ref-title {
      font-family: var(--mono); font-size: .65rem; font-weight: 700;
      letter-spacing: .18em; text-transform: uppercase; color: var(--muted);
      display: flex; align-items: center; gap: .5rem;
    }
    .ad-ref-title::before {
      content: ''; display: block;
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--accent); box-shadow: 0 0 8px var(--accent);
    }
    .ad-ref-rows { padding: .5rem; }
    .ad-ref-row {
      display: grid;
      grid-template-columns: 58px 1fr auto auto;
      gap: .625rem;
      align-items: center;
      padding: .6rem .875rem;
      border-radius: var(--radius-sm);
      transition: background .12s;
    }
    .ad-ref-row:hover { background: var(--surface); }
    .ad-badge {
      display: inline-flex; align-items: center; justify-content: center;
      padding: .16rem .5rem; border-radius: 5px;
      font-family: var(--mono); font-size: .6rem; font-weight: 700;
      letter-spacing: .04em;
    }
    .b-get    { background: #1e3a5f; color: #60a5fa; }
    .b-post   { background: #064e3b; color: #34d399; }
    .b-put    { background: #451a03; color: #fbbf24; }
    .b-delete { background: #450a0a; color: #f87171; }
    .ad-ref-path { font-family: var(--mono); font-size: .8rem; color: var(--text); }
    .ad-ref-desc { font-size: .72rem; color: var(--muted); text-align: right; }
    .ad-ref-lock { font-size: 13px; color: var(--amber); }

    /* ══ MAIN GRID ════════════════════════════════════ */
    .ad-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    @@media(max-width:960px) { .ad-grid { grid-template-columns: 1fr; } }
    .ad-grid-full { grid-column: 1 / -1; }

    /* ══ API CARD ═════════════════════════════════════ */
    .ad-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 18px;
      overflow: hidden;
      transition: border-color .2s;
    }
    .ad-card:hover { border-color: rgba(162,123,92,.22); }
    .ad-card-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 1.25rem .875rem;
      border-bottom: 1px solid var(--border-soft);
      gap: .5rem;
    }
    .ad-card-head-left {
      display: flex; align-items: center; gap: .625rem; flex-wrap: wrap;
    }
    .ad-card-title {
      font-size: .875rem; font-weight: 700; color: var(--text);
      font-family: var(--mono);
    }
    .ad-card-subtitle { font-size: .7rem; color: var(--muted); margin-top: .15rem; }
    .ad-lock-icon { font-size: 14px; color: var(--amber); }

    .ad-card-body { padding: 1rem 1.25rem; }
    .ad-card-body .ad-field { margin-bottom: .625rem; }
    .ad-card-body .ad-field:last-of-type { margin-bottom: 0; }

    .ad-label {
      display: block; font-size: .62rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .1em;
      color: var(--muted); margin-bottom: .3rem;
    }
    .ad-input, .ad-select, .ad-textarea {
      width: 100%; padding: .6rem .875rem;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      font-family: var(--sans); font-size: .85rem; color: var(--text);
      outline: none; transition: border-color .15s, box-shadow .15s;
      box-sizing: border-box;
    }
    .ad-input:focus, .ad-select:focus, .ad-textarea:focus {
      border-color: rgba(162,123,92,.5);
      box-shadow: 0 0 0 3px rgba(162,123,92,.1);
    }
    .ad-input::placeholder, .ad-textarea::placeholder { color: var(--muted); opacity: .6; }
    .ad-select option { background: #1e2330; }
    .ad-input-row { display: flex; gap: .5rem; }
    .ad-input-row .ad-input { margin-bottom: 0; flex: 1; }
    .ad-checkbox-row {
      display: flex; align-items: center; gap: .5rem;
      font-size: .82rem; color: var(--muted); margin-bottom: .5rem;
    }
    .ad-checkbox-row input { accent-color: var(--accent); width: 14px; height: 14px; cursor: pointer; }
    .ad-slide-field { display: none; margin-top: .5rem; }
    .ad-slide-field.show { display: block; }

    .ad-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem; }

    /* ══ BUTTONS ══════════════════════════════════════ */
    .ad-btn {
      display: inline-flex; align-items: center; gap: .4rem;
      padding: .58rem 1.1rem; border-radius: var(--radius-sm); border: none;
      font-family: var(--sans); font-size: .82rem; font-weight: 600;
      cursor: pointer; transition: opacity .15s, transform .12s;
      white-space: nowrap;
    }
    .ad-btn:hover:not(:disabled) { opacity: .82; transform: translateY(-1px); }
    .ad-btn:disabled { opacity: .4; cursor: not-allowed; transform: none; }
    .ad-btn .material-symbols-outlined { font-size: 15px; }
    .ad-btn-blue   { background: var(--blue);   color: #fff; }
    .ad-btn-green  { background: var(--green);  color: #fff; }
    .ad-btn-amber  { background: var(--amber);  color: #000; }
    .ad-btn-red    { background: var(--red);    color: #fff; }
    .ad-btn-ghost  { background: var(--surface2); color: var(--muted); }
    .ad-btn-ghost:hover { color: var(--text); }
    .ad-btn-full { width: 100%; justify-content: center; margin-top: .625rem; }

    .ad-card-footer { padding: 0 1.25rem 1.25rem; }

    /* ══ STATUS + COUNT ══ */
    .ad-meta { display: flex; align-items: center; gap: .625rem; margin-bottom: .6rem; flex-wrap: wrap; }
    .ad-status-chip {
      display: inline-flex; align-items: center; gap: .3rem;
      padding: .2rem .6rem; border-radius: 99px;
      font-size: .65rem; font-weight: 700; letter-spacing: .05em;
    }
    .chip-2xx  { background: rgba(16,185,129,.15); color: var(--green); border: 1px solid rgba(16,185,129,.25); }
    .chip-201  { background: rgba(6,182,212,.12);  color: var(--teal);  border: 1px solid rgba(6,182,212,.25); }
    .chip-204  { background: rgba(139,92,246,.12); color: #a78bfa;      border: 1px solid rgba(139,92,246,.25); }
    .chip-4xx  { background: rgba(245,158,11,.12); color: var(--amber); border: 1px solid rgba(245,158,11,.25); }
    .chip-5xx  { background: rgba(239,68,68,.12);  color: var(--red);   border: 1px solid rgba(239,68,68,.25); }
    .ad-count-badge {
      font-size: .7rem; color: var(--muted);
      display: flex; align-items: center; gap: .3rem;
      font-family: var(--mono);
    }
    .ad-count-badge .material-symbols-outlined { font-size: 13px; color: var(--accent); }

    /* ══ RESULT BOX ══════════════════════════════════ */
    .ad-result-wrap { position: relative; margin-top: .75rem; }
    .ad-result {
      background: var(--bg);
      border: 1px solid var(--border);
      border-left: 3px solid var(--border);
      border-radius: var(--radius-sm);
      padding: .875rem 1rem;
      font-family: var(--mono); font-size: .73rem; color: var(--muted);
      max-height: 220px; overflow-y: auto;
      white-space: pre-wrap; word-break: break-all;
      line-height: 1.7; transition: border-left-color .25s;
      scrollbar-width: thin; scrollbar-color: var(--border) transparent;
    }
    .ad-result::-webkit-scrollbar { width: 4px; }
    .ad-result::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }
    .ad-result.s2xx  { border-left-color: var(--green); color: #86efac; }
    .ad-result.s201  { border-left-color: var(--teal);  color: #a5f3fc; }
    .ad-result.s204  { border-left-color: #8b5cf6;      color: #c4b5fd; }
    .ad-result.s4xx  { border-left-color: var(--amber); color: #fde68a; }
    .ad-result.s5xx  { border-left-color: var(--red);   color: #fca5a5; }
    .ad-result.loading { border-left-color: var(--amber); }
    .ad-copy-wrap { position: absolute; top: .5rem; right: .5rem; }
    .ad-copy-btn {
      display: flex; align-items: center; gap: .25rem;
      padding: .25rem .55rem; border-radius: 6px;
      background: rgba(255,255,255,.06); border: 1px solid var(--border);
      color: var(--muted); font-family: var(--sans); font-size: .68rem;
      font-weight: 600; cursor: pointer; transition: background .15s, color .15s;
    }
    .ad-copy-btn:hover { background: rgba(255,255,255,.12); color: var(--text); }
    .ad-copy-btn .material-symbols-outlined { font-size: 12px; }

    /* ══ HISTORY ══════════════════════════════════════ */
    .ad-history {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 18px;
      margin-top: 1rem;
      overflow: hidden;
    }
    .ad-history-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: .875rem 1.25rem;
      border-bottom: 1px solid var(--border-soft);
    }
    .ad-history-title {
      display: flex; align-items: center; gap: .5rem;
      font-size: .82rem; font-weight: 700; color: var(--text);
    }
    .ad-history-title .material-symbols-outlined { font-size: 17px; color: var(--accent); }
    .ad-history-clear {
      font-size: .7rem; color: var(--muted); background: none; border: none;
      cursor: pointer; font-family: var(--sans); transition: color .15s;
      padding: .2rem .5rem; border-radius: 5px;
    }
    .ad-history-clear:hover { color: var(--red); background: rgba(239,68,68,.08); }
    .ad-history-list { padding: .5rem; min-height: 60px; }
    .ad-history-empty {
      text-align: center; padding: 1.5rem; color: var(--muted);
      font-size: .82rem; font-style: italic;
    }
    .ad-history-item {
      display: flex; align-items: center; gap: .75rem;
      padding: .5rem .75rem; border-radius: var(--radius-sm);
      transition: background .12s; cursor: pointer;
    }
    .ad-history-item:hover { background: var(--surface2); }
    .ad-hist-method { font-family: var(--mono); font-size: .68rem; font-weight: 800; min-width: 46px; }
    .m-get    { color: var(--blue); }
    .m-post   { color: var(--green); }
    .m-put    { color: var(--amber); }
    .m-delete { color: var(--red); }
    .ad-hist-url { flex: 1; font-family: var(--mono); font-size: .75rem; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ad-hist-status { font-family: var(--mono); font-size: .72rem; font-weight: 700; min-width: 36px; text-align: right; }
    .ad-hist-ts { font-size: .65rem; color: var(--muted); min-width: 52px; text-align: right; }

    /* ══ DELETE MODAL ════════════════════════════════ */
    .ad-modal-overlay {
      position: fixed; inset: 0; z-index: 9000;
      background: rgba(0,0,0,.72); backdrop-filter: blur(6px);
      display: flex; align-items: center; justify-content: center; padding: 1rem;
      opacity: 0; pointer-events: none; transition: opacity .22s;
    }
    .ad-modal-overlay.open { opacity: 1; pointer-events: all; }
    .ad-modal {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 18px; padding: 1.75rem; max-width: 380px; width: 100%;
      box-shadow: 0 24px 64px rgba(0,0,0,.6);
      transform: scale(.93) translateY(10px);
      transition: transform .25s cubic-bezier(.34,1.56,.64,1);
    }
    .ad-modal-overlay.open .ad-modal { transform: scale(1) translateY(0); }
    .ad-modal-icon {
      width: 48px; height: 48px; border-radius: 50%;
      background: rgba(239,68,68,.12); border: 1px solid rgba(239,68,68,.25);
      display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;
    }
    .ad-modal-icon .material-symbols-outlined { font-size: 22px; color: var(--red); }
    .ad-modal-title { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: .4rem; }
    .ad-modal-label { font-size: .78rem; color: var(--muted); margin-bottom: 1rem; }
    .ad-modal-body  { font-size: .85rem; color: var(--muted); line-height: 1.7; margin-bottom: 1.25rem; }
    .ad-modal-body strong { color: var(--text); }
    .ad-modal-actions { display: flex; gap: .625rem; }
    .ad-modal-cancel {
      flex: 1; padding: .65rem; border-radius: var(--radius-sm);
      background: var(--surface2); border: 1px solid var(--border);
