    <script>
        var _cats = [];
        var _hist = [];
        var _pollCount = 0;

        /* ── INIT ── */
        // Không dùng DOMContentLoaded vì trang được nạp qua SPA fetch
        loadCategories();

        async function loadCategories() {
          try {
            var r = await fetch('/api/products/categories');
            if (!r.ok) return;
            _cats = await r.json();
            ['filter-catid','post-catid','put-catid'].forEach(function(id) {
              var sel = document.getElementById(id); if (!sel) return;
              var first = sel.options[0];
              sel.innerHTML = ''; sel.appendChild(first);
              _cats.forEach(function(c) {
                var o = document.createElement('option');
                o.value = c.id; o.textContent = c.name; sel.appendChild(o);
              });
            });
          } catch(e) {}
        }

        /* ── GUIDE TOGGLE ── */
        function toggleGuide() {
          var g = document.getElementById('adGuide');
          var open = g.classList.toggle('open');
          document.getElementById('guideBtnText').textContent = open ? 'Đóng Hướng Dẫn' : 'Hướng Dẫn';
          document.getElementById('guideIcon').textContent = open ? 'close' : 'menu_book';
        }

        /* ── TOGGLE DISCOUNT FIELD ── */
        function toggleDiscount(pfx) {
          var cb = document.getElementById(pfx+'-onsale');
          var w = document.getElementById(pfx+'-discount-wrap');
          if (w) w.classList.toggle('show', cb.checked);
        }

        /* ── HELPERS ── */
        function statusClass(code) {
          if (code===204) return 's204';
          if (code===201) return 's201';
          if (code>=200&&code<300) return 's2xx';
          if (code>=400&&code<500) return 's4xx';
          if (code>=500) return 's5xx';
          return '';
        }
        function statusChip(code) {
          var cls = code===204?'chip-204':code===201?'chip-201':code>=200&&code<300?'chip-2xx':code>=400&&code<500?'chip-4xx':'chip-5xx';
          var map = {200:'200 OK',201:'201 Created',204:'204 No Content',400:'400 Bad Request',401:'401 Unauthorized',403:'403 Forbidden',404:'404 Not Found',409:'409 Conflict',422:'422 Unprocessable',500:'500 Server Error'};
          return '<span class="ad-status-chip '+cls+'">'+map[code]+'</span>';
        }
        function fmtStatus(code) {
          var map={200:'200 OK',201:'201 Created',204:'204 No Content',400:'400 Bad Request',401:'401 Unauthorized',403:'403 Forbidden',404:'404 Not Found',409:'409 Conflict',422:'422 Unprocessable',500:'500 Server Error'};
          return map[code]||String(code);
        }
        async function safeJson(r) { try{return await r.json();}catch(e){return null;} }

        function showResult(id, code, data, reqBody) {
          var el = document.getElementById(id);
          el.className = 'ad-result '+statusClass(code);
          var out = '// HTTP '+fmtStatus(code)+'\n\n';
          if (reqBody) out += '// Request Body:\n'+JSON.stringify(reqBody,null,2)+'\n\n';
          if (data!=null) out += '// Response:\n'+(typeof data==='string'?data:JSON.stringify(data,null,2));
          else out += '// (No response body)';
          el.textContent = out;
        }
        function showLoading(id, btnId, iconId) {
          var el=document.getElementById(id);
          el.className='ad-result loading'; el.textContent='⏳ Đang gửi request...';
          if(btnId){document.getElementById(btnId).disabled=true;}
          if(iconId){var ico=document.getElementById(iconId);ico.textContent='sync';ico.className='material-symbols-outlined spin';}
        }
        function doneLoading(btnId, iconId, iconText) {
          if(btnId)document.getElementById(btnId).disabled=false;
          if(iconId){var ico=document.getElementById(iconId);ico.textContent=iconText||'send';ico.className='material-symbols-outlined';}
        }

        /* ── HISTORY ── */
        function pushHistory(method, url, code) {
          var now=new Date();
          var ts=now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0')+':'+now.getSeconds().toString().padStart(2,'0');
          _hist.unshift({method:method,url:url,code:code,ts:ts});
          if(_hist.length>5)_hist.pop();
          renderHistory();
        }
        function clearHistory() { _hist=[]; renderHistory(); }
        function renderHistory() {
          var panel=document.getElementById('histList');
          if(!_hist.length){panel.innerHTML='<div class="ad-history-empty">Chưa có request nào.</div>';return;}
          panel.innerHTML=_hist.map(function(h){
            var sc=h.code<300?'var(--green)':h.code<500?'var(--amber)':'var(--red)';
            return '<div class="ad-history-item">'
              +'<span class="ad-hist-method m-'+h.method.toLowerCase()+'">'+h.method+'</span>'
              +'<span class="ad-hist-url">'+h.url+'</span>'
              +'<span class="ad-hist-status" style="color:'+sc+'">'+h.code+'</span>'
              +'<span class="ad-hist-ts">'+h.ts+'</span>'
              +'</div>';
          }).join('');
        }

        /* ── COPY ── */
        function copyRes(id) {
          var el=document.getElementById(id);
          navigator.clipboard.writeText(el.textContent)
            .then(function(){adToast('✅ Đã copy vào clipboard');})
            .catch(function(){
              var t=document.createElement('textarea');t.value=el.textContent;
              document.body.appendChild(t);t.select();document.execCommand('copy');t.remove();
              adToast('✅ Đã copy');
            });
        }
        function adToast(msg) {
          var t=document.getElementById('adToast');
          document.getElementById('adToastMsg').textContent=msg;
          t.classList.add('show');
          setTimeout(function(){t.classList.remove('show');},2800);
        }

        /* ── META ROW ── */
        function showMeta(id, chip, extra) {
          var el=document.getElementById(id); if(!el)return;
          el.style.display='flex';
          el.innerHTML=chip+(extra?'<span class="ad-count-badge"><span class="material-symbols-outlined">inventory_2</span>'+extra+'</span>':'');
        }

        /* ── GET ALL ── */
        async function apiGetAll() {
          showLoading('res-getall','btn-getall','icon-getall');
          var p=new URLSearchParams();
          var catId=document.getElementById('filter-catid').value;
          var sale=document.getElementById('filter-sale').value;
          if(catId)p.append('categoryId',catId);
          if(sale)p.append('onSaleOnly',sale);
          var url='/api/products'+(p.toString()?'?'+p.toString():'');
          try {
            var r=await fetch(url);
            var data=await safeJson(r);
            var tc=r.headers.get('X-Total-Count');
            showMeta('meta-getall',statusChip(r.status),tc?tc+' sản phẩm':null);
            showResult('res-getall',r.status,data);
            pushHistory('GET',url,r.status);
          } catch(e){showResult('res-getall',0,'Lỗi kết nối: '+e.message);}
          doneLoading('btn-getall','icon-getall','send');
        }

        /* ── GET BY ID ── */
        async function apiGetById() {
          var id=document.getElementById('input-getid').value.trim();
          if(!id){showResult('res-getbyid',400,{message:'Vui lòng nhập ID.'});return;}
          showLoading('res-getbyid','btn-getbyid','icon-getbyid');
          var url='/api/products/'+id;
          try {
            var r=await fetch(url);
            var data=await safeJson(r);
            showResult('res-getbyid',r.status,data);
            pushHistory('GET',url,r.status);
            if(r.ok&&data){
              document.getElementById('put-id').value=data.id||'';
              document.getElementById('put-name').value=data.name||'';
              document.getElementById('put-price').value=data.price||'';
              document.getElementById('put-desc').value=data.description||'';
              document.getElementById('put-catid').value=data.categoryId||'';
              var ps=document.getElementById('put-onsale');
              ps.checked=!!data.isOnSale; toggleDiscount('put');
              if(data.discountPercent!=null)document.getElementById('put-discount').value=data.discountPercent;
              adToast('✏️ Đã tự điền form PUT với dữ liệu sản phẩm #'+data.id);
            }
          } catch(e){showResult('res-getbyid',0,'Lỗi kết nối: '+e.message);}
          doneLoading('btn-getbyid','icon-getbyid','send');
        }

        /* ── POST ── */
        async function apiPost() {
          var name=document.getElementById('post-name').value.trim();
          var price=parseFloat(document.getElementById('post-price').value);
          var desc=document.getElementById('post-desc').value.trim();
          var catId=parseInt(document.getElementById('post-catid').value);
          var onSale=document.getElementById('post-onsale').checked;
          var discount=onSale?parseFloat(document.getElementById('post-discount').value):null;
          if(!name){showResult('res-post',400,{message:'Vui lòng nhập Tên.'});return;}
          if(!price){showResult('res-post',400,{message:'Vui lòng nhập Giá.'});return;}
          if(!catId){showResult('res-post',400,{message:'Vui lòng chọn Danh mục.'});return;}
          var body={name:name,price:price,description:desc||null,categoryId:catId,isOnSale:onSale,discountPercent:(onSale&&!isNaN(discount)?discount:null)};
          showLoading('res-post','btn-post','icon-post');
          try {
            var r=await fetch('/api/products',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
            var data=await safeJson(r);
            showResult('res-post',r.status,data,body);
            pushHistory('POST','/api/products',r.status);
            if(r.status===201){adToast('✅ Tạo thành công! ID = '+(data?.id||'?'));await apiGetAll();}
          } catch(e){showResult('res-post',0,'Lỗi kết nối: '+e.message,body);}
          doneLoading('btn-post','icon-post','add_circle');
        }

        /* ── PUT ── */
        async function apiPut() {
          var id=document.getElementById('put-id').value.trim();
          var name=document.getElementById('put-name').value.trim();
          var price=parseFloat(document.getElementById('put-price').value);
          var desc=document.getElementById('put-desc').value.trim();
          var catId=parseInt(document.getElementById('put-catid').value);
          var onSale=document.getElementById('put-onsale').checked;
          var discount=onSale?parseFloat(document.getElementById('put-discount').value):null;
          if(!id)  {showResult('res-put',400,{message:'Vui lòng nhập ID.'});return;}
          if(!name){showResult('res-put',400,{message:'Vui lòng nhập Tên.'});return;}
          if(!price){showResult('res-put',400,{message:'Vui lòng nhập Giá.'});return;}
          if(!catId){showResult('res-put',400,{message:'Vui lòng chọn Danh mục.'});return;}
          var body={name:name,price:price,description:desc||null,categoryId:catId,isOnSale:onSale,discountPercent:(onSale&&!isNaN(discount)?discount:null)};
          var url='/api/products/'+id;
          showLoading('res-put','btn-put','icon-put');
          try {
            var r=await fetch(url,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
            if(r.status===204){
              showResult('res-put',204,{message:'Cập nhật thành công!',updated_id:parseInt(id)},body);
              adToast('✅ Cập nhật sản phẩm #'+id);
            }else{var data=await safeJson(r);showResult('res-put',r.status,data,body);}
            pushHistory('PUT',url,r.status);
          } catch(e){showResult('res-put',0,'Lỗi kết nối: '+e.message,body);}
          doneLoading('btn-put','icon-put','edit');
        }

        /* ── DELETE CONFIRM ── */
        function openDeleteConfirm() {
          var id=document.getElementById('delete-id').value.trim();
          if(!id){showResult('res-delete',400,{message:'Vui lòng nhập ID.'});return;}
          document.getElementById('adDelLabel').textContent='Sản phẩm ID #'+id;
          var overlay=document.getElementById('adDelOverlay');
          overlay.classList.add('open');
          var btn=document.getElementById('adDelConfirmBtn');
          var nb=btn.cloneNode(true); btn.parentNode.replaceChild(nb,btn);
          nb.addEventListener('click',function(){overlay.classList.remove('open');apiDelete(parseInt(id));});
        }
        async function apiDelete(id) {
          showLoading('res-delete','btn-delete','icon-delete');
          var url='/api/products/'+id;
          try {
            var r=await fetch(url,{method:'DELETE'});
            if(r.status===204){
              showResult('res-delete',204,{message:'Xóa thành công!',deleted_id:id});
              adToast('🗑️ Đã xóa sản phẩm #'+id);
              await apiGetAll();
            }else{
              var data=await safeJson(r);showResult('res-delete',r.status,data);
              if(r.status===409)adToast('⚠️ Không thể xóa — có đơn hàng liên kết');
            }
            pushHistory('DELETE',url,r.status);
          } catch(e){showResult('res-delete',0,'Lỗi kết nối: '+e.message);}
          doneLoading('btn-delete','icon-delete','delete_forever');
        }

        document.addEventListener('keydown',function(e){
          if(e.key==='Escape')document.getElementById('adDelOverlay').classList.remove('open');
        });
    </script>
