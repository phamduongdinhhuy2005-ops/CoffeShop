@model WebBanHang_2380600870.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Thêm Sản Phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActivePage"] = "Product";
    ViewData["Breadcrumb"] = "<a href='/Product'>Sản phẩm</a> <span class='material-symbols-outlined'>chevron_right</span> Thêm mới";
}

<style>
    .hc-form-label { display:block; font-size:.78rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#2c3639; margin-bottom:.5rem; }
    .hc-input { width:100%; padding:.7rem 1rem; border:1.5px solid rgba(162,123,92,.35); border-radius:10px; font-family:'Work Sans',sans-serif; font-size:.9rem; color:#2c3639; background:#fafaf9; outline:none; transition:border-color .15s; box-sizing:border-box; }
    .hc-input:focus { border-color:#a27b5c; }
    .hc-card { background:#fff; border-radius:16px; padding:1.75rem; box-shadow:0 1px 4px rgba(44,54,57,.06); border:1px solid rgba(162,123,92,.15); }
    .hc-toast { position:fixed; top:1.5rem; right:1.5rem; z-index:9999; background:#fff; border:1px solid rgba(162,123,92,.3); border-left:4px solid #a27b5c; border-radius:12px; padding:1rem 1.25rem; display:flex; align-items:center; gap:.75rem; box-shadow:0 8px 24px rgba(44,54,57,.12); transform:translateX(110%); opacity:0; transition:transform .35s cubic-bezier(.34,1.56,.64,1),opacity .35s ease; max-width:360px; }
    .hc-toast.show { transform:translateX(0); opacity:1; }
    .hc-toast.error { border-left-color:#ef4444; }
    .hc-toast.error .hc-toast-icon { color:#ef4444; }
    .hc-toast-icon { color:#a27b5c; font-size:22px; flex-shrink:0; }
    .hc-toast-msg { font-size:.875rem; font-weight:500; color:#2c3639; }
    .hc-toast-close { margin-left:auto; background:none; border:none; cursor:pointer; color:#94a3b8; flex-shrink:0; }
</style>

<div class="hc-toast" id="hcToast">
    <span class="material-symbols-outlined hc-toast-icon" id="hcToastIcon">check_circle</span>
    <span class="hc-toast-msg" id="hcToastMsg">Thành công!</span>
    <button class="hc-toast-close material-symbols-outlined" onclick="hideToast()">close</button>
</div>

<form asp-action="Add" method="post" enctype="multipart/form-data" id="addForm">
    @Html.AntiForgeryToken()

    <div style="display:grid; grid-template-columns:1fr 340px; gap:1.5rem; align-items:start;">

        @* Cột trái *@
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
            <div class="hc-card">
                <div style="font-size:.9rem;font-weight:700;color:#2c3639;margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem;">
                    <span class="material-symbols-outlined" style="color:#a27b5c;font-size:20px;">info</span>
                    Thông tin cơ bản
                </div>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div style="background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.25);border-radius:10px;padding:.75rem 1rem;margin-bottom:1rem;color:#b91c1c;font-size:.85rem;">
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                <div style="margin-bottom:1rem;">
                    <label asp-for="Name" class="hc-form-label">Tên sản phẩm <span style="color:#ef4444;">*</span></label>
                    <input asp-for="Name" class="hc-input" placeholder="Ví dụ: Cà Phê Trứng Hà Nội" />
                    <span asp-validation-for="Name" style="color:#ef4444;font-size:.78rem;margin-top:.25rem;display:block;"></span>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
                    <div>
                        <label asp-for="Price" class="hc-form-label">Giá (đ) <span style="color:#ef4444;">*</span></label>
                        <input asp-for="Price" class="hc-input" placeholder="65000" type="number" min="0" step="1000" />
                        <span asp-validation-for="Price" style="color:#ef4444;font-size:.78rem;margin-top:.25rem;display:block;"></span>
                    </div>
                    <div>
                        <label asp-for="CategoryId" class="hc-form-label">Danh mục <span style="color:#ef4444;">*</span></label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="hc-input" style="cursor:pointer;">
                            <option value="">-- Chọn --</option>
                        </select>
                        <span asp-validation-for="CategoryId" style="color:#ef4444;font-size:.78rem;margin-top:.25rem;display:block;"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="Description" class="hc-form-label">Mô tả</label>
                    <textarea asp-for="Description" class="hc-input" rows="4" placeholder="Mô tả ngắn về sản phẩm..."></textarea>
                </div>
            </div>
        </div>

        @* Cột phải - Hình ảnh *@
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
            <div class="hc-card">
                <div style="font-size:.9rem;font-weight:700;color:#2c3639;margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem;">
                    <span class="material-symbols-outlined" style="color:#a27b5c;font-size:20px;">image</span>
                    Hình ảnh
                </div>

                @* Preview *@
                <div id="imgPreviewWrap"
                     style="width:100%;aspect-ratio:1;border-radius:12px;border:2px dashed rgba(162,123,92,.3);background:#fafaf9;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem;margin-bottom:1rem;overflow:hidden;cursor:pointer;"
                     onclick="document.getElementById('imgFileInput').click()">
                    <img id="imgPreview" src="" alt="" style="display:none;width:100%;height:100%;object-fit:cover;border-radius:10px;" />
                    <span id="imgPlaceholder" class="material-symbols-outlined" style="font-size:40px;color:rgba(162,123,92,.4);">add_photo_alternate</span>
                    <span id="imgPlaceholderTxt" style="font-size:.78rem;color:#94a3b8;">Nhấn để chọn ảnh</span>
                </div>

                @* File input - khi chọn file thì clear URL input *@
                <input type="file" id="imgFileInput" name="ImageFile" accept="image/*" style="display:none;"
                       onchange="onFileSelected(this)" />

                <button type="button" onclick="document.getElementById('imgFileInput').click()"
                        style="width:100%;padding:.65rem;border:1.5px solid rgba(162,123,92,.35);border-radius:10px;background:transparent;color:#a27b5c;font-family:'Work Sans',sans-serif;font-size:.85rem;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.4rem;transition:background .15s;margin-bottom:.75rem;"
                        onmouseover="this.style.background='rgba(162,123,92,.06)'" onmouseout="this.style.background='transparent'">
                    <span class="material-symbols-outlined" style="font-size:18px;">upload</span> Chọn ảnh từ máy
                </button>

                @* URL input - có name="ImageUrl" để submit khi không có file *@
                <div>
                    <label class="hc-form-label" style="margin-bottom:.4rem;">Hoặc dán URL ảnh</label>
                    <input type="text" id="urlInput" name="ImageUrl" class="hc-input"
                           placeholder="https://..." oninput="onUrlInput(this.value)" />
                </div>

                <p style="font-size:.72rem;color:#94a3b8;margin-top:.5rem;">Nếu chọn file, file sẽ được dùng thay URL.</p>
            </div>

            @* Actions *@
            <div class="hc-card">
                <button type="submit"
                        style="width:100%;padding:.8rem;background:#a27b5c;color:#fff;border:none;border-radius:10px;font-family:'Work Sans',sans-serif;font-size:.95rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.5rem;transition:opacity .15s;margin-bottom:.75rem;"
                        onmouseover="this.style.opacity='.88'" onmouseout="this.style.opacity='1'">
                    <span class="material-symbols-outlined" style="font-size:20px;">save</span> Lưu sản phẩm
                </button>
                <a asp-action="Index"
                       style="width:100%;padding:.75rem;border:1.5px solid rgba(44,54,57,.2);border-radius:10px;color:#2c3639;text-decoration:none;font-size:.9rem;font-weight:600;display:flex;align-items:center;justify-content:center;gap:.4rem;transition:background .15s;"
                       onmouseover="this.style.background='rgba(44,54,57,.05)'" onmouseout="this.style.background='transparent'">
                    <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span> Hủy
                </a>
            </div>
        </div>

    </div>
</form>

<div id="hc-toast-bridge" data-msg="@(TempData["Error"]?.ToString() ?? "")" data-error="1" style="display:none;"></div>
<div id="hc-success-bridge" data-msg="@(TempData["Success"]?.ToString() ?? "")" style="display:none;"></div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        // Khi chọn FILE: clear URL input để không conflict, hiển thị preview
        function onFileSelected(input) {
            var file = input.files[0];
            if (!file) return;
            // Clear URL input - file wins over URL
            document.getElementById('urlInput').value = '';
            // Show preview
            var reader = new FileReader();
            reader.onload = function(e) { showPreview(e.target.result); };
            reader.readAsDataURL(file);
        }

        // Khi nhập URL: clear file input, hiển thị preview
        function onUrlInput(url) {
            if (url.trim()) {
                document.getElementById('imgFileInput').value = '';
                showPreview(url.trim());
            }
        }

        function showPreview(src) {
            var img = document.getElementById('imgPreview');
            img.src = src;
            img.style.display = 'block';
            document.getElementById('imgPlaceholder').style.display = 'none';
            document.getElementById('imgPlaceholderTxt').style.display = 'none';
        }

        function showToast(msg, isError) {
            var t = document.getElementById('hcToast');
            var icon = document.getElementById('hcToastIcon');
            document.getElementById('hcToastMsg').textContent = msg;
            t.classList.toggle('error', !!isError);
            icon.textContent = isError ? 'error' : 'check_circle';
            t.classList.add('show');
            setTimeout(hideToast, 4000);
        }
        function hideToast() { document.getElementById('hcToast').classList.remove('show'); }

        (function() {
            var errBridge = document.getElementById('hc-toast-bridge');
            var sucBridge = document.getElementById('hc-success-bridge');
            if (errBridge && errBridge.getAttribute('data-msg')) {
                setTimeout(function() { showToast(errBridge.getAttribute('data-msg'), true); }, 200);
            } else if (sucBridge && sucBridge.getAttribute('data-msg')) {
                setTimeout(function() { showToast(sucBridge.getAttribute('data-msg'), false); }, 200);
            }
        })();
    </script>
}
