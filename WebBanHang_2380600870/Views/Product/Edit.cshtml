@model WebBanHang_2380600870.Models.Product
@{
    ViewData["Title"] = "Chỉnh Sửa Sản Phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActivePage"] = "Product";
    ViewData["Breadcrumb"] = "<a href='/Product'>Sản phẩm</a> <span class='material-symbols-outlined'>chevron_right</span> Chỉnh sửa";
    var categories = ViewBag.Categories as IEnumerable<WebBanHang_2380600870.Models.Category>;

    // Ảnh phụ từ bảng ProductImages (tối đa 3 slot, index 0-2)
    var extraImages = Model.Images?.ToList() ?? new List<WebBanHang_2380600870.Models.ProductImage>();
    string ExtraUrl(int i) => i < extraImages.Count ? (extraImages[i].Url ?? "") : "";
    int ExtraId(int i)     => i < extraImages.Count ? extraImages[i].Id : 0;
}

<style>
    /* ══════════════════════════════════
       PAGE HEADER — redesigned
    ══════════════════════════════════ */
    .ep-header {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0,0,0,.04);
        flex-wrap: wrap;
    }

    .ep-back-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px; height: 36px;
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        background: #f7f7f6;
        color: #3f4e4f;
        text-decoration: none;
        flex-shrink: 0;
        transition: background .15s, border-color .15s, color .15s;
    }
    .ep-back-btn:hover { background: #dcd7c9; border-color: #a27b5c; color: #a27b5c; }
    .ep-back-btn .material-symbols-outlined { font-size: 19px; }

    /* Vertical divider */
    .ep-header-div {
        width: 1px; height: 32px; background: #e2e8f0; flex-shrink: 0;
    }

    /* Title block */
    .ep-header-title-block { flex: 1; min-width: 0; }
    .ep-header-title {
        font-size: 1.05rem; font-weight: 800; color: #2c3639;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .ep-header-sub {
        display: flex; align-items: center; gap: .5rem;
        margin-top: .25rem; flex-wrap: wrap;
    }
    .ep-header-chip {
        display: inline-flex; align-items: center; gap: .3rem;
        font-size: .68rem; font-weight: 700;
        padding: .18rem .6rem; border-radius: 99px;
        letter-spacing: .04em;
    }
    .ep-chip-id       { background: rgba(162,123,92,.1);  color: #a27b5c; }
    .ep-chip-status   { background: rgba(16,185,129,.1);  color: #059669; }
    .ep-chip-category { background: rgba(63,78,79,.08);   color: #3f4e4f; }
    .ep-chip-time     { background: rgba(100,116,139,.08); color: #64748b; }
    .ep-chip-status .status-dot {
        width: 6px; height: 6px; border-radius: 50%;
        background: #10b981; flex-shrink: 0;
    }

    /* Action buttons */
    .ep-header-actions { display: flex; gap: .5rem; align-items: center; margin-left: auto; }

    .ep-btn-ghost {
        display: flex; align-items: center; gap: .4rem;
        padding: .55rem 1.1rem; border-radius: 10px;
        border: 1px solid #e2e8f0; background: #fff; color: #3f4e4f;
        font-size: .85rem; font-weight: 600; cursor: pointer;
        font-family: 'Work Sans', sans-serif;
        transition: background .18s, border-color .18s;
    }
    .ep-btn-ghost:hover { background: #f7f7f6; border-color: #a27b5c; }
    .ep-btn-ghost .material-symbols-outlined { font-size: 18px; }

    .ep-btn-danger {
        display: flex; align-items: center; gap: .38rem;
        padding: .55rem 1rem; border-radius: 10px;
        border: 1.5px solid rgba(239,68,68,.25);
        background: #fef2f2; color: #dc2626;
        font-size: .82rem; font-weight: 700; cursor: pointer;
        font-family: 'Work Sans', sans-serif; transition: background .15s, border-color .15s;
    }
    .ep-btn-danger:hover { background: #fee2e2; border-color: rgba(239,68,68,.45); }
    .ep-btn-danger .material-symbols-outlined { font-size: 16px; }

    .ep-btn-primary {
        display: flex; align-items: center; gap: .38rem;
        padding: .6rem 1.25rem; border-radius: 10px;
        border: none; background: #a27b5c; color: #fff;
        font-size: .875rem; font-weight: 700; cursor: pointer;
        font-family: 'Work Sans', sans-serif;
        box-shadow: 0 4px 14px rgba(162,123,92,.3);
        transition: background .15s, transform .12s, box-shadow .15s;
    }
    .ep-btn-primary:hover {
        background: #8d6a4d;
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(162,123,92,.38);
    }
    .ep-btn-primary:active { transform: translateY(0); }
    .ep-btn-primary .material-symbols-outlined { font-size: 17px; }

    /* Hide old status bar */
    .ep-status-bar { display: none; }
    .ep-status-dot, .ep-status-text, .ep-status-sep,
    .ep-sku-badge, .ep-updated { display: none; }

    .ep-grid {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 1.25rem;
        align-items: start;
    }
    @@media(max-width:900px) { .ep-grid { grid-template-columns: 1fr; } }

    .ep-card {
        background: #fff; border: 1px solid #e2e8f0;
        border-radius: 16px; padding: 1.75rem;
        margin-bottom: 1.25rem; box-shadow: 0 1px 4px rgba(0,0,0,.04);
    }
    .ep-card:last-child { margin-bottom: 0; }

    .ep-card-title {
        font-size: .78rem; font-weight: 800; text-transform: uppercase;
        letter-spacing: .1em; color: #2c3639; margin-bottom: 1.25rem;
        display: flex; align-items: center; gap: .5rem;
    }
    .ep-card-title .material-symbols-outlined { font-size: 17px; color: #a27b5c; }

    .ep-field { margin-bottom: 1.25rem; }
    .ep-field:last-child { margin-bottom: 0; }

    .ep-label {
        display: block; font-size: .72rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .08em;
        color: rgba(44,54,57,.65); margin-bottom: .4rem;
    }
    .ep-label span { color: #ef4444; margin-left: 2px; }

    .ep-input, .ep-select, .ep-textarea {
        width: 100%; padding: .65rem 1rem;
        border: 1.5px solid #e2e8f0; border-radius: 10px;
        font-size: .9rem; font-family: 'Work Sans', sans-serif;
        color: #2c3639; background: #fff; outline: none;
        transition: border-color .2s, box-shadow .2s; box-sizing: border-box;
    }
    .ep-input:focus, .ep-select:focus, .ep-textarea:focus {
        border-color: #a27b5c;
        box-shadow: 0 0 0 3px rgba(162,123,92,.12);
    }
    .ep-input.error { border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239,68,68,.1); }
    .ep-textarea { resize: vertical; min-height: 100px; }
    .ep-input-group { position: relative; }
    .ep-input-prefix {
        position: absolute; left: .875rem; top: 50%; transform: translateY(-50%);
        font-size: .9rem; font-weight: 700; color: rgba(63,78,79,.45); pointer-events: none;
    }
    .ep-input-group .ep-input { padding-left: 1.75rem; }
    .ep-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .ep-counter { text-align: right; font-size: .7rem; color: rgba(63,78,79,.4); margin-top: .25rem; }
    .ep-val-msg { color: #ef4444; font-size: .72rem; font-weight: 600; margin-top: .3rem; display: none; }
    .ep-val-msg.show { display: block; }

    /* ── SALE BOX ── */
    .ep-sale-box {
        background: rgba(234,179,8,.06);
        border: 1.5px solid rgba(234,179,8,.3);
        border-radius: 12px; padding: 1rem; margin-top: .75rem; display: none;
    }
    .ep-sale-box.show { display: block; }

    /* ══════════════════════════════════════════
       4-SLOT IMAGE GALLERY
    ══════════════════════════════════════════ */
    .img-gallery-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .625rem;
        margin-bottom: 1.1rem;
    }

    .img-slot {
        position: relative;
        aspect-ratio: 1 / 1;
        border-radius: 11px;
        overflow: hidden;
        background: #f3f0eb;
        border: 2px solid #e2e8f0;
        cursor: pointer;
        transition: border-color .2s, box-shadow .2s;
    }
    .img-slot:hover { border-color: rgba(162,123,92,.55); box-shadow: 0 4px 14px rgba(162,123,92,.14); }

    /* Slot 0 = ảnh chính */
    .img-slot.slot-main { border-color: #a27b5c; }

    /* Badge số thứ tự */
    .slot-badge {
        position: absolute; top: .38rem; left: .38rem; z-index: 3;
        background: rgba(44,54,57,.68); color: #fff;
        font-family: 'Work Sans', sans-serif;
        font-size: .58rem; font-weight: 700;
        padding: .15rem .48rem; border-radius: 99px;
        letter-spacing: .04em; pointer-events: none;
        backdrop-filter: blur(4px);
    }
    .img-slot.slot-main .slot-badge { background: rgba(162,123,92,.85); }

    /* "Ảnh chính" label at bottom of slot 0 */
    .slot-main-label {
        position: absolute; bottom: 0; left: 0; right: 0; z-index: 3;
        background: rgba(162,123,92,.82);
        font-family: 'Work Sans', sans-serif;
        font-size: .58rem; font-weight: 700; color: #fff;
        text-align: center; padding: .22rem 0;
        letter-spacing: .08em; text-transform: uppercase;
        pointer-events: none;
    }

    /* Image fill */
    .img-slot img {
        width: 100%; height: 100%; object-fit: cover;
        display: block; transition: transform .35s;
    }
    .img-slot:hover img { transform: scale(1.04); }

    /* Empty state */
    .slot-empty {
        position: absolute; inset: 0;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: .35rem; color: rgba(63,78,79,.35);
        pointer-events: none;
    }
    .slot-empty .material-symbols-outlined { font-size: 26px; }
    .slot-empty span { font-size: .68rem; font-weight: 600; text-align: center; line-height: 1.35; }

    /* Hover overlay */
    .slot-overlay {
        position: absolute; inset: 0; z-index: 2;
        background: rgba(28,22,16,.52);
        display: flex; align-items: center; justify-content: center; gap: .45rem;
        opacity: 0; transition: opacity .2s;
    }
    .img-slot:hover .slot-overlay { opacity: 1; }

    .slot-action-btn {
        width: 30px; height: 30px; border-radius: 50%;
        background: rgba(255,255,255,.18); border: 1.5px solid rgba(255,255,255,.65);
        color: #fff; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: background .15s; backdrop-filter: blur(6px);
    }
    .slot-action-btn:hover { background: rgba(255,255,255,.36); }
    .slot-action-btn.del:hover { background: rgba(220,38,38,.55); border-color: rgba(220,38,38,.8); }
    .slot-action-btn.url-btn:hover { background: rgba(162,123,92,.7); border-color: rgba(162,123,92,.9); }
    .slot-action-btn .material-symbols-outlined { font-size: 15px; pointer-events: none; }

    /* ── URL Mini Modal ── */
    .url-modal-overlay {
        position: fixed; inset: 0; z-index: 10000;
        background: rgba(28,22,16,.45); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        opacity: 0; pointer-events: none;
        transition: opacity .2s;
    }
    .url-modal-overlay.open { opacity: 1; pointer-events: all; }

    .url-modal-box {
        background: #fff; border-radius: 16px; padding: 1.5rem 1.75rem;
        width: 100%; max-width: 420px;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
        transform: translateY(12px) scale(.97);
        transition: transform .22s cubic-bezier(.34,1.56,.64,1);
    }
    .url-modal-overlay.open .url-modal-box { transform: translateY(0) scale(1); }

    .url-modal-title {
        font-size: .78rem; font-weight: 800; text-transform: uppercase;
        letter-spacing: .1em; color: #2c3639; margin-bottom: 1rem;
        display: flex; align-items: center; gap: .45rem;
    }
    .url-modal-title .material-symbols-outlined { font-size: 17px; color: #a27b5c; }

    .url-modal-input {
        width: 100%; padding: .65rem 1rem;
        border: 1.5px solid #e2e8f0; border-radius: 10px;
        font-size: .88rem; font-family: 'Work Sans', sans-serif;
        color: #2c3639; background: #fafaf9; outline: none;
        transition: border-color .2s, box-shadow .2s;
        box-sizing: border-box; margin-bottom: 1rem;
    }
    .url-modal-input:focus {
        border-color: #a27b5c;
        box-shadow: 0 0 0 3px rgba(162,123,92,.12);
        background: #fff;
    }
    .url-modal-actions { display: flex; gap: .6rem; justify-content: flex-end; }

    .url-modal-cancel {
        padding: .55rem 1.1rem; border-radius: 10px;
        border: 1px solid #e2e8f0; background: #fff; color: #3f4e4f;
        font-size: .85rem; font-weight: 600; cursor: pointer;
        font-family: 'Work Sans', sans-serif; transition: background .15s;
    }
    .url-modal-cancel:hover { background: #f7f7f6; }

    .url-modal-apply {
        padding: .55rem 1.25rem; border-radius: 10px;
        border: none; background: #a27b5c; color: #fff;
        font-size: .85rem; font-weight: 700; cursor: pointer;
        font-family: 'Work Sans', sans-serif;
        box-shadow: 0 4px 12px rgba(162,123,92,.28);
        transition: background .15s, transform .12s;
    }
    .url-modal-apply:hover { background: rgba(162,123,92,.88); transform: translateY(-1px); }

    /* Upload hint bar */
    .img-hint {
        display: flex; align-items: center; gap: .45rem;
        background: rgba(162,123,92,.06);
        border: 1px dashed rgba(162,123,92,.3);
        border-radius: 9px; padding: .6rem .875rem;
        font-size: .73rem; color: rgba(63,78,79,.55);
        margin-top: .25rem;
    }
    .img-hint .material-symbols-outlined { font-size: 14px; color: #a27b5c; flex-shrink: 0; }

    /* ── DELETE MODAL ── */
    .ep-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,.5);
        backdrop-filter: blur(3px); z-index: 9998;
        display: flex; align-items: center; justify-content: center;
        opacity: 0; pointer-events: none; transition: opacity .25s;
    }
    .ep-overlay.show { opacity: 1; pointer-events: all; }
    .ep-modal {
        background: #fff; border-radius: 18px; padding: 2rem;
        width: 400px; max-width: 90vw;
        box-shadow: 0 20px 60px rgba(0,0,0,.18);
        transform: scale(.92); transition: transform .25s;
    }
    .ep-overlay.show .ep-modal { transform: scale(1); }
    .ep-modal-icon {
        width: 52px; height: 52px; background: #fef2f2; border-radius: 50%;
        display: flex; align-items: center; justify-content: center; margin-bottom: 1.1rem;
    }
    .ep-modal-icon .material-symbols-outlined { font-size: 26px; color: #dc2626; }
    .ep-modal h3 { font-size: 1.1rem; font-weight: 800; color: #2c3639; margin-bottom: .5rem; }
    .ep-modal p  { font-size: .85rem; color: rgba(63,78,79,.65); line-height: 1.6; margin-bottom: 1.5rem; }
    .ep-modal-actions { display: flex; gap: .625rem; justify-content: flex-end; }

    /* ── TOAST ── */
    .ep-toast {
        position: fixed; bottom: 1.75rem; right: 1.75rem;
        background: #2c3639; color: #dcd7c9;
        padding: .875rem 1.25rem; border-radius: 12px;
        font-size: .85rem; font-weight: 600;
        display: flex; align-items: center; gap: .625rem;
        box-shadow: 0 8px 28px rgba(0,0,0,.18);
        transform: translateY(20px); opacity: 0;
        transition: transform .3s ease, opacity .3s ease;
        z-index: 9999; pointer-events: none;
    }
    .ep-toast.show { transform: translateY(0); opacity: 1; }
    .ep-toast .material-symbols-outlined { font-size: 20px; color: #a27b5c; }
</style>

@* ── PAGE HEADER ── *@
<div class="ep-header">

    @* Back button — icon only *@
    <a href="@Url.Action("Index", "Product")" class="ep-back-btn" title="Quay lại danh sách">
        <span class="material-symbols-outlined">arrow_back</span>
    </a>

    @* Vertical divider *@
    <div class="ep-header-div"></div>

    @* Title + meta chips *@
    <div class="ep-header-title-block">
        <div class="ep-header-title">Chỉnh Sửa Sản Phẩm</div>
        <div class="ep-header-sub">
            <span class="ep-header-chip ep-chip-id">
                <span class="material-symbols-outlined" style="font-size:11px;">tag</span>
                #@Model.Id
            </span>
            <span class="ep-header-chip ep-chip-status">
                <span class="status-dot"></span>
                Còn hàng
            </span>
            @if (Model.Category != null)
            {
                <span class="ep-header-chip ep-chip-category">
                    <span class="material-symbols-outlined" style="font-size:11px;">category</span>
                    @Model.Category.Name
                </span>
            }
            <span class="ep-header-chip ep-chip-time">
                <span class="material-symbols-outlined" style="font-size:11px;">schedule</span>
                @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
            </span>
        </div>
    </div>

    @* Action buttons *@
    <div class="ep-header-actions">
        <button class="ep-btn-danger" type="button" onclick="showDeleteModal()">
            <span class="material-symbols-outlined">delete</span>
            Xóa
        </button>
        <button class="ep-btn-primary" type="button" onclick="submitForm()">
            <span class="material-symbols-outlined">save</span>
            Lưu thay đổi
        </button>
    </div>
</div>

@* ── STATUS BAR ── *@
<div class="ep-status-bar">
    <span class="ep-status-dot" id="statusDot"></span>
    <span class="ep-status-text" id="statusText">Còn hàng</span>
    <span class="ep-status-sep"></span>
    <span class="ep-sku-badge">ID: @Model.Id</span>
    <span class="ep-status-sep"></span>
    <span class="ep-sku-badge">Danh mục: @(Model.Category?.Name ?? "—")</span>
    <span class="ep-updated">Cập nhật: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
</div>

@* ── FORM ── *@
<form asp-action="Edit" asp-controller="Product" method="post" enctype="multipart/form-data" id="editForm" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ImageUrl" id="hiddenImageUrl" />

    @* Hidden inputs tracking URL của từng slot ảnh phụ (empty string = đã xóa) *@
    <input type="hidden" name="ExtraImageUrls[0]" id="extraUrl0" value="@ExtraUrl(0)" />
    <input type="hidden" name="ExtraImageUrls[1]" id="extraUrl1" value="@ExtraUrl(1)" />
    <input type="hidden" name="ExtraImageUrls[2]" id="extraUrl2" value="@ExtraUrl(2)" />

    @* Hidden inputs lưu ID ảnh phụ hiện có (để controller biết cần update hay insert) *@
    <input type="hidden" name="ExtraImageIds[0]" value="@ExtraId(0)" />
    <input type="hidden" name="ExtraImageIds[1]" value="@ExtraId(1)" />
    <input type="hidden" name="ExtraImageIds[2]" value="@ExtraId(2)" />

    <div class="ep-grid">

        @* ════════════════════════
           CỘT TRÁI — Thông tin
        ════════════════════════ *@
        <div>

            @* Thông tin cơ bản *@
            <div class="ep-card">
                <div class="ep-card-title">
                    <span class="material-symbols-outlined">info</span>Thông Tin Cơ Bản
                </div>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div style="background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.25);border-radius:10px;padding:.75rem 1rem;margin-bottom:1rem;color:#b91c1c;font-size:.85rem;">
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                <div class="ep-field">
                    <label class="ep-label" for="Name">Tên sản phẩm <span>*</span></label>
                    <input class="ep-input" asp-for="Name" id="Name"
                           placeholder="VD: Cà Phê Sữa Đá..." maxlength="100"
                           oninput="updateCounter('Name','nameCounter',100)" />
                    <div class="ep-counter"><span id="nameCounter">@(Model.Name?.Length ?? 0)</span>/100</div>
                    <div class="ep-val-msg" id="nameErr">Vui lòng nhập tên sản phẩm.</div>
                </div>

                <div class="ep-field">
                    <label class="ep-label" for="Description">Mô tả</label>
                    <textarea class="ep-textarea" asp-for="Description" id="Description"
                              placeholder="Mô tả hương vị, nguyên liệu..." maxlength="500" rows="4"
                              oninput="updateCounter('Description','descCounter',500)">@Model.Description</textarea>
                    <div class="ep-counter"><span id="descCounter">@(Model.Description?.Length ?? 0)</span>/500</div>
                </div>

                <div class="ep-row">
                    <div class="ep-field">
                        <label class="ep-label" for="Price">Giá gốc (₫) <span>*</span></label>
                        <div class="ep-input-group">
                            <span class="ep-input-prefix">₫</span>
                            <input class="ep-input" type="number" asp-for="Price" id="Price"
                                   placeholder="0" min="0" step="500" oninput="calcSalePrice()" />
                        </div>
                        <div class="ep-val-msg" id="priceErr">Vui lòng nhập giá hợp lệ.</div>
                    </div>
                    <div class="ep-field">
                        <label class="ep-label" for="CategoryId">Danh mục <span>*</span></label>
                        <select class="ep-select" asp-for="CategoryId" id="CategoryId">
                            <option value="">-- Chọn danh mục --</option>
                            @if (categories != null)
                            {
                                @foreach (var cat in categories)
                                {
                                    if (cat.Id == Model.CategoryId)
                                    { <option value="@cat.Id" selected>@cat.Name</option> }
                                    else
                                    { <option value="@cat.Id">@cat.Name</option> }
                                }
                            }
                        </select>
                        <div class="ep-val-msg" id="catErr">Vui lòng chọn danh mục.</div>
                    </div>
                </div>
            </div>

            @* Khuyến mãi *@
            <div class="ep-card">
                <div class="ep-card-title">
                    <span class="material-symbols-outlined">local_offer</span>Khuyến Mãi / Sale
                </div>

                <div style="display:flex;align-items:center;justify-content:space-between;padding:.75rem 1rem;border:1px solid #e2e8f0;border-radius:10px;">
                    <div style="display:flex;align-items:center;gap:.6rem;">
                        <span class="material-symbols-outlined" style="font-size:18px;color:#a27b5c;">local_offer</span>
                        <div>
                            <div style="font-size:.85rem;font-weight:600;color:#2c3639;">Bật khuyến mãi</div>
                            <div style="font-size:.72rem;color:rgba(63,78,79,.45);">Hiện badge "Sale" và giá sau giảm</div>
                        </div>
                    </div>
                    <div style="position:relative;display:inline-block;width:40px;height:22px;flex-shrink:0;">
                        <input type="checkbox" id="toggleSale" asp-for="IsOnSale"
                               onchange="toggleSaleBox(this.checked)" style="display:none;" />
                        <span id="saleSlider"
                              onclick="var cb=document.getElementById('toggleSale');cb.checked=!cb.checked;toggleSaleBox(cb.checked);"
                              style="position:absolute;inset:0;border-radius:11px;cursor:pointer;transition:background .2s;background:#e2e8f0;">
                            <span id="saleThumb"
                                  style="position:absolute;width:16px;height:16px;left:3px;top:3px;background:#fff;border-radius:50%;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);display:block;"></span>
                        </span>
                    </div>
                </div>

                <div class="ep-sale-box" id="saleBox">
                    <div class="ep-field" style="margin-bottom:.75rem;">
                        <label class="ep-label">Phần trăm giảm (%)</label>
                        <input class="ep-input" type="number" asp-for="DiscountPercent" id="DiscountPercent"
                               placeholder="VD: 10" min="0" max="100" step="1" oninput="calcSalePrice()" />
                    </div>
                    <div style="padding:.75rem 1rem;background:#fff;border-radius:10px;border:1px solid rgba(234,179,8,.25);">
                        <div style="font-size:.72rem;color:rgba(63,78,79,.5);margin-bottom:2px;">Giá sau giảm:</div>
                        <div id="salePriceDisplay" style="font-size:1.15rem;font-weight:800;color:#d97706;">—</div>
                    </div>
                </div>
            </div>

        </div>

        @* ════════════════════════
           CỘT PHẢI — Hình ảnh
        ════════════════════════ *@
        <div>
            <div class="ep-card">
                <div class="ep-card-title">
                    <span class="material-symbols-outlined">photo_library</span>
                    Hình Ảnh Sản Phẩm
                    <span style="margin-left:auto;font-size:.65rem;font-weight:500;color:#94a3b8;letter-spacing:.03em;text-transform:none;">
                        Tối đa 4 ảnh
                    </span>
                </div>

                @* ── 4-SLOT GRID ── *@
                <div class="img-gallery-grid">

                    @* SLOT 0 — Ảnh chính *@
                    <div class="img-slot slot-main" id="slot0" onclick="slotClick(0)">
                        <span class="slot-badge">1</span>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img id="slotImg0" src="@Model.ImageUrl" alt="Ảnh chính" />
                            <div class="slot-overlay">
                                <button type="button" class="slot-action-btn"
                                        onclick="event.stopPropagation();triggerFile(0)" title="Tải file lên">
                                    <span class="material-symbols-outlined">upload</span>
                                </button>
                                <button type="button" class="slot-action-btn url-btn"
                                        onclick="event.stopPropagation();openUrlModal(0)" title="Dán URL">
                                    <span class="material-symbols-outlined">link</span>
                                </button>
                                <button type="button" class="slot-action-btn del"
                                        onclick="event.stopPropagation();clearSlot(0)" title="Xóa">
                                    <span class="material-symbols-outlined">delete</span>
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="slot-empty" id="slotEmpty0">
                                <span class="material-symbols-outlined">add_photo_alternate</span>
                                <span>Thêm ảnh chính</span>
                            </div>
                        }
                        <div class="slot-main-label">Ảnh chính</div>
                    </div>

                    @* SLOTS 1-3 — Ảnh phụ *@
                    @for (int s = 1; s <= 3; s++)
                    {
                        var sUrl = ExtraUrl(s - 1);
                        var sIdx = s;
                        <div class="img-slot" id="slot@(sIdx)" onclick="slotClick(@sIdx)">
                            <span class="slot-badge">@(sIdx + 1)</span>
                            @if (!string.IsNullOrEmpty(sUrl))
                            {
                                <img id="slotImg@(sIdx)" src="@sUrl" alt="Ảnh @(sIdx+1)" />
                                <div class="slot-overlay">
                                    <button type="button" class="slot-action-btn"
                                            onclick="event.stopPropagation();triggerFile(@sIdx)" title="Tải file lên">
                                        <span class="material-symbols-outlined">upload</span>
                                    </button>
                                    <button type="button" class="slot-action-btn url-btn"
                                            onclick="event.stopPropagation();openUrlModal(@sIdx)" title="Dán URL">
                                        <span class="material-symbols-outlined">link</span>
                                    </button>
                                    <button type="button" class="slot-action-btn del"
                                            onclick="event.stopPropagation();clearSlot(@sIdx)" title="Xóa">
                                        <span class="material-symbols-outlined">delete</span>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="slot-empty" id="slotEmpty@(sIdx)">
                                    <span class="material-symbols-outlined">add_photo_alternate</span>
                                    <span>Chưa có ảnh</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                @* ── Hidden file inputs — một per slot ── *@
                <input type="file" id="fileSlot0" name="ImageFile"       accept="image/*" style="display:none;" onchange="handleFile(0,this)" />
                <input type="file" id="fileSlot1" name="ExtraImages[0]"  accept="image/*" style="display:none;" onchange="handleFile(1,this)" />
                <input type="file" id="fileSlot2" name="ExtraImages[1]"  accept="image/*" style="display:none;" onchange="handleFile(2,this)" />
                <input type="file" id="fileSlot3" name="ExtraImages[2]"  accept="image/*" style="display:none;" onchange="handleFile(3,this)" />

                @* ── URL paste cho ảnh chính ── *@
                <div style="margin-top:.75rem;">
                    <label class="ep-label" style="margin-bottom:.4rem;">Hoặc dán URL ảnh chính</label>
                    <div style="display:flex;gap:.5rem;">
                        <input class="ep-input" id="urlInput" placeholder="https://..."
                               value="@Model.ImageUrl"
                               style="font-size:.83rem;padding:.52rem .875rem;"
                               oninput="applyUrlPreview()" />
                    </div>
                </div>

                @* ── Drag & drop zone ── *@
                <div id="dropZone" style="margin-top:.875rem;border:2px dashed #dcd7c9;border-radius:11px;padding:1.1rem 1rem;text-align:center;cursor:pointer;background:#fafaf9;transition:border-color .2s,background .2s;"
                     onclick="triggerFile(0)"
                     ondragover="event.preventDefault();this.style.borderColor='#a27b5c';"
                     ondragleave="this.style.borderColor='';"
                     ondrop="handleDrop(event)">
                    <span class="material-symbols-outlined" style="font-size:24px;color:#a27b5c;display:block;margin-bottom:.3rem;">cloud_upload</span>
                    <p style="font-size:.75rem;color:rgba(63,78,79,.6);margin:0;line-height:1.5;">
                        <strong style="color:#a27b5c;">Kéo &amp; thả</strong> hoặc nhấn để tải ảnh chính lên<br/>
                        <span style="color:rgba(63,78,79,.4);font-size:.7rem;">PNG, JPG, WEBP — tối đa 5MB</span>
                    </p>
                </div>

                @* Hint *@
                <div class="img-hint" style="margin-top:.75rem;">
                    <span class="material-symbols-outlined">info</span>
                    Nhấn ô ảnh để chọn: tải file lên <span style="font-weight:700;color:#a27b5c;">↑</span> hoặc dán URL <span style="font-weight:700;color:#a27b5c;">🔗</span>
                </div>
            </div>
        </div>

    </div>
</form>

@* ── URL Input Modal (dùng cho tất cả slots) ── *@
<div class="url-modal-overlay" id="urlModal" onclick="closeUrlModal(event)">
    <div class="url-modal-box">
        <div class="url-modal-title">
            <span class="material-symbols-outlined">link</span>
            <span id="urlModalTitle">Dán URL ảnh</span>
        </div>
        <input class="url-modal-input" type="url" id="urlModalInput"
               placeholder="https://example.com/image.jpg"
               onkeydown="if(event.key==='Enter'){event.preventDefault();applyUrlModal();}" />
        <div style="font-size:.72rem;color:#94a3b8;margin-top:-.6rem;margin-bottom:.875rem;">
            Hỗ trợ liên kết ảnh từ Google, Pinterest, Unsplash...
        </div>
        <div class="url-modal-actions">
            <button type="button" class="url-modal-cancel" onclick="closeUrlModal()">Hủy</button>
            <button type="button" class="url-modal-apply" onclick="applyUrlModal()">
                <span style="display:flex;align-items:center;gap:.35rem;">
                    <span class="material-symbols-outlined" style="font-size:16px;">check</span> Áp dụng
                </span>
            </button>
        </div>
    </div>
</div>

@* ── Choose method popup (file upload vs URL) khi click vào slot trống ── *@
<div id="choosePopup"
     style="position:fixed;z-index:10001;display:none;background:#fff;border-radius:14px;
            padding:.75rem;box-shadow:0 12px 40px rgba(44,54,57,.18);
            border:1px solid rgba(162,123,92,.2);min-width:200px;">
    <div style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;
                color:#94a3b8;padding:.25rem .5rem .6rem;">Thêm ảnh bằng</div>
    <button type="button" id="chooseUpload"
            style="width:100%;display:flex;align-items:center;gap:.6rem;padding:.6rem .75rem;
                   border:none;background:transparent;border-radius:9px;cursor:pointer;
                   font-family:'Work Sans',sans-serif;font-size:.85rem;font-weight:600;color:#2c3639;
                   transition:background .15s;text-align:left;"
            onmouseover="this.style.background='rgba(162,123,92,.08)'"
            onmouseout="this.style.background='transparent'">
        <span class="material-symbols-outlined" style="font-size:18px;color:#a27b5c;">upload</span>
        Tải file lên
    </button>
    <button type="button" id="chooseUrl"
            style="width:100%;display:flex;align-items:center;gap:.6rem;padding:.6rem .75rem;
                   border:none;background:transparent;border-radius:9px;cursor:pointer;
                   font-family:'Work Sans',sans-serif;font-size:.85rem;font-weight:600;color:#2c3639;
                   transition:background .15s;text-align:left;"
            onmouseover="this.style.background='rgba(162,123,92,.08)'"
            onmouseout="this.style.background='transparent'">
        <span class="material-symbols-outlined" style="font-size:18px;color:#a27b5c;">link</span>
        Dán URL ảnh
    </button>
</div>
<div id="chooseBackdrop"
     style="position:fixed;inset:0;z-index:10000;display:none;"
     onclick="closeChoosePopup()"></div>

@* Delete modal *@
<div class="ep-overlay" id="deleteOverlay">
    <div class="ep-modal">
        <div class="ep-modal-icon"><span class="material-symbols-outlined">delete_forever</span></div>
        <h3>Xóa sản phẩm này?</h3>
        <p>Hành động này không thể hoàn tác. Sản phẩm <strong>@Model.Name</strong> sẽ bị xóa vĩnh viễn.</p>
        <div class="ep-modal-actions">
            <button class="ep-btn-ghost" type="button" onclick="closeModal()">Hủy bỏ</button>
            <form asp-action="Delete" asp-controller="Product" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="ep-btn-danger">
                    <span class="material-symbols-outlined">delete</span> Xác nhận xóa
                </button>
            </form>
        </div>
    </div>
</div>

<div class="ep-toast" id="toast">
    <span class="material-symbols-outlined">check_circle</span>
    <span id="toastMsg">Đã lưu thay đổi!</span>
</div>

@{
    var epToastMsg = TempData["Success"]?.ToString() ?? "";
}
<div id="ep-toast-bridge" data-msg="@epToastMsg" style="display:none;"></div>

@section Scripts {
    <script>
        // ── Init ─────────────────────────────────────────────
        (function init() {
            var hidden   = document.getElementById('hiddenImageUrl');
            var urlInput = document.getElementById('urlInput');
            if (hidden && urlInput && urlInput.value && !hidden.value) {
                hidden.value = urlInput.value;
            }
            var saleChecked = document.getElementById('toggleSale').checked;
            toggleSaleBox(saleChecked);
            calcSalePrice();
        })();

        // ── Sale toggle ───────────────────────────────────────
        function toggleSaleBox(on) {
            var box    = document.getElementById('saleBox');
            var slider = document.getElementById('saleSlider');
            var thumb  = document.getElementById('saleThumb');
            if (on) {
                box.classList.add('show');
                slider.style.background = '#a27b5c';
                thumb.style.transform   = 'translateX(18px)';
            } else {
                box.classList.remove('show');
                slider.style.background = '#e2e8f0';
                thumb.style.transform   = 'translateX(0)';
            }
            calcSalePrice();
        }

        function calcSalePrice() {
            var price    = parseFloat(document.getElementById('Price').value)    || 0;
            var discount = parseFloat(document.getElementById('DiscountPercent').value) || 0;
            var el = document.getElementById('salePriceDisplay');
            if (!el) return;
            if (price > 0 && discount > 0)
                el.textContent = (price * (1 - discount / 100)).toLocaleString('vi-VN') + '₫';
            else
                el.textContent = price > 0 ? price.toLocaleString('vi-VN') + '₫' : '—';
        }

        // ══════════════════════════════════════════════════════
        //  SLOT CLICK — mở choose popup (upload / URL)
        // ══════════════════════════════════════════════════════
        var _activeSlot = 0;

        function slotClick(slot) {
            // Nếu slot đã có ảnh, overlay xử lý → không làm gì thêm
            var img = document.getElementById('slotImg' + slot);
            if (img) return; // overlay handles it
            // Slot trống → mở choose popup
            openChoosePopup(slot, document.getElementById('slot' + slot));
        }

        // ── Choose popup ──────────────────────────────────────
        function openChoosePopup(slot, anchorEl) {
            _activeSlot = slot;
            var popup    = document.getElementById('choosePopup');
            var backdrop = document.getElementById('chooseBackdrop');

            var rect = anchorEl.getBoundingClientRect();
            popup.style.top  = (rect.top + window.scrollY + rect.height / 2 - 30) + 'px';
            popup.style.left = (rect.right + window.scrollX + 8) + 'px';

            // Clamp nếu ra ngoài viewport
            popup.style.display = 'block';
            var pw = popup.offsetWidth;
            var ph = popup.offsetHeight;
            if (rect.right + pw + 16 > window.innerWidth) {
                popup.style.left = Math.max(8, rect.left + window.scrollX - pw - 8) + 'px';
            }
            var topPx = parseFloat(popup.style.top);
            if (topPx + ph > window.scrollY + window.innerHeight - 8) {
                popup.style.top = (window.scrollY + window.innerHeight - ph - 12) + 'px';
            }

            backdrop.style.display = 'block';

            document.getElementById('chooseUpload').onclick = function() {
                closeChoosePopup();
                triggerFile(_activeSlot);
            };
            document.getElementById('chooseUrl').onclick = function() {
                closeChoosePopup();
                openUrlModal(_activeSlot);
            };
        }

        function closeChoosePopup() {
            document.getElementById('choosePopup').style.display    = 'none';
            document.getElementById('chooseBackdrop').style.display = 'none';
        }

        // ── File inputs ───────────────────────────────────────
        function triggerFile(slot) {
            document.getElementById('fileSlot' + slot).click();
        }

        function handleFile(slot, input) {
            var file = input.files[0];
            if (!file) return;
            var reader = new FileReader();
            reader.onload = function(e) { applyPreview(slot, e.target.result); };
            reader.readAsDataURL(file);
            if (slot === 0) {
                document.getElementById('hiddenImageUrl').value = '';
                document.getElementById('urlInput').value       = '';
            } else {
                var extraEl = document.getElementById('extraUrl' + (slot - 1));
                if (extraEl) extraEl.value = 'new_file';
            }
        }

        // ── URL modal ─────────────────────────────────────────
        function openUrlModal(slot) {
            _activeSlot = slot;
            var modal   = document.getElementById('urlModal');
            var input   = document.getElementById('urlModalInput');
            var title   = document.getElementById('urlModalTitle');

            title.textContent = slot === 0 ? 'Dán URL ảnh chính' : 'Dán URL ảnh phụ ' + (slot + 1);

            // Pre-fill URL hiện tại của slot
            var currentUrl = '';
            if (slot === 0) {
                currentUrl = document.getElementById('urlInput').value;
            } else {
                var extraEl = document.getElementById('extraUrl' + (slot - 1));
                if (extraEl && extraEl.value !== 'new_file') currentUrl = extraEl.value;
            }
            input.value = currentUrl;

            modal.classList.add('open');
            setTimeout(function() { input.focus(); input.select(); }, 120);
        }

        function closeUrlModal(e) {
            if (e && e.target !== document.getElementById('urlModal')) return;
            document.getElementById('urlModal').classList.remove('open');
        }

        function applyUrlModal() {
            var url = document.getElementById('urlModalInput').value.trim();
            if (!url) return;

            document.getElementById('urlModal').classList.remove('open');

            if (_activeSlot === 0) {
                // Slot 0: cập nhật URL input chính + hiddenImageUrl
                document.getElementById('urlInput').value        = url;
                document.getElementById('hiddenImageUrl').value  = url;
                // Clear file input
                document.getElementById('fileSlot0').value       = '';
                applyPreview(0, url);
            } else {
                // Slots 1-3: cập nhật extraUrl hidden + preview
                var extraEl = document.getElementById('extraUrl' + (_activeSlot - 1));
                if (extraEl) extraEl.value = url;
                // Clear file input cho slot này
                document.getElementById('fileSlot' + _activeSlot).value = '';
                applyPreview(_activeSlot, url);
            }
        }

        // ── Preview helpers ───────────────────────────────────
        function applyUrlPreview() {
            var url = document.getElementById('urlInput').value.trim();
            document.getElementById('hiddenImageUrl').value = url;
            if (url) applyPreview(0, url);
        }

        function applyPreview(slot, src) {
            var slotEl   = document.getElementById('slot' + slot);
            var existImg = document.getElementById('slotImg' + slot);
            var emptyEl  = document.getElementById('slotEmpty' + slot);

            if (emptyEl) emptyEl.style.display = 'none';

            if (existImg) {
                existImg.src = src;
            } else {
                var img     = document.createElement('img');
                img.id      = 'slotImg' + slot;
                img.src     = src;
                img.alt     = 'Ảnh ' + (slot + 1);
                var overlay = slotEl.querySelector('.slot-overlay');
                if (overlay) slotEl.insertBefore(img, overlay);
                else         slotEl.appendChild(img);
            }

            ensureOverlay(slot, slotEl);
        }

        function ensureOverlay(slot, slotEl) {
            if (slotEl.querySelector('.slot-overlay')) return;
            var ov = document.createElement('div');
            ov.className = 'slot-overlay';
            ov.innerHTML =
                '<button type="button" class="slot-action-btn" onclick="event.stopPropagation();triggerFile(' + slot + ')" title="Tải file lên">' +
                    '<span class="material-symbols-outlined">upload</span>' +
                '</button>' +
                '<button type="button" class="slot-action-btn url-btn" onclick="event.stopPropagation();openUrlModal(' + slot + ')" title="Dán URL">' +
                    '<span class="material-symbols-outlined">link</span>' +
                '</button>' +
                '<button type="button" class="slot-action-btn del" onclick="event.stopPropagation();clearSlot(' + slot + ')" title="Xóa">' +
                    '<span class="material-symbols-outlined">delete</span>' +
                '</button>';
            slotEl.appendChild(ov);
        }

        function clearSlot(slot) {
            var slotEl   = document.getElementById('slot' + slot);
            var existImg = document.getElementById('slotImg' + slot);
            var emptyEl  = document.getElementById('slotEmpty' + slot);
            var overlay  = slotEl.querySelector('.slot-overlay');

            if (existImg) existImg.remove();
            if (overlay)  overlay.remove();

            var fi = document.getElementById('fileSlot' + slot);
            if (fi) fi.value = '';

            if (emptyEl) {
                emptyEl.style.display = '';
            } else {
                var empty = document.createElement('div');
                empty.id        = 'slotEmpty' + slot;
                empty.className = 'slot-empty';
                empty.innerHTML = '<span class="material-symbols-outlined">add_photo_alternate</span><span>Chưa có ảnh</span>';
                slotEl.appendChild(empty);
            }

            if (slot === 0) {
                document.getElementById('hiddenImageUrl').value = '';
                document.getElementById('urlInput').value       = '';
            } else {
                var extraEl = document.getElementById('extraUrl' + (slot - 1));
                if (extraEl) extraEl.value = '';
            }
        }

        // ── Drag & Drop ───────────────────────────────────────
        function handleDrop(e) {
            e.preventDefault();
            document.getElementById('dropZone').style.borderColor = '';
            var file = e.dataTransfer.files[0];
            if (!file || !file.type.startsWith('image/')) return;
            var dt = new DataTransfer();
            dt.items.add(file);
            var fi = document.getElementById('fileSlot0');
            fi.files = dt.files;
            var reader = new FileReader();
            reader.onload = function(ev) { applyPreview(0, ev.target.result); };
            reader.readAsDataURL(file);
            document.getElementById('hiddenImageUrl').value = '';
            document.getElementById('urlInput').value       = '';
        }

        // ── Counter ───────────────────────────────────────────
        function updateCounter(fId, cId, max) {
            var el = document.getElementById(fId);
            var ct = document.getElementById(cId);
            if (el && ct) ct.textContent = el.value.length;
        }

        // ── Submit ────────────────────────────────────────────
        function submitForm() {
            var valid = true;
            var checks = [
                { id: 'Name',       err: 'nameErr',  isNum: false },
                { id: 'Price',      err: 'priceErr', isNum: true  },
                { id: 'CategoryId', err: 'catErr',   isNum: false },
            ];
            checks.forEach(function(c) {
                var el    = document.getElementById(c.id);
                var errEl = document.getElementById(c.err);
                var bad   = c.isNum
                    ? (!el.value || parseFloat(el.value) < 0)
                    : !el.value.trim();
                if (bad) { el.classList.add('error');    errEl.classList.add('show');    valid = false; }
                else     { el.classList.remove('error'); errEl.classList.remove('show'); }
            });
            if (!valid) { showToast('⚠ Vui lòng điền đầy đủ thông tin.'); return; }

            // Sync hiddenImageUrl
            var urlVal = document.getElementById('urlInput').value.trim();
            var hidden = document.getElementById('hiddenImageUrl');
            if (urlVal && !document.getElementById('fileSlot0').files.length) {
                hidden.value = urlVal;
            }

            // Sync extraUrl cho các slot URL-based (không có file mới)
            for (var s = 1; s <= 3; s++) {
                var fi = document.getElementById('fileSlot' + s);
                var eu = document.getElementById('extraUrl' + (s - 1));
                if (eu && eu.value === 'new_file' && fi && fi.files.length > 0) {
                    // có file mới → controller xử lý qua ExtraImages
                    eu.value = 'new_file'; // keep marker
                }
            }

            document.getElementById('editForm').submit();
        }

        // ── Keyboard shortcut: Esc đóng URL modal ─────────────
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                document.getElementById('urlModal').classList.remove('open');
                closeChoosePopup();
            }
        });

        // ── Modal & Toast ─────────────────────────────────────
        function showDeleteModal() { document.getElementById('deleteOverlay').classList.add('show'); }
        function closeModal()      { document.getElementById('deleteOverlay').classList.remove('show'); }

        function showToast(msg) {
            var t = document.getElementById('toast');
            document.getElementById('toastMsg').textContent = msg || 'Đã lưu!';
            t.classList.add('show');
            setTimeout(function() { t.classList.remove('show'); }, 3200);
        }

        (function() {
            var bridge = document.getElementById('ep-toast-bridge');
            if (!bridge) return;
            var msg = bridge.getAttribute('data-msg');
            if (msg) setTimeout(function() { showToast(msg); }, 300);
        })();
    </script>
}
