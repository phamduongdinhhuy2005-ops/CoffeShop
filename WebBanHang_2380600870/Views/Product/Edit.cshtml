@model WebBanHang_2380600870.Models.Product
@{
    ViewData["Title"] = "Chỉnh Sửa Sản Phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActivePage"] = "Product";
    ViewData["Breadcrumb"] = "<a href='/Product'>Sản phẩm</a> <span class='material-symbols-outlined'>chevron_right</span> Chỉnh sửa";
    var categories = ViewBag.Categories as IEnumerable<WebBanHang_2380600870.Models.Category>;
}

<style>
    .ep-header {
        background: #fff;
        border-bottom: 1px solid #e2e8f0;
        padding: 1.25rem 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .ep-back-btn {
        display: flex;
        align-items: center;
        gap: .4rem;
        color: #3f4e4f;
        font-size: .85rem;
        font-weight: 600;
        text-decoration: none;
        padding: .5rem .875rem;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: #f7f7f6;
        transition: background .18s, border-color .18s;
    }

        .ep-back-btn:hover {
            background: #dcd7c9;
            border-color: #a27b5c;
            color: #2c3639;
        }

        .ep-back-btn .material-symbols-outlined {
            font-size: 18px;
        }

    .ep-header-title {
        font-size: 1.4rem;
        font-weight: 900;
        color: #2c3639;
    }

    .ep-header-sub {
        font-size: .78rem;
        color: rgba(63,78,79,.6);
        margin-top: 2px;
    }

    .ep-header-actions {
        display: flex;
        gap: .6rem;
    }

    .ep-btn-ghost {
        display: flex;
        align-items: center;
        gap: .4rem;
        padding: .55rem 1.1rem;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: #fff;
        color: #3f4e4f;
        font-size: .85rem;
        font-weight: 600;
        cursor: pointer;
        font-family: 'Work Sans', sans-serif;
        transition: background .18s, border-color .18s;
    }

        .ep-btn-ghost:hover {
            background: #f7f7f6;
            border-color: #a27b5c;
        }

        .ep-btn-ghost .material-symbols-outlined {
            font-size: 18px;
        }

    .ep-btn-danger {
        display: flex;
        align-items: center;
        gap: .4rem;
        padding: .55rem 1.1rem;
        border-radius: 10px;
        border: none;
        background: #fef2f2;
        color: #dc2626;
        font-size: .85rem;
        font-weight: 600;
        cursor: pointer;
        font-family: 'Work Sans', sans-serif;
        transition: background .18s;
    }

        .ep-btn-danger:hover {
            background: #fee2e2;
        }

        .ep-btn-danger .material-symbols-outlined {
            font-size: 18px;
        }

    .ep-btn-primary {
        display: flex;
        align-items: center;
        gap: .4rem;
        padding: .55rem 1.25rem;
        border-radius: 10px;
        border: none;
        background: #a27b5c;
        color: #fff;
        font-size: .85rem;
        font-weight: 700;
        cursor: pointer;
        font-family: 'Work Sans', sans-serif;
        box-shadow: 0 4px 14px rgba(162,123,92,.3);
        transition: background .18s, transform .15s;
    }

        .ep-btn-primary:hover {
            background: rgba(162,123,92,.88);
            transform: translateY(-1px);
        }

        .ep-btn-primary .material-symbols-outlined {
            font-size: 18px;
        }

    .ep-status-bar {
        display: flex;
        align-items: center;
        gap: .75rem;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: .875rem 1.25rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

    .ep-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #10b981;
        flex-shrink: 0;
    }

    .ep-status-text {
        font-size: .85rem;
        font-weight: 600;
        color: #3f4e4f;
    }

    .ep-status-sep {
        width: 1px;
        height: 18px;
        background: #e2e8f0;
    }

    .ep-sku-badge {
        font-size: .72rem;
        font-weight: 700;
        color: rgba(63,78,79,.5);
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .ep-updated {
        margin-left: auto;
        font-size: .78rem;
        color: rgba(63,78,79,.45);
    }

    .ep-grid {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 1.25rem;
        align-items: start;
    }

    @@media(max-width:860px) {
        .ep-grid {
            grid-template-columns: 1fr;
        }
    }

    .ep-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 1.75rem;
        margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0,0,0,.04);
    }

        .ep-card:last-child {
            margin-bottom: 0;
        }

    .ep-card-title {
        font-size: .78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: #2c3639;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .ep-card-title .material-symbols-outlined {
            font-size: 17px;
            color: #a27b5c;
        }

    .ep-field {
        margin-bottom: 1.25rem;
    }

        .ep-field:last-child {
            margin-bottom: 0;
        }

    .ep-label {
        display: block;
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: rgba(44,54,57,.65);
        margin-bottom: .4rem;
    }

        .ep-label span {
            color: #ef4444;
            margin-left: 2px;
        }

    .ep-input, .ep-select, .ep-textarea {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: .9rem;
        font-family: 'Work Sans', sans-serif;
        color: #2c3639;
        background: #fff;
        outline: none;
        transition: border-color .2s, box-shadow .2s;
        box-sizing: border-box;
    }

        .ep-input:focus, .ep-select:focus, .ep-textarea:focus {
            border-color: #a27b5c;
            box-shadow: 0 0 0 3px rgba(162,123,92,.12);
        }

        .ep-input.error {
            border-color: #ef4444;
            box-shadow: 0 0 0 3px rgba(239,68,68,.1);
        }

    .ep-textarea {
        resize: vertical;
        min-height: 100px;
    }

    .ep-input-group {
        position: relative;
    }

    .ep-input-prefix {
        position: absolute;
        left: .875rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: .9rem;
        font-weight: 700;
        color: rgba(63,78,79,.45);
        pointer-events: none;
    }

    .ep-input-group .ep-input {
        padding-left: 1.75rem;
    }

    .ep-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .ep-counter {
        text-align: right;
        font-size: .7rem;
        color: rgba(63,78,79,.4);
        margin-top: .25rem;
    }

    .ep-val-msg {
        color: #ef4444;
        font-size: .72rem;
        font-weight: 600;
        margin-top: .3rem;
        display: none;
    }

        .ep-val-msg.show {
            display: block;
        }

    .ep-img-current {
        width: 100%;
        aspect-ratio: 1;
        border-radius: 12px;
        object-fit: cover;
        border: 2px solid #e2e8f0;
        margin-bottom: .875rem;
        background: #f7f7f6;
    }

    .ep-img-placeholder {
        width: 100%;
        aspect-ratio: 1;
        border-radius: 12px;
        border: 2px dashed #dcd7c9;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        background: #f7f7f6;
        margin-bottom: .875rem;
        color: rgba(63,78,79,.4);
        font-size: .82rem;
    }

        .ep-img-placeholder .material-symbols-outlined {
            font-size: 36px;
        }

    .ep-upload-drop {
        border: 2px dashed #dcd7c9;
        border-radius: 12px;
        padding: 1.5rem 1rem;
        text-align: center;
        cursor: pointer;
        transition: border-color .2s, background .2s;
        background: #fafaf9;
    }

        .ep-upload-drop:hover {
            border-color: #a27b5c;
            background: rgba(162,123,92,.04);
        }

        .ep-upload-drop .material-symbols-outlined {
            font-size: 28px;
            color: #a27b5c;
            display: block;
            margin-bottom: .5rem;
        }

        .ep-upload-drop p {
            font-size: .78rem;
            color: rgba(63,78,79,.6);
            margin: 0;
            line-height: 1.5;
        }

        .ep-upload-drop strong {
            color: #a27b5c;
            font-weight: 700;
        }

    #fileInput {
        display: none;
    }

    .ep-sale-box {
        background: rgba(234,179,8,.06);
        border: 1.5px solid rgba(234,179,8,.3);
        border-radius: 12px;
        padding: 1rem;
        margin-top: .75rem;
        display: none;
    }

        .ep-sale-box.show {
            display: block;
        }

    .ep-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.5);
        backdrop-filter: blur(3px);
        z-index: 9998;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity .25s;
    }

        .ep-overlay.show {
            opacity: 1;
            pointer-events: all;
        }

    .ep-modal {
        background: #fff;
        border-radius: 18px;
        padding: 2rem;
        width: 400px;
        max-width: 90vw;
        box-shadow: 0 20px 60px rgba(0,0,0,.18);
        transform: scale(.92);
        transition: transform .25s;
    }

    .ep-overlay.show .ep-modal {
        transform: scale(1);
    }

    .ep-modal-icon {
        width: 52px;
        height: 52px;
        background: #fef2f2;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.1rem;
    }

        .ep-modal-icon .material-symbols-outlined {
            font-size: 26px;
            color: #dc2626;
        }

    .ep-modal h3 {
        font-size: 1.1rem;
        font-weight: 800;
        color: #2c3639;
        margin-bottom: .5rem;
    }

    .ep-modal p {
        font-size: .85rem;
        color: rgba(63,78,79,.65);
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }

    .ep-modal-actions {
        display: flex;
        gap: .625rem;
        justify-content: flex-end;
    }

    .ep-toast {
        position: fixed;
        bottom: 1.75rem;
        right: 1.75rem;
        background: #2c3639;
        color: #dcd7c9;
        padding: .875rem 1.25rem;
        border-radius: 12px;
        font-size: .85rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: .625rem;
        box-shadow: 0 8px 28px rgba(0,0,0,.18);
        transform: translateY(20px);
        opacity: 0;
        transition: transform .3s ease, opacity .3s ease;
        z-index: 9999;
        pointer-events: none;
    }

        .ep-toast.show {
            transform: translateY(0);
            opacity: 1;
        }

        .ep-toast .material-symbols-outlined {
            font-size: 20px;
            color: #a27b5c;
        }
</style>

@* Page header *@
<div class="ep-header">
    <div style="display:flex;align-items:center;gap:.875rem;">
        <a href="@Url.Action("Index", "Product")" class="ep-back-btn">
            <span class="material-symbols-outlined">arrow_back</span> Quay lại
        </a>
        <div>
            <div class="ep-header-title">Chỉnh Sửa Sản Phẩm</div>
            <div class="ep-header-sub">ID: #@Model.Id &nbsp;·&nbsp; Cập nhật thông tin sản phẩm</div>
        </div>
    </div>
    <div class="ep-header-actions">
        <button class="ep-btn-danger" type="button" onclick="showDeleteModal()">
            <span class="material-symbols-outlined">delete</span> Xóa
        </button>
        <button class="ep-btn-primary" type="button" onclick="submitForm()">
            <span class="material-symbols-outlined">save</span> Lưu thay đổi
        </button>
    </div>
</div>

@* Status bar *@
<div class="ep-status-bar">
    <span class="ep-status-dot" id="statusDot"></span>
    <span class="ep-status-text" id="statusText">Còn hàng</span>
    <span class="ep-status-sep"></span>
    <span class="ep-sku-badge">ID: @Model.Id</span>
    <span class="ep-status-sep"></span>
    <span class="ep-sku-badge">Danh mục: @(Model.Category?.Name ?? "—")</span>
    <span class="ep-updated">Cập nhật: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
</div>

@* Form *@
<form asp-action="Edit" asp-controller="Product" method="post" enctype="multipart/form-data" id="editForm" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ImageUrl" id="hiddenImageUrl" />

    <div class="ep-grid">

        @* LEFT column *@
        <div>
            @* Thông tin cơ bản *@
            <div class="ep-card">
                <div class="ep-card-title">
                    <span class="material-symbols-outlined">info</span>Thông Tin Cơ Bản
                </div>

                <div class="ep-field">
                    <label class="ep-label" for="Name">Tên sản phẩm <span>*</span></label>
                    <input class="ep-input" asp-for="Name" id="Name" placeholder="VD: Cà Phê Sữa Đá..." maxlength="100"
                           oninput="updateCounter('Name','nameCounter',100)" />
                    <div class="ep-counter"><span id="nameCounter">@(Model.Name?.Length ?? 0)</span>/100</div>
                    <div class="ep-val-msg" id="nameErr">Vui lòng nhập tên sản phẩm.</div>
                </div>

                <div class="ep-field">
                    <label class="ep-label" for="Description">Mô tả</label>
                    <textarea class="ep-textarea" asp-for="Description" id="Description"
                              placeholder="Mô tả hương vị, nguyên liệu..." maxlength="500" rows="4"
                              oninput="updateCounter('Description','descCounter',500)">@Model.Description</textarea>
                    <div class="ep-counter"><span id="descCounter">@(Model.Description?.Length ?? 0)</span>/500</div>
                </div>

                <div class="ep-row">
                    <div class="ep-field">
                        <label class="ep-label" for="Price">Giá gốc (₫) <span>*</span></label>
                        <div class="ep-input-group">
                            <span class="ep-input-prefix">₫</span>
                            <input class="ep-input" type="number" asp-for="Price" id="Price"
                                   placeholder="0" min="0" step="500"
                                   oninput="calcSalePrice()" />
                        </div>
                        <div class="ep-val-msg" id="priceErr">Vui lòng nhập giá hợp lệ.</div>
                    </div>
                    <div class="ep-field">
                        <label class="ep-label" for="CategoryId">Danh mục <span>*</span></label>
                        <select class="ep-select" asp-for="CategoryId" id="CategoryId">
                            <option value="">-- Chọn danh mục --</option>
                            @if (categories != null)
                            {
                                @foreach (var cat in categories)
                                {
                                    if (cat.Id == Model.CategoryId)
                                    {
                                        <option value="@cat.Id" selected>@cat.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                }
                            }
                        </select>
                        <div class="ep-val-msg" id="catErr">Vui lòng chọn danh mục.</div>
                    </div>
                </div>
            </div>

            @* Khuyến mãi *@
            <div class="ep-card">
                <div class="ep-card-title">
                    <span class="material-symbols-outlined">local_offer</span>Khuyến Mãi / Sale
                </div>

                <div style="display:flex;align-items:center;justify-content:space-between;padding:.75rem 1rem;border:1px solid #e2e8f0;border-radius:10px;">
                    <div style="display:flex;align-items:center;gap:.6rem;">
                        <span class="material-symbols-outlined" style="font-size:18px;color:#a27b5c;">local_offer</span>
                        <div>
                            <div style="font-size:.85rem;font-weight:600;color:#2c3639;">Bật khuyến mãi</div>
                            <div style="font-size:.72rem;color:rgba(63,78,79,.45);">Hiện badge "Sale" và giá sau giảm</div>
                        </div>
                    </div>
                    <label style="position:relative;display:inline-block;width:40px;height:22px;flex-shrink:0;">
                        <input type="checkbox" id="toggleSale" asp-for="IsOnSale"
                               onchange="toggleSaleBox(this.checked)" style="display:none;" />
                        <span id="saleSlider" onclick="document.getElementById('toggleSale').click();toggleSaleBox(document.getElementById('toggleSale').checked)"
                              style="position:absolute;inset:0;border-radius:11px;cursor:pointer;transition:background .2s;background:#e2e8f0;">
                            <span style="position:absolute;width:16px;height:16px;left:3px;top:3px;background:#fff;border-radius:50%;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);display:block;" id="saleThumb"></span>
                        </span>
                    </label>
                </div>

                <div class="ep-sale-box" id="saleBox">
                    <div class="ep-field" style="margin-bottom:.75rem;">
                        <label class="ep-label">Phần trăm giảm (%)</label>
                        <input class="ep-input" type="number" asp-for="DiscountPercent" id="DiscountPercent"
                               placeholder="VD: 10" min="0" max="100" step="1"
                               oninput="calcSalePrice()" />
                    </div>
                    <div style="padding:.75rem 1rem;background:#fff;border-radius:10px;border:1px solid rgba(234,179,8,.25);">
                        <div style="font-size:.72rem;color:rgba(63,78,79,.5);margin-bottom:2px;">Giá sau giảm:</div>
                        <div id="salePriceDisplay" style="font-size:1.15rem;font-weight:800;color:#d97706;">—</div>
                    </div>
                </div>
            </div>
        </div>

        @* RIGHT column *@
        <div>
            <div class="ep-card">
                <div class="ep-card-title">
                    <span class="material-symbols-outlined">image</span>Ảnh Sản Phẩm
                </div>

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="ep-img-current" id="imgPreview" />
                }
                else
                {
                    <div class="ep-img-placeholder" id="imgPreview">
                        <span class="material-symbols-outlined">image</span>
                        <span>Chưa có ảnh</span>
                    </div>
                }

                <div class="ep-upload-drop" onclick="document.getElementById('fileInput').click()" id="dropZone">
                    <span class="material-symbols-outlined">cloud_upload</span>
                    <p>
                        <strong>Bấm để tải ảnh lên</strong><br />
                        hoặc kéo &amp; thả vào đây<br />
                        <span style="color:rgba(63,78,79,.4);font-size:.72rem">PNG, JPG, WEBP — tối đa 5MB</span>
                    </p>
                </div>
                <input type="file" id="fileInput" name="ImageFile" accept="image/*" onchange="previewImage(event)" />

                <div class="ep-field" style="margin-top:.875rem;margin-bottom:0;">
                    <label class="ep-label">Hoặc dán URL ảnh</label>
                    <input class="ep-input" id="urlInput" placeholder="https://..."
                           value="@Model.ImageUrl"
                           oninput="applyUrlPreview()" />
                </div>
            </div>
        </div>

    </div>
</form>

@* Delete modal *@
<div class="ep-overlay" id="deleteOverlay">
    <div class="ep-modal">
        <div class="ep-modal-icon"><span class="material-symbols-outlined">delete_forever</span></div>
        <h3>Xóa sản phẩm này?</h3>
        <p>Hành động này không thể hoàn tác. Sản phẩm <strong>@Model.Name</strong> sẽ bị xóa vĩnh viễn.</p>
        <div class="ep-modal-actions">
            <button class="ep-btn-ghost" type="button" onclick="closeModal()">Hủy bỏ</button>
            <form asp-action="Delete" asp-controller="Product" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="ep-btn-danger">
                    <span class="material-symbols-outlined">delete</span> Xác nhận xóa
                </button>
            </form>
        </div>
    </div>
</div>

<div class="ep-toast" id="toast">
    <span class="material-symbols-outlined">check_circle</span>
    <span id="toastMsg">Đã lưu thay đổi!</span>
</div>

@section Scripts {
    <script>
        // ── Khởi tạo khi load ───────────────────────────────
        (function init() {
            // Sync hiddenImageUrl với urlInput
            const hidden   = document.getElementById('hiddenImageUrl');
            const urlInput = document.getElementById('urlInput');
            if (hidden && urlInput && urlInput.value && !hidden.value) {
                hidden.value = urlInput.value;
            }

            // Khởi tạo Sale toggle
            const saleChecked = document.getElementById('toggleSale').checked;
            toggleSaleBox(saleChecked);
            calcSalePrice();
        })();

        // ── Sale toggle ──────────────────────────────────────
        function toggleSaleBox(on) {
            const box    = document.getElementById('saleBox');
            const slider = document.getElementById('saleSlider');
            const thumb  = document.getElementById('saleThumb');
            if (on) {
                box.classList.add('show');
                slider.style.background = '#a27b5c';
                thumb.style.transform = 'translateX(18px)';
            } else {
                box.classList.remove('show');
                slider.style.background = '#e2e8f0';
                thumb.style.transform = 'translateX(0)';
            }
            calcSalePrice();
        }

        function calcSalePrice() {
            const price    = parseFloat(document.getElementById('Price')?.value) || 0;
            const discount = parseFloat(document.getElementById('DiscountPercent')?.value) || 0;
            const el = document.getElementById('salePriceDisplay');
            if (!el) return;
            if (price > 0 && discount > 0) {
                const sale = price * (1 - discount / 100);
                el.textContent = sale.toLocaleString('vi-VN') + '₫';
            } else {
                el.textContent = price > 0 ? price.toLocaleString('vi-VN') + '₫' : '—';
            }
        }

        // ── Ảnh ─────────────────────────────────────────────
        function previewImage(e) {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = ev => setPreview(ev.target.result);
            reader.readAsDataURL(file);
            document.getElementById('hiddenImageUrl').value = '';
            document.getElementById('urlInput').value = '';
        }

        function applyUrlPreview() {
            const url = document.getElementById('urlInput').value.trim();
            document.getElementById('hiddenImageUrl').value = url;
            if (url) setPreview(url);
        }

        function setPreview(src) {
            const el = document.getElementById('imgPreview');
            if (el.tagName === 'IMG') {
                el.src = src;
            } else {
                const img = document.createElement('img');
                img.src = src; img.className = 'ep-img-current'; img.id = 'imgPreview';
                el.replaceWith(img);
            }
        }

        // Drag & drop
        const dz = document.getElementById('dropZone');
        dz.addEventListener('dragover', e => { e.preventDefault(); dz.style.borderColor='#a27b5c'; });
        dz.addEventListener('dragleave', () => { dz.style.borderColor=''; });
        dz.addEventListener('drop', e => {
            e.preventDefault(); dz.style.borderColor='';
            const file = e.dataTransfer.files[0];
            if (file && file.type.startsWith('image/')) {
                const dt = new DataTransfer(); dt.items.add(file);
                document.getElementById('fileInput').files = dt.files;
                const reader = new FileReader();
                reader.onload = ev => setPreview(ev.target.result);
                reader.readAsDataURL(file);
                document.getElementById('hiddenImageUrl').value = '';
            }
        });

        // ── Counter ──────────────────────────────────────────
        function updateCounter(fId, cId, max) {
            document.getElementById(cId).textContent = document.getElementById(fId).value.length;
        }

        // ── Submit với validation ─────────────────────────────
        function submitForm() {
            let valid = true;
            const checks = [
                { id:'Name',       err:'nameErr',  isNum:false },
                { id:'Price',      err:'priceErr', isNum:true  },
                { id:'CategoryId', err:'catErr',   isNum:false },
            ];
            checks.forEach(c => {
                const el    = document.getElementById(c.id);
                const errEl = document.getElementById(c.err);
                const bad   = c.isNum ? (!el.value || parseFloat(el.value) < 0) : !el.value.trim();
                if (bad) { el.classList.add('error'); errEl.classList.add('show'); valid = false; }
                else     { el.classList.remove('error'); errEl.classList.remove('show'); }
            });
            if (!valid) { showToast('⚠ Vui lòng điền đầy đủ thông tin.'); return; }
            document.getElementById('editForm').submit();
        }

        // ── Modal & Toast ─────────────────────────────────────
        function showDeleteModal() { document.getElementById('deleteOverlay').classList.add('show'); }
        function closeModal()      { document.getElementById('deleteOverlay').classList.remove('show'); }
        function showToast(msg) {
            const t = document.getElementById('toast');
            document.getElementById('toastMsg').textContent = msg || 'Đã lưu!';
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 3200);
        }

        @if (TempData["Success"] != null)
        {
                <text>setTimeout(() => showToast('@TempData["Success"]'), 300);</text>
        }
    </script>
}
