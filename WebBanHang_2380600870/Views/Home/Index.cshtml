@* Views/Home/Index.cshtml *@
@* UPDATED: Unified product card design matching Menu/Index v4 *@
@model IEnumerable<WebBanHang_2380600870.Models.Product>
@{
    ViewData["Title"] = "Góc Lặng — Nơi Dừng Chân Giữa Ngày";
    var allProducts = Model.ToList();
    var featured = allProducts.Where(p => p.CategoryId == 1).Take(4).ToList();
    var coffee   = allProducts.Where(p => p.CategoryId == 2).Take(4).ToList();
    var pastry   = allProducts.Where(p => p.CategoryId == 3).Take(4).ToList();
    string PriceK(decimal price) => (price / 1000).ToString("0") + "k";
}

@section Styles {
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />
<style>
/* ── HOME PRODUCT CARD — unified with Menu ── */
.hp-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
}
.hp-card__frame {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: .875rem;
    background: #e5ddd3;
    margin-bottom: .85rem;
    box-shadow: 0 1px 5px rgba(44,54,57,.07);
    transition: box-shadow .5s cubic-bezier(.22,1,.36,1), transform .5s cubic-bezier(.22,1,.36,1);
}
.hp-card:hover .hp-card__frame {
    box-shadow: 0 16px 44px rgba(44,54,57,.16), 0 0 0 2.5px rgba(162,123,92,.2);
    transform: translateY(-4px);
}
.hp-card__photo {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    transition: transform .75s cubic-bezier(.22,1,.36,1);
}
.hp-card:hover .hp-card__photo { transform: scale(1.07); }
.hp-card__vignette {
    position: absolute; bottom: 0; left: 0; right: 0; height: 60%;
    background: linear-gradient(to top, rgba(22,18,14,.58) 0%, rgba(22,18,14,0) 100%);
    z-index: 1; opacity: 0; transition: opacity .35s;
}
.hp-card:hover .hp-card__vignette { opacity: 1; }
.hp-card__cta-wrap {
    position: absolute; bottom: .85rem; left: 50%;
    transform: translateX(-50%) translateY(8px);
    z-index: 2; opacity: 0; white-space: nowrap;
    transition: opacity .28s, transform .38s cubic-bezier(.22,1,.36,1);
}
.hp-card:hover .hp-card__cta-wrap { opacity: 1; transform: translateX(-50%) translateY(0); }
.hp-card__cta-pill {
    font-family: 'Work Sans', sans-serif; font-size: .6rem; font-weight: 700;
    letter-spacing: .2em; text-transform: uppercase; color: #fff;
    padding: .36rem 1rem; border-radius: 9999px;
    border: 1px solid rgba(255,255,255,.65);
    background: rgba(22,18,14,.28);
    -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);
}
/* sale badge */
.hp-card__sale {
    position: absolute; top: .65rem; right: .65rem; z-index: 3;
    font-family: 'Playfair Display', serif; font-style: italic;
    font-size: .65rem; font-weight: 700;
    padding: .18rem .58rem; border-radius: 9999px;
    background: #ef4444; color: #fff;
}
/* text */
.hp-card__name {
    font-family: 'Playfair Display', serif; font-size: .92rem; font-weight: 700;
    color: #2C3639; line-height: 1.35; transition: color .2s;
    margin-bottom: .18rem;
}
.hp-card:hover .hp-card__name { color: #A27B5C; }
.hp-card__desc {
    font-family: 'Cormorant Garamond', serif; font-size: .87rem; font-style: italic;
    color: #3F4E4F; opacity: .78; line-height: 1.55;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    margin-bottom: .25rem;
}
.hp-card__price-row {
    display: flex; align-items: center; justify-content: center; gap: .4rem; flex-wrap: wrap;
}
.hp-card__price-line { width: 12px; height: 1px; background: rgba(162,123,92,.38); flex-shrink: 0; }
.hp-card__price {
    font-family: 'Playfair Display', serif; font-size: .88rem; font-weight: 700;
    color: #A27B5C;
}
.hp-card__price-old {
    font-family: 'Playfair Display', serif; font-size: .74rem; font-weight: 400;
    color: #b0b8be; text-decoration: line-through; font-style: italic;
}
.hp-card__price-block { display: flex; flex-direction: column; align-items: center; gap: .1rem; }
.hp-card__price-original {
    font-family: 'Cormorant Garamond', serif; font-size: .78rem;
    color: #94a3b8; text-decoration: line-through; font-style: italic; opacity: .7; line-height: 1;
}
.hp-card__price-sale-row { display: flex; align-items: center; justify-content: center; gap: .38rem; }
.hp-card__price-sale {
    font-family: 'Playfair Display', serif; font-size: .92rem; font-weight: 700;
    font-style: italic; color: #A27B5C;
}

/* ── HOME TABS ── */
.ht-bar {
    display: flex; justify-content: center;
    border-bottom: 1px solid rgba(139,90,43,0.13);
    margin-bottom: 2.5rem;
}
.ht-btn {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    width: 180px; padding: .75rem 1rem 1.1rem;
    border: none; background: transparent; cursor: pointer;
    border-bottom: 2.5px solid transparent; margin-bottom: -1px;
    transition: all .22s;
    font-family: 'Work Sans', sans-serif;
}
.ht-btn--active { border-bottom-color: #A27B5C; }
.ht-btn .ht-icon {
    font-size: 24px; margin-bottom: 6px; color: rgba(63,78,79,.4); transition: color .2s;
}
.ht-btn--active .ht-icon { color: #A27B5C; }
.ht-btn .ht-label {
    font-size: .68rem; font-weight: 700; letter-spacing: .15em; text-transform: uppercase;
    color: rgba(63,78,79,.45); transition: color .2s; margin: 0;
}
.ht-btn--active .ht-label { color: #2C3639; }

/* panel fade */
.ht-panel {
    display: none;
    grid-template-columns: repeat(4,1fr); gap: 2rem;
    opacity: 0; transform: translateY(6px);
    transition: opacity .3s ease, transform .3s ease;
}
.ht-panel.ht-panel--visible {
    display: grid; opacity: 1; transform: translateY(0);
}
/* trick: display none blocks transitions, use two-step */
.ht-panel.ht-panel--entering {
    display: grid; opacity: 0; transform: translateY(6px);
}
@@media (max-width: 768px) {
    .ht-panel, .ht-panel.ht-panel--visible, .ht-panel.ht-panel--entering {
        grid-template-columns: repeat(2,1fr); gap: 1.4rem;
    }
    .ht-btn { width: 120px; }
}

/* ── "Xem toàn bộ" button — unified ── */
.ht-more-btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .9rem 2.5rem;
    border: 1.5px solid #2C3639; border-radius: 9999px;
    color: #2C3639; font-family: 'Work Sans', sans-serif;
    font-size: .8rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    text-decoration: none; transition: all .2s;
}
.ht-more-btn:hover { background: #2C3639; color: #DCD7C9; text-decoration: none; }
</style>
}

<main class="flex-1">

    <!-- HERO -->
    <div class="px-4 md:px-10 py-6">
        <div class="relative w-full min-h-[600px] rounded-xl overflow-hidden flex flex-col items-center justify-center text-center"
             style="background-image: linear-gradient(rgba(28,20,14,0.65), rgba(28,20,14,0.45)),
                    url('https://lh3.googleusercontent.com/aida-public/AB6AXuCPbbxfASi-rYqxHYCVtSGTQZ--TMdNj0FDJXsoBmVNsIrwIgCkDv76iaZtRyoSzvUU7ec7JZaEksl2kYREjaoay-G9FrYRwkszVe_Ey30DncbScTSARonXPv-ngaFaREZRO4F3fVb0UA2PWvnzQrsUPppz5XyGqLDfGEqwSrFSrVZlL5ox9Cl-10U2epsiMo819tJ9LIE6TLVxFhPg0YudTrnNV1qTPu5GDjny5_-oJA3qbLwu9X5Eg18Eb2939imxAWVNPu9DfREz');
                    background-size: cover; background-position: center;">
            <div class="relative z-10 flex flex-col items-center gap-5 max-w-3xl px-6">
                <span class="text-primary font-semibold tracking-[0.35em] uppercase text-xs">Thành lập bởi những người bạn — vì niềm đam mê</span>
                <h1 class="vn-heading-xl text-cream-custom text-4xl md:text-5xl font-black tracking-tight"
                    style="text-shadow: 0 2px 24px rgba(0,0,0,0.5);">
                    Dừng lại một chút,<br />bạn xứng đáng được nghỉ ngơi.
                </h1>
                <p class="vn-body text-cream-custom text-lg md:text-xl font-light max-w-2xl" style="opacity:0.85;">
                    Một buổi sáng chậm rãi, một ly cà phê đúng vị, một không gian cổ điển — Góc Lặng là nơi chúng mình tạo ra để mọi người có thể thở giữa thế giới vội vã này.
                </p>
                <div class="flex flex-wrap justify-center gap-4 mt-2">
                    <a asp-controller="Menu" asp-action="Index"
                       class="flex min-w-[160px] items-center justify-center rounded-full h-14 px-8 bg-primary text-white text-sm font-bold uppercase tracking-widest hover:opacity-90 transition-all shadow-lg">
                        Xem Thực Đơn
                    </a>
                    <a asp-controller="Booking" asp-action="Index"
                       class="flex min-w-[160px] items-center justify-center rounded-full h-14 px-8 text-white text-sm font-bold uppercase tracking-widest transition-all hover:bg-white hover:text-slate-custom"
                       style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.3); backdrop-filter: blur(8px);">
                        Đặt Chỗ
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- TOAST -->
    @if (TempData["SubscribeSuccess"] != null)
    {
        <div id="toast-ok" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl text-white text-sm font-semibold"
             style="background:#3F4E4F; max-width:340px;">
            <span class="material-symbols-outlined" style="font-size:20px; color:#A27B5C;">check_circle</span>
            @TempData["SubscribeSuccess"]
            <button type="button" onclick="this.parentElement.remove()" class="ml-auto opacity-60 hover:opacity-100">
                <span class="material-symbols-outlined" style="font-size:18px;">close</span>
            </button>
        </div>
    }
    @if (TempData["SubscribeError"] != null)
    {
        <div id="toast-err" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl text-white text-sm font-semibold"
             style="background:#b91c1c; max-width:340px;">
            <span class="material-symbols-outlined" style="font-size:20px;">error</span>
            @TempData["SubscribeError"]
            <button type="button" onclick="this.parentElement.remove()" class="ml-auto opacity-60 hover:opacity-100">
                <span class="material-symbols-outlined" style="font-size:18px;">close</span>
            </button>
        </div>
    }

    <!-- CÂU CHUYỆN -->
    <section class="py-20 px-6 md:px-20" style="background-color: rgba(245,240,232,0.2);">
        <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
            <div class="order-2 md:order-1">
                <div class="relative">
                    <div class="absolute -top-4 -left-4 w-full h-full border-2 border-primary rounded-xl"></div>
                    <img alt="Không gian Góc Lặng"
                         class="relative z-10 rounded-xl shadow-2xl w-full object-cover"
                         style="height: 500px;"
                         src="https://lh3.googleusercontent.com/aida-public/AB6AXuDnAnQXXrRhCmWzm2WbFHv44wDwIiTd6_BFDKWnoC9xFVrKv9MTM1kNzGOu0bQ7AGkEcyynl1cMwROAsA1H_mAapTFq6GKIhPwxSn-KSUHDYczHhUUyMzi13Gd_ysPHsJ_DJ4eDGYWOF2YP8vbkEqcdj5L_Ao89-cYC7bQTi0xvA0XWeiqzI3ShMUhP6RmS-P-8i104PKOfp0N5n6mLS-cHxNuqaUfAjLmEYr7sV3pIQRb2cya6uzWoAODjlMwAiLwoDGe50ilVutUC" />
                </div>
            </div>
            <div class="order-1 md:order-2 flex flex-col gap-6">
                <h3 class="text-primary font-bold tracking-widest uppercase text-sm">Câu chuyện của chúng mình</h3>
                <h2 class="vn-heading-xl text-slate-custom text-3xl md:text-4xl font-bold">Bắt đầu từ<br />một niềm đam mê</h2>
                <p class="vn-body text-teal-custom text-lg">
                    Góc Lặng không ra đời từ kế hoạch kinh doanh — mà từ những buổi chiều tà mà một nhóm bạn ngồi lại với nhau, pha cà phê, nghe nhạc cổ điển, và ước có một nơi như thế này giữa lòng thành phố.
                </p>
                <p class="vn-body text-teal-custom text-lg">
                    Mỗi món đồ uống ở đây đều đơn giản, nhưng được làm thật chỉnh chu. Mỗi góc nhỏ đều được chăm chút như ngôi nhà của chính mình. Vì với chúng mình — đây <em>là</em> nhà.
                </p>
                <div>
                    <a asp-controller="Home" asp-action="CauChuyen"
                       class="inline-flex items-center gap-2 text-primary font-bold border-b-2 border-primary pb-1 hover:opacity-70 transition-all">
                        Đọc thêm về chúng mình →
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- SẢN PHẨM — TABS -->
    <section class="py-20 px-6 md:px-20 max-w-[1200px] mx-auto">
        <div class="text-center mb-10">
            <h2 class="vn-heading text-slate-custom text-3xl md:text-4xl font-bold mb-4">Những thứ chúng mình làm bằng tâm huyết</h2>
            <div class="w-16 h-px mx-auto" style="background:linear-gradient(to right,transparent,#A27B5C,transparent);"></div>
        </div>

        <!-- Tab buttons -->
        <div class="ht-bar">
            <button onclick="htSwitch('tra')"   id="ht-btn-tra"   class="ht-btn ht-btn--active">
                <span class="material-symbols-outlined ht-icon">emoji_food_beverage</span>
                <p class="ht-label">Trà &amp; Thảo Mộc</p>
            </button>
            <button onclick="htSwitch('caphe')" id="ht-btn-caphe" class="ht-btn">
                <span class="material-symbols-outlined ht-icon">coffee</span>
                <p class="ht-label">Cà Phê</p>
            </button>
            <button onclick="htSwitch('banh')"  id="ht-btn-banh"  class="ht-btn">
                <span class="material-symbols-outlined ht-icon">cake</span>
                <p class="ht-label">Bánh Sáng</p>
            </button>
        </div>

        <!-- Panels -->
        @foreach (var (panelId, panelProducts) in new[] {
            ("tra",   featured),
            ("caphe", coffee),
            ("banh",  pastry)
        })
        {
            <div id="ht-panel-@panelId"
                 class="ht-panel @(panelId == "tra" ? "ht-panel--visible" : "")">
                @foreach (var product in panelProducts)
                {
                    bool onSale = product.IsOnSale && product.SalePrice > 0 && product.SalePrice < product.Price;
                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id" class="hp-card">
                        <div class="hp-card__frame">
                            <div class="hp-card__photo"
                                 style="background-image:url('@product.ImageUrl');"
                                 onerror="this.style.backgroundImage='none'">
                            </div>
                            <div class="hp-card__vignette"></div>
                            <div class="hp-card__cta-wrap">
                                <span class="hp-card__cta-pill">Xem thêm</span>
                            </div>
                            @if (onSale)
                            {
                                <span class="hp-card__sale">−@(product.DiscountPercent?.ToString("0"))%</span>
                            }
                        </div>
                        <div style="text-align:center;">
                            <div class="hp-card__name">@product.Name</div>
                            @if (!string.IsNullOrWhiteSpace(product.Description))
                            {
                                <p class="hp-card__desc">@product.Description</p>
                            }
                            @if (onSale)
                            {
                                <div class="hp-card__price-block">
                                    <span class="hp-card__price-original">@PriceK(product.Price)</span>
                                    <div class="hp-card__price-sale-row">
                                        <div class="hp-card__price-line"></div>
                                        <span class="hp-card__price-sale">@PriceK(product.SalePrice)</span>
                                        <div class="hp-card__price-line"></div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="hp-card__price-row">
                                    <div class="hp-card__price-line"></div>
                                    <span class="hp-card__price">@PriceK(product.Price)</span>
                                    <div class="hp-card__price-line"></div>
                                </div>
                            }
                        </div>
                    </a>
                }
                @if (!panelProducts.Any())
                {
                    <div style="grid-column:1/-1; padding:3rem 0; text-align:center; font-style:italic; opacity:.5; font-size:.9rem; color:#3F4E4F;">Chưa có sản phẩm.</div>
                }
            </div>
        }

        <div class="mt-14 text-center">
            <a asp-controller="Menu" asp-action="Index" class="ht-more-btn">
                Xem Toàn Bộ Thực Đơn
            </a>
        </div>
    </section>

    <!-- CTA / NEWSLETTER -->
    <section class="bg-slate-custom text-cream-custom py-24 px-6 relative overflow-hidden">
        <div class="absolute left-6 top-6 select-none pointer-events-none"
             style="font-family:'Playfair Display',serif;font-size:140px;line-height:1;color:rgba(255,255,255,0.04);">"</div>
        <div class="max-w-4xl mx-auto text-center relative z-10">
            <p class="text-primary font-semibold tracking-widest uppercase text-xs mb-4">Góc Lặng nhắn gửi</p>
            <h2 class="vn-heading-xl text-2xl md:text-4xl font-bold mb-10">
                Thế giới có thể vội —<br />nhưng buổi sáng của bạn thì không cần phải vậy.
            </h2>
            <p class="vn-body text-lg mb-12 max-w-2xl mx-auto font-light" style="color:rgba(245,240,232,0.75);">
                Để lại email để chúng mình kể bạn nghe những câu chuyện nhỏ từ Góc Lặng — thực đơn mới, buổi chiều nhạc sống, hay đơn giản là một lời nhắc: hãy uống cà phê chậm thôi.
            </p>
            <form asp-controller="Home" asp-action="Subscribe" method="post"
                  class="flex flex-col md:flex-row gap-4 max-w-xl mx-auto">
                @Html.AntiForgeryToken()
                <input name="email" type="email" required
                       class="flex-1 px-6 py-4 rounded-full border-none focus:outline-none text-cream-custom"
                       style="background:rgba(74,103,100,0.6);"
                       placeholder="Email của bạn..." />
                <button type="submit"
                        class="bg-primary text-white font-bold px-8 py-4 rounded-full uppercase tracking-widest whitespace-nowrap hover:opacity-90 transition-all">
                    Theo Dõi
                </button>
            </form>
        </div>
    </section>

</main>

@section Scripts {
<script>
    // ── Home tabs with smooth fade ──
    var HT_TABS = ['tra','caphe','banh'];

    function htSwitch(name) {
        HT_TABS.forEach(function(id) {
            var panel = document.getElementById('ht-panel-' + id);
            var btn   = document.getElementById('ht-btn-' + id);
            if (id === name) {
                btn.classList.add('ht-btn--active');
                // Two-step fade in
                panel.classList.remove('ht-panel--visible');
                panel.classList.add('ht-panel--entering');
                requestAnimationFrame(function() {
                    requestAnimationFrame(function() {
                        panel.classList.remove('ht-panel--entering');
                        panel.classList.add('ht-panel--visible');
                    });
                });
            } else {
                btn.classList.remove('ht-btn--active');
                panel.classList.remove('ht-panel--visible', 'ht-panel--entering');
                panel.style.display = 'none';
                // Reset display for next time
                setTimeout(function(p){ p.style.display = ''; }, 320, panel);
            }
        });
    }

    // Auto-dismiss toast
    setTimeout(function() {
        ['toast-ok','toast-err'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) { el.style.transition='opacity 0.5s'; el.style.opacity='0'; setTimeout(function(){ el && el.remove(); },500); }
        });
    }, 5000);
</script>
}
