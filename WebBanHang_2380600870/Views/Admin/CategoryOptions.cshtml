@* Views/Admin/CategoryOptions.cshtml *@
@{
    ViewData["Title"] = "Tùy Chọn Theo Danh Mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActivePage"] = "Category";
    ViewData["Breadcrumb"] = "<a href='/Category'>Danh mục</a> <span class='material-symbols-outlined'>chevron_right</span> Tùy chọn sản phẩm";

    var serverCategories = ViewBag.Categories as IEnumerable<WebBanHang_2380600870.Models.Category>
                          ?? Enumerable.Empty<WebBanHang_2380600870.Models.Category>();

    // FIX TS1109: pre-compute để tránh C# lambda trong <script>
    var serverCategoriesJson = System.Text.Json.JsonSerializer.Serialize(
        serverCategories.Select(c => new { id = c.Id, name = c.Name }));
}

<style>
    .co-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
        gap: 1.5rem;
    }

    .co-card {
        background: #fff;
        border: 1px solid rgba(162,123,92,.18);
        border-radius: 18px;
        padding: 1.75rem;
        box-shadow: 0 2px 8px rgba(44,54,57,.06);
    }

    .co-card-header {
        display: flex;
        align-items: center;
        gap: .875rem;
        margin-bottom: 1.5rem;
    }

    .co-cat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: rgba(162,123,92,.1);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .co-cat-name {
        font-size: 1.1rem;
        font-weight: 800;
        color: #2c3639;
    }

    .co-cat-sub {
        font-size: .75rem;
        color: #94a3b8;
        margin-top: 2px;
    }

    .co-section-title {
        font-size: .72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: rgba(44,54,57,.5);
        margin: 1.25rem 0 .75rem;
    }

        .co-section-title:first-of-type {
            margin-top: 0;
        }

    .co-option-row {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .625rem .875rem;
        border: 1.5px solid rgba(162,123,92,.18);
        border-radius: 10px;
        margin-bottom: .5rem;
        background: #fafaf9;
        transition: border-color .15s, background .15s;
    }

        .co-option-row:hover {
            border-color: #a27b5c;
            background: #fff;
        }

    .co-option-icon {
        color: #a27b5c;
        font-size: 18px;
        flex-shrink: 0;
    }

    .co-option-name {
        flex: 1;
        font-size: .88rem;
        font-weight: 600;
        color: #2c3639;
    }

    .co-option-price {
        font-size: .8rem;
        font-weight: 700;
        color: #a27b5c;
        background: rgba(162,123,92,.1);
        padding: .2rem .6rem;
        border-radius: 20px;
    }

    .co-option-edit {
        display: flex;
        gap: .3rem;
        opacity: 0;
        transition: opacity .15s;
    }

    .co-option-row:hover .co-option-edit {
        opacity: 1;
    }

    .co-icon-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: #94a3b8;
        font-size: 18px;
        padding: .15rem;
        border-radius: 6px;
        transition: color .15s, background .15s;
        display: flex;
        align-items: center;
    }

        .co-icon-btn:hover {
            color: #2c3639;
            background: rgba(44,54,57,.08);
        }

        .co-icon-btn.del:hover {
            color: #ef4444;
            background: rgba(239,68,68,.08);
        }

    .co-add-row {
        display: flex;
        gap: .5rem;
        margin-top: .875rem;
    }

    .co-input {
        flex: 1;
        padding: .55rem .875rem;
        border: 1.5px solid rgba(162,123,92,.25);
        border-radius: 10px;
        font-size: .85rem;
        color: #2c3639;
        background: #fafaf9;
        outline: none;
        transition: border-color .15s;
        font-family: 'Work Sans',sans-serif;
    }

        .co-input:focus {
            border-color: #a27b5c;
            background: #fff;
        }

    .co-input-price {
        width: 80px;
        padding: .55rem .75rem;
        border: 1.5px solid rgba(162,123,92,.25);
        border-radius: 10px;
        font-size: .85rem;
        color: #2c3639;
        background: #fafaf9;
        outline: none;
        transition: border-color .15s;
        font-family: 'Work Sans',sans-serif;
        text-align: right;
    }

        .co-input-price:focus {
            border-color: #a27b5c;
            background: #fff;
        }

    .co-add-btn {
        padding: .55rem .875rem;
        background: #a27b5c;
        color: #fff;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        font-size: .85rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: .3rem;
        transition: opacity .15s;
        font-family: 'Work Sans',sans-serif;
    }

        .co-add-btn:hover {
            opacity: .88;
        }

    .co-toggle-row {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .5rem 0;
        border-bottom: 1px solid rgba(162,123,92,.08);
    }

        .co-toggle-row:last-child {
            border-bottom: none;
        }

    .co-toggle-label {
        flex: 1;
        font-size: .88rem;
        font-weight: 600;
        color: #2c3639;
    }

    .co-toggle-sub {
        font-size: .75rem;
        color: #94a3b8;
    }

    .co-switch {
        position: relative;
        width: 44px;
        height: 24px;
        flex-shrink: 0;
    }

        .co-switch input {
            opacity: 0;
            width: 0;
            height: 0;
            position: absolute;
        }

    .co-slider {
        position: absolute;
        inset: 0;
        border-radius: 24px;
        background: rgba(162,123,92,.2);
        cursor: pointer;
        transition: background .2s;
    }

        .co-slider::after {
            content: '';
            position: absolute;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #fff;
            top: 3px;
            left: 3px;
            transition: transform .2s;
            box-shadow: 0 1px 3px rgba(0,0,0,.2);
        }

    .co-switch input:checked + .co-slider {
        background: #a27b5c;
    }

        .co-switch input:checked + .co-slider::after {
            transform: translateX(20px);
        }

    .co-save-bar {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        display: flex;
        gap: .75rem;
        z-index: 1000;
        transform: translateY(calc(100% + 1.5rem));
        opacity: 0;
        transition: transform .35s cubic-bezier(.34,1.56,.64,1), opacity .3s;
    }

        .co-save-bar.show {
            transform: translateY(0);
            opacity: 1;
        }

    .co-save-btn {
        padding: .75rem 1.5rem;
        background: #a27b5c;
        color: #fff;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        font-size: .9rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: .5rem;
        box-shadow: 0 4px 18px rgba(162,123,92,.35);
        font-family: 'Work Sans',sans-serif;
        transition: opacity .15s;
    }

        .co-save-btn:hover {
            opacity: .9;
        }

    .co-discard-btn {
        padding: .75rem 1.25rem;
        background: #fff;
        color: #2c3639;
        border: 1.5px solid rgba(44,54,57,.15);
        border-radius: 12px;
        cursor: pointer;
        font-size: .9rem;
        font-weight: 600;
        font-family: 'Work Sans',sans-serif;
    }

    .co-toast {
        position: fixed;
        top: 1.5rem;
        right: 1.5rem;
        z-index: 9999;
        background: #fff;
        border: 1px solid rgba(162,123,92,.3);
        border-left: 4px solid #a27b5c;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: .75rem;
        box-shadow: 0 8px 24px rgba(44,54,57,.12);
        transform: translateX(110%);
        opacity: 0;
        transition: transform .35s cubic-bezier(.34,1.56,.64,1), opacity .35s;
        max-width: 360px;
    }

        .co-toast.show {
            transform: translateX(0);
            opacity: 1;
        }

    /* ── Inline Edit Modal ─────────────────────────────────── */
    .co-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 8000;
        background: rgba(44,54,57,.35);
        backdrop-filter: blur(3px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity .2s;
    }

        .co-modal-overlay.open {
            opacity: 1;
            pointer-events: all;
        }

    .co-modal {
        background: #fff;
        border-radius: 18px;
        padding: 1.75rem;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 20px 60px rgba(44,54,57,.18);
        transform: translateY(16px) scale(.97);
        transition: transform .25s cubic-bezier(.34,1.56,.64,1);
    }

    .co-modal-overlay.open .co-modal {
        transform: translateY(0) scale(1);
    }

    .co-modal-title {
        font-size: 1rem;
        font-weight: 800;
        color: #2c3639;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .co-modal-field {
        margin-bottom: 1rem;
    }

    .co-modal-label {
        display: block;
        font-size: .78rem;
        font-weight: 700;
        color: rgba(44,54,57,.6);
        text-transform: uppercase;
        letter-spacing: .07em;
        margin-bottom: .4rem;
    }

    .co-modal-input {
        width: 100%;
        padding: .65rem 1rem;
        border: 1.5px solid rgba(162,123,92,.25);
        border-radius: 10px;
        font-size: .9rem;
        color: #2c3639;
        background: #fafaf9;
        outline: none;
        transition: border-color .15s;
        font-family: 'Work Sans',sans-serif;
        box-sizing: border-box;
    }

        .co-modal-input:focus {
            border-color: #a27b5c;
            background: #fff;
        }

    .co-modal-footer {
        display: flex;
        gap: .75rem;
        margin-top: 1.5rem;
        justify-content: flex-end;
    }

    .co-modal-cancel {
        padding: .6rem 1.2rem;
        background: none;
        border: 1.5px solid rgba(44,54,57,.15);
        border-radius: 10px;
        color: #2c3639;
        font-size: .875rem;
        font-weight: 600;
        cursor: pointer;
        font-family: 'Work Sans',sans-serif;
        transition: background .15s;
    }

        .co-modal-cancel:hover {
            background: rgba(44,54,57,.05);
        }

    .co-modal-confirm {
        padding: .6rem 1.4rem;
        background: #a27b5c;
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: .875rem;
        font-weight: 700;
        cursor: pointer;
        font-family: 'Work Sans',sans-serif;
        transition: opacity .15s;
    }

        .co-modal-confirm:hover {
            opacity: .88;
        }
</style>

<!-- Toast -->
<div class="co-toast" id="coToast">
    <span class="material-symbols-outlined" style="color:#a27b5c;font-size:22px;">check_circle</span>
    <span id="coToastMsg" style="font-size:.875rem;font-weight:500;color:#2c3639;">Đã lưu!</span>
    <button onclick="hideToast()" style="margin-left:auto;background:none;border:none;cursor:pointer;color:#94a3b8;" class="material-symbols-outlined">close</button>
</div>

<!-- Save bar -->
<div class="co-save-bar" id="saveBar">
    <button class="co-discard-btn" onclick="discardChanges()">Hủy thay đổi</button>
    <button class="co-save-btn" onclick="saveAllOptions()">
        <span class="material-symbols-outlined" style="font-size:18px;">save</span>
        Lưu tất cả thay đổi
    </button>
</div>

<!-- Inline Edit Modal -->
<div class="co-modal-overlay" id="editModal" onclick="closeModalOnBackdrop(event)">
    <div class="co-modal">
        <div class="co-modal-title">
            <span class="material-symbols-outlined" style="color:#a27b5c;font-size:20px;">edit</span>
            Chỉnh sửa Topping
        </div>
        <div class="co-modal-field">
            <label class="co-modal-label">Tên topping</label>
