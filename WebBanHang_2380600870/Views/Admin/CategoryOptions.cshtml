</div>

<!-- Header info -->
<div style="background:#fff;border:1px solid rgba(162,123,92,.12);border-radius:14px;padding:1.25rem 1.5rem;margin-bottom:1.5rem;display:flex;align-items:center;gap:1rem;">
    <div style="width:42px;height:42px;border-radius:10px;background:rgba(162,123,92,.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <span class="material-symbols-outlined" style="color:#a27b5c;font-size:22px;">tune</span>
    </div>
    <div>
        <div style="font-size:.95rem;font-weight:700;color:#2c3639;">Quản lý tùy chọn theo danh mục</div>
        <div style="font-size:.8rem;color:#94a3b8;">Các tùy chọn này sẽ hiển thị trong trang chi tiết sản phẩm theo từng loại danh mục. Thay đổi sẽ được áp dụng ngay sau khi lưu.</div>
    </div>
    <div style="margin-left:auto;display:flex;gap:.5rem;">
        <a href="/Product" style="display:flex;align-items:center;gap:.4rem;padding:.5rem 1rem;border:1px solid rgba(162,123,92,.25);border-radius:10px;color:#a27b5c;text-decoration:none;font-size:.85rem;font-weight:600;">
            <span class="material-symbols-outlined" style="font-size:17px;">storefront</span> Xem sản phẩm
        </a>
    </div>
</div>

<div class="co-grid" id="categoriesGrid">
    <!-- Cards rendered by JS -->
</div>

<!-- Pass server categories to JS -->
<script>
    // ── Danh mục từ server (luôn up-to-date) ──────────────────────
    const SERVER_CATEGORIES = @Html.Raw(serverCategoriesJson); // FIX TS1109

    // ── Icon mapping theo tên (fallback cho danh mục mới) ─────────
    const ICON_MAP = {
        "Cà Phê":           { icon: "coffee",        sub: "Đồ uống có caffeine" },
        "Trà & Thảo Mộc":   { icon: "local_florist", sub: "Trà tươi & thảo mộc" },
        "Bánh Sáng":        { icon: "bakery_dining",  sub: "Bánh & đồ ăn" },
        "Thức uống đặc biệt": { icon: "local_cafe",  sub: "Thức uống đặc biệt" },
    };
    function getIconInfo(name) {
        return ICON_MAP[name] || { icon: "category", sub: name };
    }

    // ── Default config cho danh mục chưa có config ────────────────
    const DEFAULT_TOPPINGS = {
        "Cà Phê": [
            { name: "Thêm đá",           price: 0     },
            { name: "Sữa yến mạch",      price: 10000 },
            { name: "Shot espresso thêm",price: 15000 },
            { name: "Trân châu đen",     price: 15000 },
        ],
        "Trà & Thảo Mộc": [
            { name: "Thêm đá",       price: 0    },
            { name: "Đào miếng",     price: 10000},
            { name: "Mật ong thêm",  price: 5000 },
            { name: "Chanh tươi",    price: 5000 },
            { name: "Trân châu trắng", price: 8000 },
        ],
        "Bánh Sáng": [
            { name: "Bơ thêm",     price: 5000  },
            { name: "Mứt dâu",     price: 5000  },
            { name: "Trứng ốp la", price: 15000 },
            { name: "Cà phê đen kèm", price: 20000 },
        ],
    };

    // ── Storage key (phải khớp với Detail.cshtml) ─────────────────
    const STORAGE_KEY = 'goclang_category_options';

    // ── Load/Save config ─────────────────────────────────────────
    function loadConfig() {
        try {
            const saved = localStorage.getItem(STORAGE_KEY);
            return saved ? JSON.parse(saved) : null;
        } catch { return null; }
    }

    // Merge: server categories làm chủ — config cũ giữ lại toppings/settings
    function buildConfig() {
        const saved = loadConfig() || {};
        const merged = {};
        SERVER_CATEGORIES.forEach(cat => {
            const name = cat.name;
            const iconInfo = getIconInfo(name);
            if (saved[name]) {
                // Giữ nguyên settings đã lưu, chỉ update icon/sub nếu thiếu
                merged[name] = {
                    icon:      saved[name].icon      || iconInfo.icon,
                    sub:       saved[name].sub       || iconInfo.sub,
                    hasSugar:  saved[name].hasSugar  !== undefined ? saved[name].hasSugar : true,
                    sizeLabel: saved[name].sizeLabel || "Kích Cỡ",
                    toppings:  saved[name].toppings  || DEFAULT_TOPPINGS[name] || [],
                };
            } else {
                // Danh mục mới chưa có config — dùng default
                merged[name] = {
                    icon:      iconInfo.icon,
                    sub:       iconInfo.sub,
                    hasSugar:  name !== "Bánh Sáng",
                    sizeLabel: name === "Bánh Sáng" ? "Phần" : "Kích Cỡ",
                    toppings:  DEFAULT_TOPPINGS[name] || [],
                };
            }
        });
        return merged;
    }

    let config = buildConfig();
    let dirty  = false;

    // ── Modal state ───────────────────────────────────────────────
    let _editCat   = null;
    let _editIndex = null;

    function setDirty() {
        dirty = true;
        document.getElementById('saveBar').classList.add('show');
    }

    function discardChanges() {
        config = buildConfig();
        dirty  = false;
        document.getElementById('saveBar').classList.remove('show');
        renderAll();
    }

    function saveAllOptions() {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(config));
        dirty = false;
        document.getElementById('saveBar').classList.remove('show');
        showToast('✅ Đã lưu! Trang chi tiết sản phẩm sẽ cập nhật ngay.');
    }

    // ── Render ────────────────────────────────────────────────────
    function renderAll() {
        const grid = document.getElementById('categoriesGrid');
        grid.innerHTML = '';
        Object.keys(config).forEach(catName => renderCard(catName, grid));
    }

    function safeName(name) {
        return name.replace(/[^a-zA-Z0-9]/g, '_');
    }

    function fmtPrice(price) {
        return price === 0 ? '+0k' : '+' + (price / 1000) + 'k';
    }

    function renderCard(catName, container) {
        const cat  = config[catName];
        const sn   = safeName(catName);
        const card = document.createElement('div');
        card.className = 'co-card';
        card.dataset.cat = catName;

        card.innerHTML = `
            <div class="co-card-header">
                <div class="co-cat-icon">
                    <span class="material-symbols-outlined" style="color:#a27b5c;font-size:24px;">${cat.icon}</span>
                </div>
                <div>
                    <div class="co-cat-name">${catName}</div>
                    <div class="co-cat-sub">${cat.sub}</div>
                </div>
            </div>

            <div class="co-section-title">Cài đặt chung</div>
            <div class="co-toggle-row">
                <div>
                    <div class="co-toggle-label">Độ ngọt</div>
                    <div class="co-toggle-sub">Cho phép chọn mức đường</div>
                </div>
                <label class="co-switch">
                    <input type="checkbox" ${cat.hasSugar ? 'checked' : ''}
                           onchange="toggleSugar('${catName}', this.checked)" />
                    <span class="co-slider"></span>
                </label>
            </div>
            <div class="co-toggle-row" style="margin-top:.25rem;">
                <div><div class="co-toggle-label">Nhãn kích cỡ</div></div>
                <input class="co-input" style="max-width:130px;margin:0;flex:unset;"
                       value="${cat.sizeLabel}"
                       onchange="config['${catName}'].sizeLabel=this.value;setDirty();" />
            </div>

            <div class="co-section-title" style="margin-top:1.25rem;">
                Topping / Tùy chọn thêm
            </div>
            <div id="toppings-${sn}">
                ${renderToppingList(catName)}
            </div>
            <div class="co-add-row">
                <input class="co-input" id="new-name-${sn}" placeholder="Tên topping..." />
                <input class="co-input-price" id="new-price-${sn}" placeholder="0" type="number" min="0" step="1000" value="0" />
                <button class="co-add-btn" onclick="addTopping('${catName}')">
                    <span class="material-symbols-outlined" style="font-size:17px;">add</span> Thêm
                </button>
            </div>

            <div class="co-section-title" style="margin-top:1.25rem;">Giá theo kích cỡ</div>
            <div style="background:rgba(162,123,92,.06);border-radius:10px;padding:.875rem 1rem;font-size:.82rem;color:#3f4e4f;display:flex;gap:1rem;flex-wrap:wrap;">
                <span>🔹 <strong>Nhỏ</strong>: Giá gốc −7k</span>
                <span>🔹 <strong>Vừa</strong>: Giá gốc (mặc định)</span>
                <span>🔹 <strong>Lớn</strong>: Giá gốc +7k</span>
            </div>
        `;
        container.appendChild(card);
    }

    function renderToppingList(catName) {
        return config[catName].toppings
            .map((t, i) => renderToppingRow(catName, t, i))
            .join('');
    }

    function renderToppingRow(catName, topping, index) {
        const sn = safeName(catName);
        // Escape single quotes for inline onclick
        const escapedCat = catName.replace(/'/g, "\\'");
        return `
        <div class="co-option-row" id="tr-${sn}-${index}">
            <span class="material-symbols-outlined co-option-icon">local_offer</span>
            <span class="co-option-name">${topping.name}</span>
            <span class="co-option-price">${fmtPrice(topping.price)}</span>
            <div class="co-option-edit">
                <button class="co-icon-btn" onclick="openEditModal('${escapedCat}',${index})" title="Sửa">
                    <span class="material-symbols-outlined" style="font-size:17px;">edit</span>
                </button>
                <button class="co-icon-btn del" onclick="deleteTopping('${escapedCat}',${index})" title="Xóa">
                    <span class="material-symbols-outlined" style="font-size:17px;">delete</span>
                </button>
            </div>
        </div>`;
    }

    function refreshToppingList(catName) {
        const sn = safeName(catName);
        const el = document.getElementById('toppings-' + sn);
        if (el) el.innerHTML = renderToppingList(catName);
    }

    // ── Actions ───────────────────────────────────────────────────
    function toggleSugar(catName, val) {
        config[catName].hasSugar = val;
        setDirty();
    }

    function addTopping(catName) {
        const sn = safeName(catName);
        const nameEl  = document.getElementById('new-name-' + sn);
        const priceEl = document.getElementById('new-price-' + sn);
        const name  = nameEl.value.trim();
        const price = parseInt(priceEl.value) || 0;
        if (!name) {
            nameEl.style.borderColor = '#ef4444';
            setTimeout(() => nameEl.style.borderColor = '', 1500);
            return;
        }
        config[catName].toppings.push({ name, price });
        setDirty();
        nameEl.value = ''; priceEl.value = '0';
        refreshToppingList(catName);
    }

    function deleteTopping(catName, index) {
        const t = config[catName].toppings[index];
        if (!t) return;
        // Dùng custom confirm thay vì browser confirm
        openDeleteConfirm(catName, index, t.name);
    }

    // ── Inline Edit Modal ─────────────────────────────────────────
    function openEditModal(catName, index) {
        _editCat   = catName;
        _editIndex = index;
        const t = config[catName].toppings[index];
        document.getElementById('modalToppingName').value  = t.name;
        document.getElementById('modalToppingPrice').value = t.price;
        document.getElementById('editModal').classList.add('open');
        setTimeout(() => document.getElementById('modalToppingName').focus(), 50);
    }

    function closeModal() {
        document.getElementById('editModal').classList.remove('open');
        _editCat = null; _editIndex = null;
    }

    function closeModalOnBackdrop(e) {
        if (e.target === document.getElementById('editModal')) closeModal();
    }

    function confirmEdit() {
        if (_editCat === null || _editIndex === null) return;
        const name  = document.getElementById('modalToppingName').value.trim();
        const price = parseInt(document.getElementById('modalToppingPrice').value) || 0;
        if (!name) {
            document.getElementById('modalToppingName').style.borderColor = '#ef4444';
            setTimeout(() => document.getElementById('modalToppingName').style.borderColor = '', 1500);
            return;
        }
        config[_editCat].toppings[_editIndex] = { name, price };
        setDirty();
        refreshToppingList(_editCat);
        closeModal();
    }

    // ── Delete confirm (inline, không dùng browser confirm) ───────
    function openDeleteConfirm(catName, index, toppingName) {
        // Tạo mini-confirm overlay
        const overlay = document.createElement('div');
        overlay.style.cssText = 'position:fixed;inset:0;z-index:8500;background:rgba(44,54,57,.3);backdrop-filter:blur(2px);display:flex;align-items:center;justify-content:center;';
        overlay.innerHTML = `
        <div style="background:#fff;border-radius:16px;padding:1.5rem 1.75rem;max-width:360px;width:100%;box-shadow:0 16px 48px rgba(44,54,57,.18);">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem;">
                <span class="material-symbols-outlined" style="color:#ef4444;font-size:22px;">delete</span>
                <span style="font-size:1rem;font-weight:800;color:#2c3639;">Xóa topping?</span>
            </div>
            <p style="font-size:.875rem;color:#64748b;margin-bottom:1.25rem;">
                Bạn chắc chắn muốn xóa <strong>"${toppingName}"</strong> khỏi danh mục này?
            </p>
            <div style="display:flex;gap:.75rem;justify-content:flex-end;">
                <button id="dcCancel" style="padding:.55rem 1.1rem;background:none;border:1.5px solid rgba(44,54,57,.15);border-radius:10px;color:#2c3639;font-size:.875rem;font-weight:600;cursor:pointer;font-family:'Work Sans',sans-serif;">Hủy</button>
                <button id="dcConfirm" style="padding:.55rem 1.1rem;background:#ef4444;color:#fff;border:none;border-radius:10px;font-size:.875rem;font-weight:700;cursor:pointer;font-family:'Work Sans',sans-serif;">Xóa</button>
            </div>
        </div>`;
        document.body.appendChild(overlay);
        document.getElementById('dcCancel').onclick  = () => overlay.remove();
        document.getElementById('dcConfirm').onclick = () => {
            config[catName].toppings.splice(index, 1);
            setDirty();
            refreshToppingList(catName);
            overlay.remove();
        };
    }

    // ── Toast ─────────────────────────────────────────────────────
    let _toastTimer = null;
    function showToast(msg) {
        clearTimeout(_toastTimer);
        const t = document.getElementById('coToast');
        document.getElementById('coToastMsg').textContent = msg;
        t.classList.add('show');
        _toastTimer = setTimeout(hideToast, 4000);
    }
    function hideToast() { document.getElementById('coToast').classList.remove('show'); }

    // ── Keyboard shortcut: Enter = confirm modal ───────────────────
    document.addEventListener('keydown', e => {
        if (e.key === 'Enter' && document.getElementById('editModal').classList.contains('open')) {
            e.preventDefault();
            confirmEdit();
        }
        if (e.key === 'Escape' && document.getElementById('editModal').classList.contains('open')) {
            closeModal();
        }
    });

    // ── Init ──────────────────────────────────────────────────────
    renderAll();
    if (!loadConfig()) {
        setTimeout(() => showToast('💡 Đang dùng cấu hình mặc định. Thay đổi và nhấn Lưu để áp dụng.'), 600);
    }
</script>
