@model IEnumerable<WebBanHang_2380600870.Models.Order>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActivePage"] = "Dashboard";
}

<style>
    .stat-row {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 12px;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: #fff;
        border: 1px solid rgba(162,123,92,.12);
        border-radius: 14px;
        padding: 1.1rem 1.25rem;
        opacity: 0;
        transform: translateY(10px);
        animation: fadeUp .4s ease forwards;
        transition: box-shadow .2s,transform .2s;
    }

        .stat-card:hover {
            box-shadow: 0 6px 22px rgba(44,54,57,.1);
            transform: translateY(-2px);
        }

        .stat-card:nth-child(1) {
            animation-delay: .05s
        }

        .stat-card:nth-child(2) {
            animation-delay: .12s
        }

        .stat-card:nth-child(3) {
            animation-delay: .19s
        }

        .stat-card:nth-child(4) {
            animation-delay: .26s
        }

    .dash-grid {
        display: grid;
        grid-template-columns: 1fr 240px;
        gap: 1.25rem;
        align-items: start;
    }

    .quick-row {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 10px;
        margin-bottom: 1.5rem;
    }

    .quick-card {
        background: #fff;
        border: 1px solid rgba(162,123,92,.12);
        border-radius: 12px;
        padding: 1rem;
        display: flex;
        align-items: center;
        gap: .75rem;
        text-decoration: none;
        transition: box-shadow .2s,transform .2s,border-color .2s;
    }

        .quick-card:hover {
            box-shadow: 0 5px 18px rgba(44,54,57,.09);
            transform: translateY(-2px);
            border-color: rgba(162,123,92,.3);
        }

        .quick-card .q-arr {
            margin-left: auto;
            flex-shrink: 0;
            opacity: 0;
            transform: translateX(-4px);
            transition: opacity .15s,transform .15s;
        }

        .quick-card:hover .q-arr {
            opacity: 1;
            transform: translateX(0);
        }

    .orders-box {
        background: #fff;
        border: 1px solid rgba(162,123,92,.12);
        border-radius: 14px;
        overflow: hidden;
    }

        .orders-box table {
            width: 100%;
            border-collapse: collapse;
            font-size: .82rem;
        }

        .orders-box thead th {
            text-align: left;
            padding: .75rem 1rem;
            font-size: .7rem;
            font-weight: 800;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: #a27b5c;
            background: rgba(162,123,92,.06);
            border-bottom: 1.5px solid rgba(162,123,92,.12);
        }

        .orders-box tbody tr {
            border-bottom: 1px solid rgba(162,123,92,.07);
            transition: background .14s;
        }

            .orders-box tbody tr:last-child {
                border-bottom: none;
            }

            .orders-box tbody tr:hover {
                background: rgba(162,123,92,.04);
            }

        .orders-box td {
            padding: .75rem 1rem;
            color: #3f4e4f;
        }

    .r-panel {
        background: #fff;
        border: 1px solid rgba(162,123,92,.12);
        border-radius: 14px;
        padding: 1.1rem;
        margin-bottom: .875rem;
        opacity: 0;
        transform: translateY(8px);
        animation: fadeUp .4s ease forwards;
    }

        .r-panel:nth-child(1) {
            animation-delay: .15s
        }

        .r-panel:nth-child(2) {
            animation-delay: .28s
        }

        .r-panel:nth-child(3) {
            animation-delay: .41s
        }

    .r-label {
        font-size: .68rem;
        font-weight: 800;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: #a27b5c;
        margin-bottom: .75rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

        .r-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(162,123,92,.18);
        }

    .sc-lnk {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .5rem .6rem;
        border-radius: 9px;
        text-decoration: none;
        color: #3f4e4f;
        font-size: .82rem;
        font-weight: 600;
        transition: background .14s,transform .14s;
    }

        .sc-lnk:hover {
            background: rgba(162,123,92,.08);
            transform: translateX(2px);
        }

        .sc-lnk .sc-chev {
            opacity: 0;
            margin-left: auto;
            transition: opacity .14s;
        }

        .sc-lnk:hover .sc-chev {
            opacity: 1;
        }

    .sys-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .4rem 0;
        border-bottom: 1px solid rgba(162,123,92,.1);
        font-size: .78rem;
    }

        .sys-row:last-child {
            border-bottom: none;
        }

        .sys-row .sys-k {
            color: rgba(44,54,57,.45);
            font-weight: 600;
        }

        .sys-row .sys-v {
            font-weight: 700;
            color: #2c3639;
        }

    .ornament {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin: 1rem 0 .875rem;
    }

        .ornament::before, .ornament::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(162,123,92,.15);
        }

        .ornament span {
            font-size: .68rem;
            font-weight: 800;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: #a27b5c;
        }

    @@keyframes fadeUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width:900px) {
        .dash-grid {
            grid-template-columns: 1fr;
        }

        .stat-row {
            grid-template-columns: repeat(2,1fr);
        }

        .quick-row {
            grid-template-columns: repeat(2,1fr);
        }
    }
</style>

@* Page header *@
<div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:.75rem;margin-bottom:1.5rem;">
    <div>
        <p style="font-size:.68rem;font-weight:800;letter-spacing:.22em;text-transform:uppercase;color:#a27b5c;margin-bottom:3px;">Heritage Cafe</p>
        <h1 style="font-size:1.55rem;font-weight:900;color:#2c3639;line-height:1.15;margin:0;">Dashboard Admin</h1>
        <p style="font-size:.82rem;color:#3f4e4f;margin-top:3px;">
            Xin chào, <strong>@User.Identity?.Name</strong> 👋
            <span style="opacity:.4;margin-left:.4rem;">· @DateTime.Now.ToString("dd/MM/yyyy")</span>
        </p>
    </div>
    <div style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:center;">
        <a asp-action="Users" style="display:flex;align-items:center;gap:.35rem;padding:.45rem 1rem;border-radius:99px;font-size:.78rem;font-weight:700;color:#fff;background:#2c3639;text-decoration:none;" onmouseover="this.style.opacity='.8'" onmouseout="this.style.opacity='1'">
            <span class="material-symbols-outlined" style="font-size:15px;">group</span> Người Dùng
        </a>
        <a asp-action="Orders" style="display:flex;align-items:center;gap:.35rem;padding:.45rem 1rem;border-radius:99px;font-size:.78rem;font-weight:700;color:#fff;background:#a27b5c;text-decoration:none;" onmouseover="this.style.opacity='.8'" onmouseout="this.style.opacity='1'">
            <span class="material-symbols-outlined" style="font-size:15px;">receipt_long</span> Đơn Hàng
        </a>
        <a asp-action="Bookings" style="display:flex;align-items:center;gap:.35rem;padding:.45rem 1rem;border-radius:99px;font-size:.78rem;font-weight:700;color:#a27b5c;border:1.5px solid #a27b5c;text-decoration:none;" onmouseover="this.style.opacity='.75'" onmouseout="this.style.opacity='1'">
            <span class="material-symbols-outlined" style="font-size:15px;">event_seat</span> Đặt Chỗ
        </a>
    </div>
</div>

@* Stat cards *@
<div class="stat-row">
    @{
        var stats = new[] {
        new { Icon="inventory_2",  Label="SẢN PHẨM",   Value=ViewBag.TotalProducts?.ToString() ?? "—", Color="#a27b5c", Bg="rgba(162,123,92,0.09)", Tag="Tổng cộng"  },
        new { Icon="group",        Label="NGƯỜI DÙNG",  Value=ViewBag.TotalUsers?.ToString()    ?? "—", Color="#3f4e4f", Bg="rgba(63,78,79,0.09)",   Tag="Đã đăng ký" },
        new { Icon="receipt_long", Label="ĐƠN HÀNG",   Value=ViewBag.TotalOrders?.ToString()   ?? "—", Color="#2c3639", Bg="rgba(44,54,57,0.09)",   Tag="Tất cả"     },
        new { Icon="event_seat",   Label="ĐẶT CHỖ",    Value=ViewBag.TotalBookings?.ToString() ?? "—", Color="#a27b5c", Bg="rgba(162,123,92,0.09)", Tag="Tổng"       },
        };
    }
    @foreach (var s in stats)
    {
        <div class="stat-card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.6rem;">
                <div style="width:36px;height:36px;border-radius:10px;background:@s.Bg;display:flex;align-items:center;justify-content:center;">
                    <span class="material-symbols-outlined" style="font-size:18px;color:@s.Color;">@s.Icon</span>
                </div>
                <span style="font-size:.65rem;font-weight:800;padding:2px 8px;border-radius:99px;background:@s.Bg;color:@s.Color;">@s.Tag</span>
            </div>
            <p style="font-size:1.7rem;font-weight:900;color:@s.Color;line-height:1;margin:0;">@s.Value</p>
            <p style="font-size:.7rem;font-weight:800;letter-spacing:.1em;color:#3f4e4f;margin-top:.25rem;opacity:.55;">@s.Label</p>
        </div>
    }
</div>

@* 2-col grid *@
<div class="dash-grid">
    @* LEFT *@
    <div>
        <div class="ornament"><span>Thao Tác Nhanh</span></div>
        <div class="quick-row">
            @{
                var quick = new[] {
                        new { Icon="storefront",   Label="Sản Phẩm",  Sub="Thêm, sửa, xóa", Ctrl="Product",  Act="Index"    },
                        new { Icon="category",     Label="Danh Mục",  Sub="Phân loại",        Ctrl="Category", Act="Index"    },
                        new { Icon="event_seat",   Label="Đặt Chỗ",   Sub="Lịch đặt bàn",    Ctrl="Admin",    Act="Bookings" },
                        };
            }
            @foreach (var q in quick)
            {
                <a asp-controller="@q.Ctrl" asp-action="@q.Act" class="quick-card">
                    <div style="width:36px;height:36px;border-radius:10px;background:rgba(162,123,92,.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <span class="material-symbols-outlined" style="font-size:18px;color:#a27b5c;">@q.Icon</span>
                    </div>
                    <div>
                        <p style="font-size:.82rem;font-weight:700;color:#2c3639;margin:0;">@q.Label</p>
                        <p style="font-size:.72rem;color:#3f4e4f;opacity:.55;margin:1px 0 0;">@q.Sub</p>
                    </div>
                    <span class="material-symbols-outlined q-arr" style="color:#a27b5c;font-size:15px;">arrow_forward</span>
                </a>
            }
        </div>

        <div class="ornament"><span>Đơn Hàng Gần Đây</span></div>
        <div class="orders-box">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:.75rem 1rem;border-bottom:1px solid rgba(162,123,92,.1);">
                <p style="font-size:.82rem;font-weight:800;color:#2c3639;margin:0;">Danh Sách Đơn Hàng</p>
                <a asp-action="Orders" style="font-size:.72rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:#a27b5c;text-decoration:none;display:flex;align-items:center;gap:3px;">
                    Xem tất cả <span class="material-symbols-outlined" style="font-size:12px;">arrow_forward</span>
                </a>
            </div>
            @if (!Model.Any())
            {
                <div style="padding:3rem 1rem;text-align:center;">
                    <span class="material-symbols-outlined" style="font-size:36px;color:rgba(162,123,92,.3);display:block;margin-bottom:.5rem;">receipt_long</span>
                    <p style="font-size:.82rem;font-weight:700;color:#2c3639;">Chưa có đơn hàng nào</p>
                    <p style="font-size:.75rem;color:#3f4e4f;opacity:.5;font-style:italic;">Khi khách đặt hàng, thông tin sẽ hiển thị tại đây.</p>
                </div>
            }
            else
            {
                <table>
                    <thead>
                        <tr><th>Mã ĐH</th><th>Khách Hàng</th><th>Ngày Đặt</th><th>Tổng Tiền</th><th>Trạng Thái</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model)
                        {
                            var (bg, clr) = o.Status switch
                            {
                                WebBanHang_2380600870.Models.OrderStatus.Completed => ("rgba(34,197,94,.12)", "#15803d"),
                                WebBanHang_2380600870.Models.OrderStatus.Cancelled => ("rgba(239,68,68,.12)", "#b91c1c"),
                                WebBanHang_2380600870.Models.OrderStatus.Pending => ("rgba(234,179,8,.12)", "#a16207"),
                                _ => ("rgba(162,123,92,.12)", "#a27b5c")
                            };
                            <tr>
                                <td style="font-weight:700;color:#2c3639;">#@o.Id</td>
                                <td>@(o.User?.FullName ?? o.User?.Email ?? "—")</td>
                                <td>@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td style="font-weight:700;color:#a27b5c;">@o.TotalAmount.ToString("N0")đ</td>
                                <td><span style="padding:2px 8px;border-radius:99px;font-size:.72rem;font-weight:700;background:@bg;color:@clr;">@o.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    @* RIGHT *@
    <div>
        <div class="r-panel" style="background:#2c3639;">
            <div class="r-label" style="color:#a27b5c;">
                <span class="material-symbols-outlined" style="font-size:13px;">info</span> Hệ Thống
            </div>
            <h3 style="font-size:.92rem;font-weight:900;color:#dcd7c9;margin:0 0 .75rem;">Heritage Cafe</h3>
            <div class="sys-row"><span class="sys-k" style="color:rgba(220,215,201,.42);">Phiên bản</span><span class="sys-v" style="color:#a27b5c;">v1.0.0</span></div>
            <div class="sys-row"><span class="sys-k" style="color:rgba(220,215,201,.42);">Framework</span><span class="sys-v" style="color:#dcd7c9;">.NET 8</span></div>
            <div class="sys-row"><span class="sys-k" style="color:rgba(220,215,201,.42);">Ngày</span><span class="sys-v" style="color:#dcd7c9;">@DateTime.Now.ToString("dd/MM/yyyy")</span></div>
            <div class="sys-row" style="border-bottom:none;"><span class="sys-k" style="color:rgba(220,215,201,.42);">Trạng thái</span><span style="font-size:.68rem;font-weight:800;padding:2px 8px;border-radius:99px;background:rgba(34,197,94,.16);color:#4ade80;">● Online</span></div>
            <a asp-controller="Home" asp-action="Index" style="margin-top:.75rem;display:flex;align-items:center;justify-content:center;gap:.4rem;padding:.5rem;border-radius:9px;background:rgba(162,123,92,.2);color:#dcd7c9;border:1px solid rgba(162,123,92,.24);text-decoration:none;font-size:.78rem;font-weight:700;" onmouseover="this.style.opacity='.75'" onmouseout="this.style.opacity='1'">
                <span class="material-symbols-outlined" style="font-size:14px;">open_in_new</span> Xem Website
            </a>
        </div>

        <div class="r-panel">
            <div class="r-label"><span class="material-symbols-outlined" style="font-size:13px;">bolt</span> Truy Cập Nhanh</div>
            @{
                var shortcuts = new[] {
                        new { Icon="add_circle",   Label="Thêm sản phẩm mới",  Ctrl="Product",  Act="Add"    },
                        new { Icon="playlist_add", Label="Thêm danh mục mới",   Ctrl="Category", Act="Add"    },
                        new { Icon="people",       Label="Quản lý người dùng",  Ctrl="Admin",    Act="Users"  },
                        new { Icon="bar_chart",    Label="Xem đơn hàng",        Ctrl="Admin",    Act="Orders" },
                        };
            }
            @foreach (var s in shortcuts)
            {
                <a asp-controller="@s.Ctrl" asp-action="@s.Act" class="sc-lnk">
                    <span class="material-symbols-outlined" style="color:#a27b5c;font-size:16px;flex-shrink:0;">@s.Icon</span>
                    <span>@s.Label</span>
                    <span class="material-symbols-outlined sc-chev" style="color:#a27b5c;font-size:14px;">chevron_right</span>
                </a>
            }
        </div>

        <div class="r-panel">
            <div class="r-label"><span class="material-symbols-outlined" style="font-size:13px;">manage_accounts</span> Tài Khoản</div>
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem;">
                <div style="width:32px;height:32px;border-radius:50%;background:#a27b5c;display:flex;align-items:center;justify-content:center;font-weight:900;color:#fff;font-size:.82rem;flex-shrink:0;">
                    @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "A")
                </div>
                <div style="flex:1;min-width:0;">
                    <p style="font-size:.82rem;font-weight:700;color:#2c3639;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin:0;">@User.Identity?.Name</p>
                    <p style="font-size:.72rem;color:#3f4e4f;opacity:.5;margin:0;">Administrator</p>
                </div>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" style="width:100%;display:flex;align-items:center;justify-content:center;gap:.4rem;padding:.6rem;border-radius:9px;background:rgba(239,68,68,.07);color:#b91c1c;border:1.5px solid rgba(239,68,68,.15);font-family:'Work Sans',sans-serif;font-size:.78rem;font-weight:700;cursor:pointer;" onmouseover="this.style.background='rgba(239,68,68,.14)'" onmouseout="this.style.background='rgba(239,68,68,.07)'">
                    <span class="material-symbols-outlined" style="font-size:15px;">logout</span> Đăng Xuất
                </button>
            </form>
        </div>
    </div>
</div>
