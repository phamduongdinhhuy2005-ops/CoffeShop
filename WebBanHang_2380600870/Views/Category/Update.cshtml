@model WebBanHang_2380600870.Models.Category
@{
    ViewData["Title"] = "Cập Nhật Danh Mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActivePage"] = "Category";
    ViewData["Breadcrumb"] = "<a href='/Category'>Danh mục</a> <span class='material-symbols-outlined'>chevron_right</span> Cập nhật";
}

<div style="max-width:560px;">
    <div style="background:#fff; border-radius:16px; padding:2rem; box-shadow:0 1px 4px rgba(44,54,57,.06); border:1px solid rgba(162,123,92,.15);">

        <div style="display:flex; align-items:center; gap:.75rem; margin-bottom:1.75rem;">
            <div style="width:44px;height:44px;border-radius:10px;background:rgba(162,123,92,.12);display:flex;align-items:center;justify-content:center;">
                <span class="material-symbols-outlined" style="color:#a27b5c;font-size:22px;">edit</span>
            </div>
            <div>
                <div style="font-size:1.1rem;font-weight:700;color:#2c3639;">Cập nhật danh mục</div>
                <div style="font-size:.75rem;color:#94a3b8;">ID: #@Model.Id</div>
            </div>
        </div>

        <form asp-action="Update" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly"
                 style="background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.25);border-radius:10px;padding:.75rem 1rem;margin-bottom:1.25rem;color:#b91c1c;font-size:.85rem;"></div>

            <div style="margin-bottom:1.25rem;">
                <label asp-for="Name"
                       style="display:block;font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#2c3639;margin-bottom:.5rem;">
                    Tên danh mục <span style="color:#ef4444;">*</span>
                </label>
                <input asp-for="Name"
                       style="width:100%;padding:.7rem 1rem;border:1.5px solid rgba(162,123,92,.35);border-radius:10px;font-family:'Work Sans',sans-serif;font-size:.9rem;color:#2c3639;background:#fafaf9;outline:none;transition:border-color .15s;"
                       onfocus="this.style.borderColor='#a27b5c'" onblur="this.style.borderColor='rgba(162,123,92,.35)'" />
                <span asp-validation-for="Name" style="color:#ef4444;font-size:.78rem;margin-top:.3rem;display:block;"></span>
            </div>

            <div style="display:flex;gap:.75rem;margin-top:1.75rem;">
                <button type="submit"
                        style="flex:1;padding:.75rem;background:#a27b5c;color:#fff;border:none;border-radius:10px;font-family:'Work Sans',sans-serif;font-size:.9rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.5rem;transition:opacity .15s;"
                        onmouseover="this.style.opacity='.88'" onmouseout="this.style.opacity='1'">
                    <span class="material-symbols-outlined" style="font-size:18px;">save</span> Lưu thay đổi
                </button>
                <a asp-action="Index"
                   style="padding:.75rem 1.25rem;border:1.5px solid rgba(44,54,57,.2);border-radius:10px;color:#2c3639;text-decoration:none;font-size:.9rem;font-weight:600;display:flex;align-items:center;gap:.4rem;transition:background .15s;"
                   onmouseover="this.style.background='rgba(44,54,57,.05)'" onmouseout="this.style.background='transparent'">
                    <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span> Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
