@model WebBanHang_2380600870.Models.Category
@{
    ViewData["Title"] = "Xóa Danh Mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActivePage"] = "Category";
    ViewData["Breadcrumb"] = "<a href='/Category'>Danh mục</a> <span class='material-symbols-outlined'>chevron_right</span> Xóa";
}

<div style="max-width:500px;">
    <div style="background:#fff; border-radius:16px; padding:2rem; box-shadow:0 1px 4px rgba(44,54,57,.06); border:1.5px solid rgba(239,68,68,.2);">

        <div style="display:flex; align-items:center; gap:.75rem; margin-bottom:1.5rem;">
            <div style="width:48px;height:48px;border-radius:12px;background:rgba(239,68,68,.1);display:flex;align-items:center;justify-content:center;">
                <span class="material-symbols-outlined" style="color:#ef4444;font-size:24px;">delete_forever</span>
            </div>
            <div>
                <div style="font-size:1.1rem;font-weight:700;color:#2c3639;">Xác nhận xóa danh mục</div>
                <div style="font-size:.78rem;color:#ef4444;font-weight:600;">Hành động này không thể hoàn tác</div>
            </div>
        </div>

        <div style="background:rgba(239,68,68,.05);border:1px solid rgba(239,68,68,.2);border-radius:12px;padding:1.25rem;margin-bottom:1.5rem;">
            <div style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#94a3b8;margin-bottom:.5rem;">Danh mục sẽ bị xóa</div>
            <div style="font-size:1.1rem;font-weight:700;color:#2c3639;">@Model.Name</div>
            @{
                var count = Model.Products?.Count() ?? 0;
            }
            <div style="font-size:.82rem;color:#94a3b8;margin-top:.4rem;">
                @if (count > 0)
                {
                    <span style="color:#ef4444;font-weight:600;">⚠️ @count sản phẩm</span>
                    <span> thuộc danh mục này sẽ bị ảnh hưởng (CategoryId sẽ mất liên kết)</span>
                }
                else
                {
                    <span>Không có sản phẩm nào thuộc danh mục này.</span>
                }
            </div>
        </div>

        <div style="display:flex;gap:.75rem;">
            <form asp-action="DeleteConfirmed" method="post" style="flex:1;">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <button type="submit"
                        style="width:100%;padding:.75rem;background:#ef4444;color:#fff;border:none;border-radius:10px;font-family:'Work Sans',sans-serif;font-size:.9rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.5rem;transition:opacity .15s;"
                        onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">
                    <span class="material-symbols-outlined" style="font-size:18px;">delete</span> Xác nhận xóa
                </button>
            </form>
            <a asp-action="Index"
               style="padding:.75rem 1.25rem;border:1.5px solid rgba(44,54,57,.2);border-radius:10px;color:#2c3639;text-decoration:none;font-size:.9rem;font-weight:600;display:flex;align-items:center;gap:.4rem;transition:background .15s;"
               onmouseover="this.style.background='rgba(44,54,57,.05)'" onmouseout="this.style.background='transparent'">
                <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span> Hủy
            </a>
        </div>
    </div>
</div>
