@model WebBanHang_2380600870.Models.Category
@{
    ViewData["Title"] = "Thêm Danh Mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActivePage"] = "Category";
    ViewData["Breadcrumb"] = "<a href='/Category'>Danh mục</a> <span class='material-symbols-outlined'>chevron_right</span> Thêm mới";
}

<style>
    .hc-toast {
        position: fixed;
        top: 1.5rem;
        right: 1.5rem;
        z-index: 9999;
        background: #fff;
        border: 1px solid rgba(162,123,92,.3);
        border-left: 4px solid #a27b5c;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: .75rem;
        box-shadow: 0 8px 24px rgba(44,54,57,.12);
        transform: translateX(110%);
        opacity: 0;
        transition: transform .35s cubic-bezier(.34,1.56,.64,1), opacity .35s ease;
        max-width: 360px;
    }

        .hc-toast.show {
            transform: translateX(0);
            opacity: 1;
        }

        .hc-toast.error {
            border-left-color: #ef4444;
        }

            .hc-toast.error .hc-toast-icon {
                color: #ef4444;
            }

    .hc-toast-icon {
        color: #a27b5c;
        font-size: 22px;
        flex-shrink: 0;
    }

    .hc-toast-msg {
        font-size: .875rem;
        font-weight: 500;
        color: #2c3639;
    }

    .hc-toast-close {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: #94a3b8;
        flex-shrink: 0;
    }
</style>

<div class="hc-toast" id="hcToast">
    <span class="material-symbols-outlined hc-toast-icon" id="hcToastIcon">check_circle</span>
    <span class="hc-toast-msg" id="hcToastMsg">Thành công!</span>
    <button class="hc-toast-close material-symbols-outlined" onclick="hideToast()">close</button>
</div>

<div style="max-width:560px;">
    <div style="background:#fff; border-radius:16px; padding:2rem; box-shadow:0 1px 4px rgba(44,54,57,.06); border:1px solid rgba(162,123,92,.15);">

        <div style="display:flex; align-items:center; gap:.75rem; margin-bottom:1.75rem;">
            <div style="width:44px;height:44px;border-radius:10px;background:rgba(162,123,92,.12);display:flex;align-items:center;justify-content:center;">
                <span class="material-symbols-outlined" style="color:#a27b5c;font-size:22px;">add_circle</span>
            </div>
            <div>
                <div style="font-size:1.1rem;font-weight:700;color:#2c3639;">Thêm danh mục mới</div>
                <div style="font-size:.75rem;color:#94a3b8;">Tạo danh mục để phân loại sản phẩm</div>
            </div>
        </div>

        <form asp-action="Add" method="post" id="catForm">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div style="background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.25);border-radius:10px;padding:.75rem 1rem;margin-bottom:1.25rem;color:#b91c1c;font-size:.85rem;">
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            <div style="margin-bottom:1.25rem;">
                <label asp-for="Name"
                       style="display:block;font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#2c3639;margin-bottom:.5rem;">
                    Tên danh mục <span style="color:#ef4444;">*</span>
                </label>
                <input asp-for="Name"
                       id="catNameInput"
                       placeholder="Ví dụ: Cà Phê, Trà & Thảo Mộc..."
                       style="width:100%;padding:.7rem 1rem;border:1.5px solid rgba(162,123,92,.35);border-radius:10px;font-family:'Work Sans',sans-serif;font-size:.9rem;color:#2c3639;background:#fafaf9;outline:none;transition:border-color .15s;box-sizing:border-box;"
                       onfocus="this.style.borderColor='#a27b5c'" onblur="this.style.borderColor='rgba(162,123,92,.35)'" />
                <span asp-validation-for="Name" style="color:#ef4444;font-size:.78rem;margin-top:.3rem;display:block;"></span>
            </div>

            <div style="display:flex;gap:.75rem;margin-top:1.75rem;">
                <button type="submit"
                        style="flex:1;padding:.75rem;background:#a27b5c;color:#fff;border:none;border-radius:10px;font-family:'Work Sans',sans-serif;font-size:.9rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.5rem;transition:opacity .15s;"
                        onmouseover="this.style.opacity='.88'" onmouseout="this.style.opacity='1'">
                    <span class="material-symbols-outlined" style="font-size:18px;">save</span> Lưu danh mục
                </button>
                <a asp-action="Index"
                   style="padding:.75rem 1.25rem;border:1.5px solid rgba(44,54,57,.2);border-radius:10px;color:#2c3639;text-decoration:none;font-size:.9rem;font-weight:600;display:flex;align-items:center;gap:.4rem;transition:background .15s;"
                   onmouseover="this.style.background='rgba(44,54,57,.05)'" onmouseout="this.style.background='transparent'">
                    <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span> Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function showToast(msg, isError = false) {
            const t    = document.getElementById('hcToast');
            const icon = document.getElementById('hcToastIcon');
            document.getElementById('hcToastMsg').textContent = msg;
            t.classList.toggle('error', isError);
            icon.textContent = isError ? 'error' : 'check_circle';
            t.classList.add('show');
            setTimeout(hideToast, 4000);
        }
        function hideToast() {
            document.getElementById('hcToast').classList.remove('show');
        }

        @if (TempData["Success"] != null)
        {
                <text>setTimeout(() => showToast('@Html.Raw(TempData["Success"])'), 200);</text>
        }
        @if (TempData["Error"] != null)
        {
                <text>setTimeout(() => showToast('@Html.Raw(TempData["Error"])', true), 200);</text>
        }
    </script>
}
