@model WebBanHang_2380600870.Models.AccountLoginViewModel
@{
    ViewData["Title"] = "Đăng Nhập | Góc Lặng";
    Layout = "_Layout";
    bool googleEnabled   = ViewBag.GoogleEnabled   == true;
    bool facebookEnabled = ViewBag.FacebookEnabled == true;
    bool hasOAuth        = googleEnabled || facebookEnabled;
}

<style>
    .auth-input {
        width: 100%;
        padding: 13px 16px 13px 44px;
        border-radius: 50px;
        border: 1.5px solid rgba(162,123,92,0.25);
        background: #F7F7F6;
        font-size: 14px;
        color: #2C3639;
        outline: none;
        transition: border-color .2s, background .2s, box-shadow .2s;
        font-family: 'Work Sans', sans-serif;
    }
    .auth-input:focus {
        border-color: #A27B5C;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(162,123,92,0.12);
    }
    .auth-input::placeholder { color: rgba(63,78,79,0.4); }
    .auth-input-wrap { position: relative; }
    .auth-input-icon {
        position: absolute; left: 16px; top: 50%; transform: translateY(-50%);
        color: #A27B5C; font-size: 17px; pointer-events: none;
    }
    .auth-input-eye {
        position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
        color: #3F4E4F; font-size: 17px; cursor: pointer;
        background: none; border: none; transition: color .2s;
    }
    .auth-input-eye:hover { color: #A27B5C; }
</style>

<main class="flex-grow flex items-center justify-center px-4 py-14" style="background:#EDEAE5;">

    <div class="w-full max-w-[880px] grid grid-cols-1 md:grid-cols-[1.1fr_1fr] rounded-3xl shadow-2xl overflow-hidden"
         style="border:1px solid rgba(162,123,92,0.12);">

        <!-- LEFT -->
        <div class="hidden md:flex flex-col justify-between p-12 relative overflow-hidden" style="background:#2C3639; min-height:520px;">
            <div class="absolute inset-0 opacity-20"
                 style="background-image:url('https://lh3.googleusercontent.com/aida-public/AB6AXuBGJFZqLPUlnhR_k7UwNpbZzzz0QFkHBhYTZMdu3ds1fU0-ImhqJBb7Pj0hBWJ7QXDypzzJpI7E7EkfeBCr3_ne_cO7wbm3GqycYrDB8jEGVgrS8dOQ-l432PbNd-fTxqdqFEcN2PTGTkJBWljryUuR-9u9LjLdzM0KV-UPA1IWeom6L1K0DecBdV7z40afEQQGtd9tWKMvLC9MYHzvfLpa_WVOlqjLTqibYCOwuXoRnJ_RfSOejqkAmhchU2cL-vsUGfkHqaEoiOI9');
                 background-size:cover; background-position:center;"></div>
            <div class="absolute inset-0" style="background:linear-gradient(160deg,rgba(44,54,57,0.5) 0%,rgba(28,25,22,0.75) 100%);"></div>

            <div class="relative z-10">
                <span class="font-bold tracking-[0.28em] uppercase text-xs mb-5 block" style="color:#A27B5C;">Góc Lặng Café</span>
                <h2 class="font-black leading-[1.15] mb-5" style="font-family:'Playfair Display',serif; color:#DCD7C9; font-size:clamp(2.4rem,4vw,3.2rem);">
                    Chào<br />Trở Lại
                </h2>
                <p style="color:rgba(220,215,201,0.72); line-height:1.9; font-size:14px; max-width:260px;">
                    Đăng nhập để tiếp tục hành trình của bạn cùng Góc Lặng — nơi mỗi tách cà phê là một câu chuyện.
                </p>
            </div>

            <div class="relative z-10">
                <div class="h-px w-full mb-6" style="background:rgba(162,123,92,0.25);"></div>
                <div class="flex items-center gap-3">
                    <div class="flex -space-x-2">
                        @{ var _avatars = new[] { ("A", "#A27B5C"), ("M", "#3F4E4F"), ("T", "#A27B5C") }; }
                        @foreach (var _av in _avatars)
                        {
                            <div class="w-9 h-9 rounded-full border-2 flex items-center justify-center text-xs font-bold text-white shrink-0"
                                 style="border-color:#2C3639; background-color:@_av.Item2;">@_av.Item1</div>
                        }
                    </div>
                    <p style="color:rgba(220,215,201,0.5); font-size:12px;">Hơn 1,200 thành viên đang thưởng thức</p>
                </div>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="p-8 md:p-10 flex flex-col justify-center" style="background:#fff;">

            <h3 class="font-black text-slate-custom mb-1" style="font-family:'Playfair Display',serif; font-size:1.75rem;">Đăng Nhập</h3>
            <p class="text-sm mb-7" style="color:#3F4E4F; line-height:1.8;">Nhập thông tin tài khoản của bạn bên dưới.</p>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div class="mb-5 px-4 py-3 rounded-2xl text-sm flex gap-2 items-start"
                     style="background:rgba(239,68,68,0.07); border:1px solid rgba(239,68,68,0.22); color:#b91c1c;">
                    <span class="material-symbols-outlined shrink-0" style="font-size:17px;margin-top:1px;">error</span>
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form asp-action="Login" method="post" class="flex flex-col gap-4">
                @Html.AntiForgeryToken()

                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-bold uppercase tracking-widest" style="color:#2C3639;">Email</label>
                    <div class="auth-input-wrap">
                        <span class="material-symbols-outlined auth-input-icon">mail</span>
                        <input asp-for="Email" type="email" class="auth-input" placeholder="email@gmail.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 text-xs px-1"></span>
                </div>

                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-bold uppercase tracking-widest" style="color:#2C3639;">Mật Khẩu</label>
                    <div class="auth-input-wrap">
                        <span class="material-symbols-outlined auth-input-icon">lock</span>
                        <input asp-for="Password" type="password" id="pwd" class="auth-input" placeholder="••••••••" style="padding-right:44px;" />
                        <button type="button" class="auth-input-eye" onclick="togglePwd('pwd','eye1')">
                            <span class="material-symbols-outlined" id="eye1" style="font-size:18px;">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-red-500 text-xs px-1"></span>
                </div>

                <div class="flex items-center gap-2 px-1">
                    <input asp-for="RememberMe" type="checkbox" id="rem" class="w-4 h-4 rounded cursor-pointer" style="accent-color:#A27B5C;" />
                    <label for="rem" class="text-sm cursor-pointer" style="color:#3F4E4F;">Ghi nhớ đăng nhập</label>
                </div>

                <button type="submit"
                        class="w-full py-3.5 rounded-full font-bold text-sm uppercase tracking-widest text-white transition-all hover:opacity-90 active:scale-[0.98] mt-1"
                        style="background:#2C3639; box-shadow:0 4px 18px rgba(44,54,57,0.22); letter-spacing:.15em;">
                    Đăng Nhập
                </button>

                @* Chỉ hiện divider "hoặc" nếu có ít nhất 1 OAuth provider *@
                @if (hasOAuth)
                {
                    <div class="flex items-center gap-3 my-1">
                        <div class="flex-1 h-px" style="background:rgba(162,123,92,0.15);"></div>
                        <span class="text-xs uppercase tracking-wider" style="color:#3F4E4F;">hoặc</span>
                        <div class="flex-1 h-px" style="background:rgba(162,123,92,0.15);"></div>
                    </div>
                }
            </form>

            @* Google Login — chỉ hiện khi đã cấu hình ClientId *@
            @if (googleEnabled)
            {
                <form asp-action="ExternalLogin" asp-controller="Account" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="provider" value="Google" />
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    <button type="submit"
                            class="w-full py-3 rounded-full font-semibold text-sm flex items-center justify-center gap-3 transition-all hover:opacity-90 active:scale-[0.98]"
                            style="border:1.5px solid rgba(162,123,92,0.25); background:#F7F7F6; color:#2C3639;">
                        <svg width="18" height="18" viewBox="0 0 48 48">
                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.08 17.74 9.5 24 9.5z" />
                            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-3.59-13.46-8.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                        </svg>
                        Tiếp tục với Google
                    </button>
                </form>
            }

            @* Facebook Login — chỉ hiện khi đã cấu hình AppId *@
            @if (facebookEnabled)
            {
                <form asp-action="ExternalLogin" asp-controller="Account" method="post" class="mb-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="provider" value="Facebook" />
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    <button type="submit"
                            class="w-full py-3 rounded-full font-semibold text-sm flex items-center justify-center gap-3 transition-all hover:opacity-90 active:scale-[0.98]"
                            style="border:1.5px solid rgba(162,123,92,0.25); background:#F7F7F6; color:#2C3639;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2">
                            <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z" />
                        </svg>
                        Tiếp tục với Facebook
                    </button>
                </form>
            }

            <p class="text-center text-sm" style="color:#3F4E4F;">
                Chưa có tài khoản?
                <a asp-controller="Account" asp-action="Register" class="font-bold hover:underline" style="color:#A27B5C;">Đăng ký ngay</a>
            </p>
        </div>
    </div>
</main>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function togglePwd(id, iconId) {
            var i = document.getElementById(id), ic = document.getElementById(iconId);
            i.type = i.type === 'password' ? 'text' : 'password';
            ic.textContent = i.type === 'password' ? 'visibility' : 'visibility_off';
        }
    </script>
}
