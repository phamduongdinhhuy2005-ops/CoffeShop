@* Views/Cart/Index.cshtml *@
@model WebBanHang_2380600870.Models.Cart
@{
    ViewData["Title"] = "Giỏ Hàng";
}

<section class="min-h-screen pt-28 pb-20" style="background-color: #F7F7F6;">
    <div class="max-w-6xl mx-auto px-4">

        <!-- Tiêu đề -->
        <div class="mb-10 text-center">
            <p class="text-sm tracking-[0.2em] uppercase mb-2" style="color: #A27B5C; font-family: 'Work Sans', sans-serif;">
                Đơn Hàng Của Bạn
            </p>
            <h1 class="text-4xl font-bold" style="font-family: 'Playfair Display', serif; color: #2C3639;">
                Giỏ Hàng
            </h1>
        </div>

        @if (!Model.Items.Any())
        {
            <!-- Giỏ trống -->
            <div class="text-center py-24">
                <div class="w-24 h-24 mx-auto mb-6 rounded-full flex items-center justify-center" style="background-color: #DCD7C9;">
                    <span class="material-symbols-outlined text-5xl" style="color: #A27B5C;">shopping_bag</span>
                </div>
                <h2 class="text-2xl font-semibold mb-3" style="font-family: 'Playfair Display', serif; color: #2C3639;">
                    Giỏ hàng đang trống
                </h2>
                <p class="mb-8" style="color: #3F4E4F; font-family: 'Work Sans', sans-serif;">
                    Hãy khám phá menu và thêm món bạn yêu thích nhé.
                </p>
                <a href="/Menu"
                   class="inline-block px-8 py-3 rounded-full text-white font-medium transition-all duration-300 hover:opacity-90"
                   style="background-color: #A27B5C; font-family: 'Work Sans', sans-serif;">
                    Xem Thực Đơn
                </a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Danh sách sản phẩm -->
                <div class="lg:col-span-2 space-y-4">
                    @foreach (var item in Model.Items)
                    {
                        <div class="bg-white rounded-2xl p-5 flex gap-4 shadow-sm">
                            <img src="@item.ImageUrl" alt="@item.ProductName"
                                 class="w-24 h-24 object-cover rounded-xl flex-shrink-0"
                                 onerror="this.src='/images/placeholder.jpg'" />

                            <div class="flex-1 min-w-0">
                                <h3 class="font-semibold text-lg mb-1" style="font-family: 'Playfair Display', serif; color: #2C3639;">
                                    @item.ProductName
                                </h3>
                                <div class="flex flex-wrap gap-2 mb-3">
                                    <span class="text-xs px-2 py-1 rounded-full" style="background-color: #DCD7C9; color: #3F4E4F; font-family: 'Work Sans', sans-serif;">
                                        Size @item.Size
                                    </span>
                                    <span class="text-xs px-2 py-1 rounded-full" style="background-color: #DCD7C9; color: #3F4E4F; font-family: 'Work Sans', sans-serif;">
                                        Đường @item.SugarLevel
                                    </span>
                                    @if (!string.IsNullOrEmpty(item.Toppings))
                                    {
                                        <span class="text-xs px-2 py-1 rounded-full" style="background-color: #DCD7C9; color: #3F4E4F; font-family: 'Work Sans', sans-serif;">
                                            @item.Toppings
                                        </span>
                                    }
                                </div>

                                <div class="flex items-center justify-between">
                                    <!-- Điều chỉnh số lượng -->
                                    <form method="post" action="/Cart/UpdateQuantity" class="flex items-center gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <input type="hidden" name="size" value="@item.Size" />
                                        <input type="hidden" name="sugarLevel" value="@item.SugarLevel" />
                                        <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                                class="w-8 h-8 rounded-full flex items-center justify-center transition-colors hover:opacity-80"
                                                style="background-color: #DCD7C9; color: #2C3639;">
                                            −
                                        </button>
                                        <span class="w-8 text-center font-medium" style="color: #2C3639; font-family: 'Work Sans', sans-serif;">
                                            @item.Quantity
                                        </span>
                                        <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                                class="w-8 h-8 rounded-full flex items-center justify-center transition-colors hover:opacity-80"
                                                style="background-color: #A27B5C; color: white;">
                                            +
                                        </button>
                                    </form>

                                    <!-- Giá + Xóa -->
                                    <div class="flex items-center gap-4">
                                        <span class="font-bold text-lg" style="color: #A27B5C; font-family: 'Playfair Display', serif;">
                                            @item.LineTotal.ToString("N0")đ
                                        </span>
                                        <form method="post" action="/Cart/Remove">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="hidden" name="size" value="@item.Size" />
                                            <input type="hidden" name="sugarLevel" value="@item.SugarLevel" />
                                            <button type="submit" class="w-8 h-8 flex items-center justify-center rounded-full transition-colors hover:bg-red-50">
                                                <span class="material-symbols-outlined text-base text-red-400">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Nút xóa toàn bộ -->
                    <div class="flex justify-between items-center pt-2">
                        <a href="/Menu" class="flex items-center gap-2 text-sm transition-colors hover:opacity-70"
                           style="color: #A27B5C; font-family: 'Work Sans', sans-serif;">
                            <span class="material-symbols-outlined text-base">arrow_back</span>
                            Tiếp tục mua hàng
                        </a>
                        <form method="post" action="/Cart/Clear">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-sm text-red-400 hover:text-red-600 transition-colors"
                                    style="font-family: 'Work Sans', sans-serif;"
                                    onclick="return confirm('Xóa toàn bộ giỏ hàng?')">
                                Xóa tất cả
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Tóm tắt đơn hàng -->
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-2xl p-6 shadow-sm sticky top-28">
                        <h2 class="text-xl font-bold mb-6" style="font-family: 'Playfair Display', serif; color: #2C3639;">
                            Tóm Tắt Đơn Hàng
                        </h2>

                        <div class="space-y-3 mb-6">
                            @foreach (var item in Model.Items)
                            {
                                <div class="flex justify-between text-sm" style="font-family: 'Work Sans', sans-serif; color: #3F4E4F;">
                                    <span class="truncate mr-2">@item.ProductName × @item.Quantity</span>
                                    <span class="flex-shrink-0">@item.LineTotal.ToString("N0")đ</span>
                                </div>
                            }
                        </div>

                        <div class="border-t pt-4 mb-6" style="border-color: #DCD7C9;">
                            <div class="flex justify-between font-bold text-lg" style="color: #2C3639; font-family: 'Playfair Display', serif;">
                                <span>Tổng cộng</span>
                                <span style="color: #A27B5C;">@Model.TotalAmount.ToString("N0")đ</span>
                            </div>
                            <p class="text-xs mt-1" style="color: #3F4E4F; font-family: 'Work Sans', sans-serif;">
                                Chưa bao gồm phí giao hàng
                            </p>
                        </div>

                        <a href="/Cart/Checkout"
                           class="w-full block text-center py-4 rounded-full text-white font-semibold transition-all duration-300 hover:opacity-90 hover:shadow-lg"
                           style="background-color: #A27B5C; font-family: 'Work Sans', sans-serif;">
                            Tiến Hành Thanh Toán →
                        </a>

                        <div class="mt-4 text-center text-xs" style="color: #3F4E4F; font-family: 'Work Sans', sans-serif;">
                            <span class="material-symbols-outlined text-xs align-middle">lock</span>
                            Thanh toán bảo mật
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
