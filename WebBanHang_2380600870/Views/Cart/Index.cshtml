@* Views/Cart/Index.cshtml *@
@* REDESIGNED: Hero section + glassmorphism cards + fix toppings fields trong form *@
@model WebBanHang_2380600870.Models.Cart
@{
    ViewData["Title"] = "Giỏ Hàng | Góc Lặng";
    Layout = "_Layout";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />
<style>
    /* ── Hero ─────────────────────────────────────────── */
    .cart-hero {
        position: relative;
        background: #2C3639;
        overflow: hidden;
        padding: 5rem 1rem 4rem;
        text-align: center;
    }

    .cart-hero-bg {
        position: absolute;
        inset: 0;
        background-image: url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&w=1400&q=80');
        background-size: cover;
        background-position: center;
        opacity: 0.28;
    }

    .cart-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 60% 50% at 20% 50%, rgba(162,123,92,0.18) 0%, transparent 70%), radial-gradient(ellipse 50% 60% at 80% 30%, rgba(162,123,92,0.12) 0%, transparent 70%);
        pointer-events: none;
    }

    .cart-hero-pattern {
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(45deg, rgba(162,123,92,0.03) 0px, rgba(162,123,92,0.03) 1px, transparent 1px, transparent 60px), repeating-linear-gradient(-45deg, rgba(162,123,92,0.03) 0px, rgba(162,123,92,0.03) 1px, transparent 1px, transparent 60px);
        pointer-events: none;
    }

    .cart-hero-content {
        position: relative;
        z-index: 1;
    }

    .cart-hero-label {
        font-size: .7rem;
        font-weight: 800;
        letter-spacing: .28em;
        text-transform: uppercase;
        color: #A27B5C;
        margin-bottom: .75rem;
    }

    .cart-hero-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 900;
        color: #F2EFE9;
        line-height: 1.1;
        margin-bottom: 1rem;
    }

    .cart-hero-sub {
        font-size: .9rem;
        color: rgba(220,215,201,0.6);
        letter-spacing: .04em;
    }

    .cart-hero-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(162,123,92,0.15);
        border: 1.5px solid rgba(162,123,92,0.3);
        margin-bottom: 1.5rem;
        backdrop-filter: blur(8px);
    }

    /* ── Body ─────────────────────────────────────────── */
    .cart-body {
        background: #F2EFE9;
        min-height: 60vh;
        padding: 2.5rem 1rem 4rem;
    }

    /* ── Cart item card ───────────────────────────────── */
    .cart-item-card {
        background: #fff;
        border: 1px solid rgba(162,123,92,0.12);
        border-radius: 20px;
        padding: 1.25rem;
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        transition: border-color .2s, box-shadow .2s;
    }

        .cart-item-card:hover {
            border-color: rgba(162,123,92,0.3);
            box-shadow: 0 6px 24px rgba(44,54,57,0.07);
        }

    .cart-item-img {
        width: 88px;
        height: 88px;
        border-radius: 14px;
        object-fit: cover;
        flex-shrink: 0;
        border: 1px solid rgba(162,123,92,0.1);
    }

    .cart-item-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: #2C3639;
        margin-bottom: .4rem;
        letter-spacing: -.01em;
    }

    .tag-pill {
        display: inline-block;
        font-size: .68rem;
        font-weight: 600;
        padding: .2rem .6rem;
        border-radius: 99px;
        background: rgba(162,123,92,0.1);
        color: #3F4E4F;
        border: 1px solid rgba(162,123,92,0.18);
    }

    .qty-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        font-weight: 700;
        transition: all .15s;
    }

    .qty-btn-minus {
        background: #F2EFE9;
        color: #2C3639;
    }

        .qty-btn-minus:hover {
            background: #DCD7C9;
        }

    .qty-btn-plus {
        background: #A27B5C;
        color: #fff;
    }

        .qty-btn-plus:hover {
            background: #8d6a4d;
        }

    .qty-display {
        min-width: 32px;
        text-align: center;
        font-weight: 700;
        font-size: 1rem;
        color: #2C3639;
    }

    .line-price {
        font-family: 'Playfair Display', serif;
        font-size: 1.05rem;
        font-weight: 700;
        font-style: italic;
        color: #A27B5C;
        white-space: nowrap;
        letter-spacing: -.01em;
    }

    .delete-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 1px solid rgba(239,68,68,0.2);
        background: transparent;
        color: #ef4444;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all .15s;
        flex-shrink: 0;
    }

        .delete-btn:hover {
            background: rgba(239,68,68,0.08);
            border-color: rgba(239,68,68,0.4);
        }

    /* ── Summary card ────────────────────────────────── */
    .summary-card {
        background: #fff;
        border: 1px solid rgba(162,123,92,0.15);
        border-radius: 24px;
        padding: 1.75rem;
        box-shadow: 0 4px 24px rgba(44,54,57,0.06);
        position: sticky;
        top: 6rem;
    }

    .summary-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.15rem;
        font-weight: 700;
        font-style: italic;
        color: #2C3639;
        margin-bottom: 1.25rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(162,123,92,0.12);
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: .5rem;
        font-size: .875rem;
        color: #3F4E4F;
        margin-bottom: .75rem;
    }

        .summary-row .name {
            flex: 1;
            min-width: 0;
        }

    .summary-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 800;
        font-size: 1.15rem;
        color: #2C3639;
        padding-top: 1rem;
        border-top: 2px solid rgba(162,123,92,0.12);
        margin-bottom: 1.5rem;
    }

        .summary-total .amount {
            color: #A27B5C;
            font-family: 'Playfair Display', serif;
        }

    .checkout-btn {
        display: block;
        width: 100%;
        padding: 1rem;
        border-radius: 99px;
        background: linear-gradient(135deg, #A27B5C, #8d6a4d);
        color: #fff;
        font-weight: 700;
        font-size: .9rem;
        letter-spacing: .08em;
        text-align: center;
        border: none;
        cursor: pointer;
        transition: all .2s;
        text-decoration: none;
        box-shadow: 0 4px 16px rgba(162,123,92,0.35);
    }

        .checkout-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 28px rgba(162,123,92,0.45);
            color: #fff;
            text-decoration: none;
        }

    .secure-badge {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        font-size: .72rem;
        color: rgba(63,78,79,0.45);
        margin-top: .875rem;
        letter-spacing: .04em;
    }

    /* ── Empty state ─────────────────────────────────── */
    .empty-wrap {
        text-align: center;
        padding: 5rem 1rem;
    }

    .empty-icon-ring {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        background: rgba(162,123,92,0.08);
        border: 2px dashed rgba(162,123,92,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
    }

    .empty-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.6rem;
        font-weight: 700;
        font-style: italic;
        color: #2C3639;
        margin-bottom: .75rem;
    }

    .empty-sub {
        font-size: .9rem;
        color: rgba(63,78,79,0.55);
        margin-bottom: 2rem;
    }

    .browse-btn {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .875rem 2rem;
        border-radius: 99px;
        background: #2C3639;
        color: #F2EFE9;
        font-weight: 600;
        font-size: .875rem;
        transition: all .2s;
        text-decoration: none;
    }

        .browse-btn:hover {
            background: #A27B5C;
            color: #fff;
            text-decoration: none;
            transform: translateY(-1px);
        }

    .continue-link {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        font-size: .85rem;
        font-weight: 600;
        color: #A27B5C;
        text-decoration: none;
        transition: opacity .15s;
    }

        .continue-link:hover {
            opacity: .7;
            text-decoration: none;
        }

    .clear-btn {
        background: none;
        border: none;
        font-size: .85rem;
        color: #ef4444;
        cursor: pointer;
        font-weight: 600;
        font-family: 'Work Sans', sans-serif;
        padding: 0;
        transition: color .15s;
    }

        .clear-btn:hover {
            color: #b91c1c;
        }
</style>

@* ── HERO ──────────────────────────────────────────── *@
<div class="cart-hero">
    <div class="cart-hero-bg"></div>
    <div class="cart-hero-pattern"></div>
    <div class="cart-hero-content">
        <div class="cart-hero-icon mx-auto">
            <span class="material-symbols-outlined" style="font-size: 28px; color: #A27B5C;">shopping_bag</span>
        </div>
        <p class="cart-hero-label">Đơn Hàng Của Bạn</p>
        <h1 class="cart-hero-title">Giỏ Hàng</h1>
        @if (Model.Items.Any())
        {
            <p class="cart-hero-sub">@Model.Items.Count món · @Model.TotalQuantity sản phẩm</p>
        }
        else
        {
            <p class="cart-hero-sub">Trống — hãy thêm gì đó nhé ☕</p>
        }
    </div>
</div>

@* ── BODY ──────────────────────────────────────────── *@
<div class="cart-body">
    <div class="max-w-5xl mx-auto">

        @if (!Model.Items.Any())
        {
            @* ── EMPTY STATE ── *@
            <div class="empty-wrap">
                <div class="empty-icon-ring">
                    <span class="material-symbols-outlined" style="font-size: 40px; color: rgba(162,123,92,0.4);">shopping_bag</span>
                </div>
                <h2 class="empty-title">Giỏ hàng đang trống</h2>
                <p class="empty-sub">Hãy khám phá thực đơn và chọn những món bạn yêu thích.</p>
                <a href="/Menu" class="browse-btn">
                    <span class="material-symbols-outlined" style="font-size: 18px;">restaurant_menu</span>
                    Khám Phá Thực Đơn
                </a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">

                @* ── ITEM LIST ── *@
                <div class="lg:col-span-2 space-y-3">

                    @foreach (var item in Model.Items)
                    {
                        <div class="cart-item-card">
                            <img src="@item.ImageUrl" alt="@item.ProductName"
                                 class="cart-item-img"
                                 onerror="this.src='/images/placeholder.jpg'" />

                            <div class="flex-1 min-w-0">
                                <h3 class="cart-item-name">@item.ProductName</h3>

                                <div class="flex flex-wrap gap-1.5 mb-3">
                                    <span class="tag-pill">Size @item.Size</span>
                                    <span class="tag-pill">Đường @item.SugarLevel</span>
                                    @if (!string.IsNullOrEmpty(item.Toppings))
                                    {
                                        <span class="tag-pill">@item.Toppings</span>
                                    }
                                </div>

                                <div class="flex items-center justify-between flex-wrap gap-3">
                                    @* Quantity form — [FIX] thêm toppings hidden field *@
                                    <div class="flex items-center gap-2">
                                        <form method="post" action="/Cart/UpdateQuantity" style="display:contents;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="hidden" name="size" value="@item.Size" />
                                            <input type="hidden" name="sugarLevel" value="@item.SugarLevel" />
                                            <input type="hidden" name="toppings" value="@item.Toppings" />
                                            <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                                    class="qty-btn qty-btn-minus" title="Giảm">
                                                −
                                            </button>
                                        </form>
                                        <span class="qty-display">@item.Quantity</span>
                                        <form method="post" action="/Cart/UpdateQuantity" style="display:contents;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="hidden" name="size" value="@item.Size" />
                                            <input type="hidden" name="sugarLevel" value="@item.SugarLevel" />
                                            <input type="hidden" name="toppings" value="@item.Toppings" />
                                            <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                                    class="qty-btn qty-btn-plus" title="Tăng">
                                                +
                                            </button>
                                        </form>
                                    </div>

                                    <div class="flex items-center gap-3">
                                        <span class="line-price">@item.LineTotal.ToString("N0")đ</span>
                                        @* Delete form — [FIX] thêm toppings hidden field *@
                                        <form method="post" action="/Cart/Remove" style="margin:0;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <input type="hidden" name="size" value="@item.Size" />
                                            <input type="hidden" name="sugarLevel" value="@item.SugarLevel" />
                                            <input type="hidden" name="toppings" value="@item.Toppings" />
                                            <button type="submit" class="delete-btn" title="Xóa sản phẩm này"
                                                    onclick="return confirm('Xóa @item.ProductName khỏi giỏ hàng?')">
                                                <span class="material-symbols-outlined" style="font-size:16px;">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    @* Bottom bar *@
                    <div class="flex justify-between items-center pt-1">
                        <a href="/Menu" class="continue-link">
                            <span class="material-symbols-outlined" style="font-size:16px;">arrow_back</span>
                            Tiếp tục mua hàng
                        </a>
                        <form method="post" action="/Cart/Clear" style="margin:0;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="clear-btn"
                                    onclick="return confirm('Bạn có chắc muốn xóa toàn bộ giỏ hàng không?')">
                                Xóa tất cả
                            </button>
                        </form>
                    </div>
                </div>

                @* ── SUMMARY ── *@
                <div class="lg:col-span-1">
                    <div class="summary-card">
                        <h2 class="summary-title">Tóm Tắt Đơn Hàng</h2>

                        <div class="mb-4">
                            @foreach (var item in Model.Items)
                            {
                                <div class="summary-row">
                                    <span class="name truncate">@item.ProductName × @item.Quantity</span>
                                    <span class="flex-shrink-0 font-semibold" style="color:#3F4E4F;">@item.LineTotal.ToString("N0")đ</span>
                                </div>
                            }
                        </div>

                        <div class="summary-total">
                            <span>Tổng cộng</span>
                            <span class="amount">@Model.TotalAmount.ToString("N0")đ</span>
                        </div>

                        <p class="text-xs mb-5" style="color:rgba(63,78,79,0.45); margin-top:-1rem;">Chưa bao gồm phí giao hàng</p>

                        <a href="/Cart/Checkout" class="checkout-btn">
                            Tiến Hành Thanh Toán →
                        </a>

                        <div class="secure-badge">
                            <span class="material-symbols-outlined" style="font-size:13px;">lock</span>
                            Thanh toán bảo mật
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
