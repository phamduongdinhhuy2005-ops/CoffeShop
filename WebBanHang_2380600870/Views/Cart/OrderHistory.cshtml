@* Views/Cart/OrderHistory.cshtml *@
@* FIX RZ1010: ordersJson computed in top-level @{} block, NOT inside @else{} *@
@* NEW: Order detail drawer + Cancel order *@
@model IEnumerable<WebBanHang_2380600870.Models.Order>
@{
    ViewData["Title"] = "Lịch Sử Đặt Hàng | Góc Lặng";
    Layout = "_Layout";

    string OStatusLabel(WebBanHang_2380600870.Models.OrderStatus s) => s switch
    {
        WebBanHang_2380600870.Models.OrderStatus.Pending    => "Chờ xác nhận",
        WebBanHang_2380600870.Models.OrderStatus.Confirmed  => "Đã xác nhận",
        WebBanHang_2380600870.Models.OrderStatus.Processing => "Đang pha chế",
        WebBanHang_2380600870.Models.OrderStatus.Ready      => "Sẵn sàng",
        WebBanHang_2380600870.Models.OrderStatus.Completed  => "Hoàn thành",
        WebBanHang_2380600870.Models.OrderStatus.Cancelled  => "Đã hủy",
        _ => "Không xác định"
    };
    string OStatusBg(WebBanHang_2380600870.Models.OrderStatus s) => s switch
    {
        WebBanHang_2380600870.Models.OrderStatus.Pending    => "rgba(234,179,8,0.12)",
        WebBanHang_2380600870.Models.OrderStatus.Confirmed  => "rgba(59,130,246,0.12)",
        WebBanHang_2380600870.Models.OrderStatus.Processing => "rgba(139,92,246,0.12)",
        WebBanHang_2380600870.Models.OrderStatus.Ready      => "rgba(16,185,129,0.12)",
        WebBanHang_2380600870.Models.OrderStatus.Completed  => "rgba(16,185,129,0.15)",
        WebBanHang_2380600870.Models.OrderStatus.Cancelled  => "rgba(239,68,68,0.1)",
        _ => "rgba(100,116,139,0.1)"
    };
    string OStatusClr(WebBanHang_2380600870.Models.OrderStatus s) => s switch
    {
        WebBanHang_2380600870.Models.OrderStatus.Pending    => "#b45309",
        WebBanHang_2380600870.Models.OrderStatus.Confirmed  => "#1d4ed8",
        WebBanHang_2380600870.Models.OrderStatus.Processing => "#7c3aed",
        WebBanHang_2380600870.Models.OrderStatus.Ready      => "#065f46",
        WebBanHang_2380600870.Models.OrderStatus.Completed  => "#065f46",
        WebBanHang_2380600870.Models.OrderStatus.Cancelled  => "#b91c1c",
        _ => "#64748b"
    };
    string OStatusIcon(WebBanHang_2380600870.Models.OrderStatus s) => s switch
    {
        WebBanHang_2380600870.Models.OrderStatus.Pending    => "hourglass_empty",
        WebBanHang_2380600870.Models.OrderStatus.Confirmed  => "check_circle",
        WebBanHang_2380600870.Models.OrderStatus.Processing => "coffee_maker",
        WebBanHang_2380600870.Models.OrderStatus.Ready      => "done_all",
        WebBanHang_2380600870.Models.OrderStatus.Completed  => "task_alt",
        WebBanHang_2380600870.Models.OrderStatus.Cancelled  => "cancel",
        _ => "help"
    };

    // FIX RZ1010: serialize ở đây (top-level @{}), không dùng @{} lồng bên trong @else{}
    var customerName  = ViewBag.CustomerName  as string ?? "";
    var customerPhone = ViewBag.CustomerPhone as string ?? "";
    var ordersJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Select(o => new {
            id             = o.Id,
            date           = o.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm"),
            status         = (int)o.Status,
            statusLabel    = OStatusLabel(o.Status),
            statusBg       = OStatusBg(o.Status),
            statusClr      = OStatusClr(o.Status),
            statusIcon     = OStatusIcon(o.Status),
            total          = o.TotalAmount,
            shipping       = o.ShippingAddress ?? "",
            payment        = o.PaymentMethod == "COD" ? "Thanh toán khi nhận (COD)" : "Chuyển khoản",
            note           = o.Note ?? "",
            canCancel      = o.Status == WebBanHang_2380600870.Models.OrderStatus.Pending,
            customerName   = customerName,
            customerPhone  = customerPhone,
            items       = (o.OrderDetails ?? new List<WebBanHang_2380600870.Models.OrderDetail>())
                            .Select(d => new {
                                name     = d.Product != null ? d.Product.Name : "Sản phẩm",
                                img      = d.Product != null ? (d.Product.ImageUrl ?? "") : "",
                                qty      = d.Quantity,
                                price    = d.UnitPrice,
                                itemNote = d.ItemNote ?? ""
                            })
        })
    );
}

<style>
    .oh-row { background:#fff; border-radius:16px; border:1px solid rgba(162,123,92,.15); padding:1.1rem 1.25rem; cursor:pointer; transition:border-color .2s,box-shadow .2s,transform .15s; display:flex; align-items:center; gap:1rem; }
    .oh-row:hover { border-color:rgba(162,123,92,.4); box-shadow:0 4px 20px rgba(44,54,57,.08); transform:translateY(-1px); }
    .oh-icon { width:44px; height:44px; border-radius:50%; background:rgba(162,123,92,.09); display:flex; align-items:center; justify-content:center; flex-shrink:0; color:#A27B5C; }
    .oh-icon .material-symbols-outlined { font-size:20px; }
    .oh-info { flex:1; min-width:0; }
    .oh-title { font-size:.95rem; font-weight:700; color:#2C3639; }
    .oh-sub { font-size:.78rem; color:rgba(63,78,79,.5); margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .oh-right { text-align:right; flex-shrink:0; }
    .oh-amount { font-size:.95rem; font-weight:800; color:#A27B5C; }
    .oh-date { font-size:.72rem; color:rgba(63,78,79,.45); margin-top:2px; }
    .oh-arrow { color:rgba(162,123,92,.4); font-size:16px; flex-shrink:0; transition:transform .2s; }
    .oh-row:hover .oh-arrow { transform:translateX(3px); color:#A27B5C; }

    /* Drawer */
    .od-overlay { position:fixed; inset:0; z-index:9000; background:rgba(28,22,16,.55); backdrop-filter:blur(4px); display:flex; align-items:flex-end; justify-content:center; opacity:0; pointer-events:none; transition:opacity .25s; }
    .od-overlay.open { opacity:1; pointer-events:all; }
    .od-drawer { width:100%; max-width:560px; background:#fff; border-radius:24px 24px 0 0; max-height:92vh; overflow-y:auto; transform:translateY(100%); transition:transform .35s cubic-bezier(.22,1,.36,1); box-shadow:0 -8px 48px rgba(44,54,57,.22); }
    .od-overlay.open .od-drawer { transform:translateY(0); }
    .od-handle { width:40px; height:4px; background:rgba(162,123,92,.25); border-radius:99px; margin:14px auto 0; }
    .od-header { display:flex; align-items:flex-start; justify-content:space-between; padding:1.25rem 1.5rem 0; gap:1rem; }
    .od-order-num { font-family:'Playfair Display',serif; font-size:1.35rem; font-weight:800; color:#2C3639; margin-bottom:.3rem; }
    .od-close { width:34px; height:34px; border-radius:50%; background:rgba(162,123,92,.08); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; color:#3F4E4F; transition:background .15s; }
    .od-close:hover { background:rgba(162,123,92,.18); }
    .od-close .material-symbols-outlined { font-size:18px; }
    .od-status-banner { margin:1rem 1.5rem 0; border-radius:12px; padding:.75rem 1rem; display:flex; align-items:center; gap:.6rem; font-size:.85rem; font-weight:700; }
    .od-section-title { font-size:.65rem; font-weight:800; text-transform:uppercase; letter-spacing:.12em; color:rgba(63,78,79,.45); padding:1.1rem 1.5rem .5rem; border-top:1px solid rgba(162,123,92,.08); margin-top:.5rem; }
    .od-info-grid { display:grid; grid-template-columns:1fr 1fr; gap:.5rem .75rem; padding:0 1.5rem; }
    .od-info-item { display:flex; flex-direction:column; gap:.15rem; }
    .od-info-label { font-size:.68rem; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:rgba(63,78,79,.4); }
    .od-info-val { font-size:.875rem; font-weight:600; color:#2C3639; }
    .od-product-list { padding:.25rem 1.5rem 0; display:flex; flex-direction:column; gap:.6rem; }
    .od-product-row { display:flex; gap:.875rem; align-items:flex-start; background:#F7F7F6; border-radius:12px; padding:.75rem; }
    .od-product-img { width:52px; height:52px; border-radius:9px; object-fit:cover; flex-shrink:0; border:1px solid rgba(162,123,92,.12); }
    .od-product-img-ph { width:52px; height:52px; border-radius:9px; flex-shrink:0; background:rgba(162,123,92,.1); display:flex; align-items:center; justify-content:center; color:rgba(162,123,92,.5); }
    .od-product-info { flex:1; min-width:0; }
    .od-product-name { font-size:.875rem; font-weight:700; color:#2C3639; }
    .od-product-note { font-size:.72rem; color:rgba(63,78,79,.5); margin-top:2px; line-height:1.5; }
    .od-product-qty { font-size:.72rem; color:rgba(63,78,79,.45); margin-top:2px; }
    .od-product-price { font-size:.875rem; font-weight:800; color:#A27B5C; white-space:nowrap; }
    .od-total { margin:.75rem 1.5rem; border-radius:12px; background:rgba(162,123,92,.05); border:1px solid rgba(162,123,92,.12); padding:1rem; }
    .od-total-row { display:flex; justify-content:space-between; align-items:center; font-size:.875rem; color:#3F4E4F; margin-bottom:.5rem; }
    .od-total-row:last-child { margin-bottom:0; }
    .od-total-final { font-size:1.1rem; font-weight:800; color:#2C3639; border-top:1px solid rgba(162,123,92,.12); padding-top:.6rem; margin-top:.5rem; }
    .od-total-final span:last-child { color:#A27B5C; }
    .od-timeline { padding:0 1.5rem .5rem; }
    .od-step { display:flex; align-items:center; gap:.75rem; padding:.5rem 0; }
    .od-step-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; background:rgba(162,123,92,.2); border:2px solid rgba(162,123,92,.2); }
    .od-step-dot.done { background:#A27B5C; border-color:#A27B5C; }
    .od-step-dot.current { background:#fff; border-color:#A27B5C; box-shadow:0 0 0 3px rgba(162,123,92,.2); }
    .od-step-line { width:1px; height:18px; background:rgba(162,123,92,.15); margin-left:4px; }
    .od-step-label { font-size:.8rem; color:rgba(63,78,79,.5); }
    .od-step-label.done { color:#2C3639; font-weight:600; }
    .od-step-label.current { color:#A27B5C; font-weight:700; }
    .od-cancel-btn { margin:.75rem 1.5rem 0; display:flex; align-items:center; justify-content:center; gap:.5rem; width:calc(100% - 3rem); padding:.75rem; border-radius:12px; border:1.5px solid rgba(239,68,68,.3); background:rgba(239,68,68,.05); color:#b91c1c; font-family:'Work Sans',sans-serif; font-size:.875rem; font-weight:700; cursor:pointer; transition:background .15s; }
    .od-cancel-btn:hover { background:rgba(239,68,68,.1); border-color:rgba(239,68,68,.5); }
    .od-bottom { height:28px; }

    /* Cancel confirm */
    .cc-overlay { position:fixed; inset:0; z-index:10000; background:rgba(28,22,16,.45); backdrop-filter:blur(3px); display:flex; align-items:center; justify-content:center; opacity:0; pointer-events:none; transition:opacity .2s; }
    .cc-overlay.open { opacity:1; pointer-events:all; }
    .cc-box { background:#fff; border-radius:18px; padding:1.75rem 2rem; max-width:380px; width:90%; box-shadow:0 20px 60px rgba(44,54,57,.22); transform:scale(.94) translateY(8px); transition:transform .25s cubic-bezier(.34,1.56,.64,1); }
    .cc-overlay.open .cc-box { transform:scale(1) translateY(0); }
</style>

<section class="min-h-screen pt-28 pb-20" style="background:#F7F7F6;">
    <div class="max-w-3xl mx-auto px-4">

        <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
            <div>
                <p class="text-sm tracking-[0.2em] uppercase mb-1" style="color:#A27B5C;">Tài Khoản</p>
                <h1 style="font-family:'Playfair Display',serif;font-size:1.9rem;font-weight:700;color:#2C3639;">Lịch Sử Đặt Hàng</h1>
            </div>
            <a asp-controller="Menu" asp-action="Index"
               class="flex items-center gap-2 px-5 py-2.5 rounded-full text-white text-sm font-semibold hover:opacity-85"
               style="background:#A27B5C;">
                <span class="material-symbols-outlined" style="font-size:18px;">add</span>Đặt Thêm
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="mb-5 px-4 py-3 rounded-xl flex items-center gap-3 text-sm font-semibold"
                 style="background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.25);color:#065f46;">
                <span class="material-symbols-outlined" style="font-size:18px;color:#10b981;">check_circle</span>
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="mb-5 px-4 py-3 rounded-xl flex items-center gap-3 text-sm font-semibold"
                 style="background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.2);color:#b91c1c;">
                <span class="material-symbols-outlined" style="font-size:18px;">error</span>
                @TempData["Error"]
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-24 bg-white rounded-2xl" style="border:1px solid rgba(162,123,92,.12);">
                <span class="material-symbols-outlined" style="font-size:64px;color:rgba(162,123,92,.3);">receipt_long</span>
                <h2 style="font-family:'Playfair Display',serif;font-size:1.25rem;font-weight:700;color:#2C3639;margin:1rem 0 .75rem;">Chưa có đơn hàng nào</h2>
                <p class="text-sm mb-8" style="color:rgba(63,78,79,.55);">Hãy thêm vào giỏ và đặt món yêu thích.</p>
                <a asp-controller="Menu" asp-action="Index"
                   class="inline-block px-8 py-3 rounded-full text-white font-semibold hover:opacity-85"
                   style="background:#A27B5C;">Xem Thực Đơn</a>
            </div>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var order in Model)
                {
                    var firstItem = order.OrderDetails?.FirstOrDefault();
                    var itemCount = order.OrderDetails?.Count ?? 0;
                    var firstName = firstItem?.Product?.Name ?? "Sản phẩm";
                    var subText = itemCount > 1
                        ? $"{firstName} +{itemCount - 1} món khác"
                        : firstName + (firstItem != null ? $" ×{firstItem.Quantity}" : "");

                    <div class="oh-row" onclick="openOrderDetail(@order.Id)">
                        <div class="oh-icon">
                            <span class="material-symbols-outlined">@OStatusIcon(order.Status)</span>
                        </div>
                        <div class="oh-info">
                            <div class="oh-title">Đơn #@order.Id</div>
                            <div class="oh-sub">@subText</div>
                        </div>
                        <div style="flex-shrink:0;">
                            <span class="inline-block px-2.5 py-1 rounded-full text-xs font-bold"
                                  style="background:@OStatusBg(order.Status);color:@OStatusClr(order.Status);">
                                @OStatusLabel(order.Status)
                            </span>
                        </div>
                        <div class="oh-right">
                            <div class="oh-amount">@order.TotalAmount.ToString("N0")đ</div>
                            <div class="oh-date">@order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy")</div>
                        </div>
                        <span class="material-symbols-outlined oh-arrow">chevron_right</span>
                    </div>
                }
            </div>
            <script id="oh-data" type="application/json">@Html.Raw(ordersJson)</script>
        }

        <div class="mt-8 text-center">
            <a asp-controller="Account" asp-action="UserAccount"
               class="text-sm font-semibold hover:opacity-70" style="color:#A27B5C;">
                ← Quay lại Cài Đặt Tài Khoản
            </a>
        </div>
    </div>
</section>

@* ── Order Detail Drawer ── *@
<div class="od-overlay" id="odOverlay" onclick="if(event.target===this)closeOrderDetail()">
    <div class="od-drawer" id="odDrawer">
        <div class="od-handle"></div>
        <div class="od-header">
            <div>
                <div class="od-order-num" id="odOrderNum">Đơn #—</div>
                <div id="odOrderDate" style="font-size:.78rem;color:rgba(63,78,79,.45);"></div>
            </div>
            <button class="od-close" onclick="closeOrderDetail()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <div class="od-status-banner" id="odStatusBanner">
            <span class="material-symbols-outlined" id="odStatusIcon">hourglass_empty</span>
            <span id="odStatusLabel">—</span>
        </div>

        <div class="od-section-title">Thông Tin Đơn Hàng</div>
        <div class="od-info-grid">
            <div class="od-info-item">
                <span class="od-info-label">Người đặt</span>
                <span class="od-info-val" id="odCustomerName">—</span>
            </div>
            <div class="od-info-item">
                <span class="od-info-label">Số điện thoại</span>
                <span class="od-info-val" id="odCustomerPhone">—</span>
            </div>
            <div class="od-info-item">
                <span class="od-info-label">Địa chỉ giao hàng</span>
                <span class="od-info-val" id="odShipping">—</span>
            </div>
            <div class="od-info-item">
                <span class="od-info-label">Phương thức</span>
                <span class="od-info-val" id="odPayment">—</span>
            </div>
            <div class="od-info-item" id="odNoteWrap" style="grid-column:1/-1;display:none;">
                <span class="od-info-label">Ghi chú</span>
                <span class="od-info-val" id="odNote">—</span>
            </div>
        </div>

        <div class="od-section-title">Sản Phẩm</div>
        <div class="od-product-list" id="odProductList"></div>

        <div class="od-total">
            <div class="od-total-row"><span>Tạm tính</span><span id="odSubtotal">—</span></div>
            <div class="od-total-row"><span>Phí giao hàng</span><span style="color:#059669;font-weight:600;">Miễn phí</span></div>
            <div class="od-total-row od-total-final"><span>Tổng cộng</span><span id="odTotal">—</span></div>
        </div>

        <div class="od-section-title">Trạng Thái Đơn Hàng</div>
        <div class="od-timeline" id="odTimeline"></div>

        <div id="odCancelWrap" style="display:none;">
            <button class="od-cancel-btn" onclick="askCancelOrder()">
                <span class="material-symbols-outlined">cancel</span>
                Hủy Đơn Hàng
            </button>
            <p style="text-align:center;font-size:.7rem;color:rgba(63,78,79,.4);margin:.4rem 1.5rem 0;">
                Chỉ có thể hủy khi đơn đang "Chờ xác nhận"
            </p>
        </div>

        <div class="od-bottom"></div>
    </div>
</div>

@* ── Cancel Confirm ── *@
<div class="cc-overlay" id="cancelOverlay">
    <div class="cc-box">
        <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1rem;">
            <div style="width:44px;height:44px;border-radius:50%;background:rgba(239,68,68,.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-symbols-outlined" style="color:#dc2626;font-size:22px;">cancel</span>
            </div>
            <div>
                <div style="font-size:1rem;font-weight:800;color:#2C3639;">Xác nhận hủy đơn?</div>
                <div id="cancelOrderLabel" style="font-size:.78rem;color:rgba(63,78,79,.5);margin-top:2px;"></div>
            </div>
        </div>
        <p style="font-size:.875rem;color:#3F4E4F;line-height:1.7;margin-bottom:1.5rem;">
            Đơn hàng sẽ không thể khôi phục sau khi hủy. Bạn có chắc chắn không?
        </p>
        <div style="display:flex;gap:.75rem;">
            <button onclick="document.getElementById('cancelOverlay').classList.remove('open')"
                    style="flex:1;padding:.65rem;border:1.5px solid rgba(162,123,92,.25);border-radius:10px;background:transparent;color:#3F4E4F;font-family:'Work Sans',sans-serif;font-size:.875rem;font-weight:600;cursor:pointer;">
                Không, giữ lại
            </button>
            <form asp-controller="Cart" asp-action="CancelOrder" method="post" style="flex:1;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" id="cancelOrderId" value="" />
                <button type="submit"
                        style="width:100%;padding:.65rem;border:none;border-radius:10px;background:#dc2626;color:#fff;font-family:'Work Sans',sans-serif;font-size:.875rem;font-weight:700;cursor:pointer;">
                    Hủy đơn hàng
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
var OH_ORDERS = [];
var _activeId = null;

(function(){
    var el = document.getElementById('oh-data');
    if (el) { try { OH_ORDERS = JSON.parse(el.textContent); } catch(e){} }
})();

var STEPS = [
    {val:0,label:'Chờ xác nhận'},{val:1,label:'Đã xác nhận'},
    {val:2,label:'Đang pha chế'},{val:3,label:'Sẵn sàng'},{val:4,label:'Hoàn thành'}
];

function vn(n){ return Number(n).toLocaleString('vi-VN')+'đ'; }
function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function openOrderDetail(id){
    var o = OH_ORDERS.find(function(x){return x.id===id;});
    if(!o) return;
    _activeId = id;

    document.getElementById('odOrderNum').textContent = 'Đơn #'+o.id;
    document.getElementById('odOrderDate').textContent = o.date;

    var b = document.getElementById('odStatusBanner');
    b.style.background = o.statusBg; b.style.color = o.statusClr;
    document.getElementById('odStatusIcon').textContent = o.statusIcon;
    document.getElementById('odStatusLabel').textContent = o.statusLabel;

    document.getElementById('odCustomerName').textContent  = o.customerName  || '—';
    document.getElementById('odCustomerPhone').textContent = o.customerPhone || '—';
    document.getElementById('odShipping').textContent = o.shipping || 'Chưa có địa chỉ';
    document.getElementById('odPayment').textContent = o.payment;
    var nw = document.getElementById('odNoteWrap');
    if(o.note){ document.getElementById('odNote').textContent=o.note; nw.style.display=''; }
    else { nw.style.display='none'; }

    document.getElementById('odProductList').innerHTML = (o.items||[]).map(function(item){
        var imgH = item.img
            ? '<img class="od-product-img" src="'+esc(item.img)+'" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'"/>'
              +'<div class="od-product-img-ph" style="display:none;"><span class="material-symbols-outlined" style="font-size:20px;">coffee</span></div>'
            : '<div class="od-product-img-ph"><span class="material-symbols-outlined" style="font-size:20px;">coffee</span></div>';
        var noteH = item.itemNote ? '<div class="od-product-note">'+esc(item.itemNote)+'</div>' : '';
        return '<div class="od-product-row">'+imgH
            +'<div class="od-product-info">'
            +'<div class="od-product-name">'+esc(item.name)+'</div>'
            +'<div class="od-product-qty">Số lượng: '+item.qty+'</div>'+noteH
            +'</div>'
            +'<div class="od-product-price">'+vn(item.price*item.qty)+'</div>'
            +'</div>';
    }).join('');

    document.getElementById('odSubtotal').textContent = vn(o.total);
    document.getElementById('odTotal').textContent = vn(o.total);

    var tl = document.getElementById('odTimeline');
    if(o.status===5){
        tl.innerHTML='<div class="od-step"><div class="od-step-dot done"></div><div class="od-step-label done">Đã đặt hàng</div></div>'
            +'<div class="od-step-line"></div>'
            +'<div class="od-step"><div class="od-step-dot" style="background:#ef4444;border-color:#ef4444;"></div>'
            +'<div class="od-step-label current" style="color:#b91c1c;">Đơn hàng đã hủy</div></div>';
    } else {
        tl.innerHTML = STEPS.map(function(s,i){
            var d=o.status>s.val, c=o.status===s.val;
            return '<div class="od-step"><div class="od-step-dot '+(d?'done':c?'current':'')+'"></div>'
                +'<div class="od-step-label '+(d?'done':c?'current':'')+'">'+ s.label+'</div></div>'
                +(i<STEPS.length-1?'<div class="od-step-line" style="margin-left:4px;"></div>':'');
        }).join('');
    }

    document.getElementById('odCancelWrap').style.display = o.canCancel ? '' : 'none';
    document.getElementById('odOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
}

function closeOrderDetail(){
    document.getElementById('odOverlay').classList.remove('open');
    document.body.style.overflow = '';
}

function askCancelOrder(){
    var o = OH_ORDERS.find(function(x){return x.id===_activeId;});
    if(!o) return;
    document.getElementById('cancelOrderLabel').textContent = 'Đơn #'+o.id+' · '+vn(o.total);
    document.getElementById('cancelOrderId').value = o.id;
    document.getElementById('cancelOverlay').classList.add('open');
}

// Swipe down
(function(){
    var el=document.getElementById('odDrawer'), sy=0;
    el.addEventListener('touchstart',function(e){sy=e.touches[0].clientY;},{passive:true});
    el.addEventListener('touchend',function(e){if(e.changedTouches[0].clientY-sy>80)closeOrderDetail();},{passive:true});
})();

document.addEventListener('keydown',function(e){
    if(e.key!=='Escape') return;
    if(document.getElementById('cancelOverlay').classList.contains('open'))
        document.getElementById('cancelOverlay').classList.remove('open');
    else closeOrderDetail();
});
</script>
}
