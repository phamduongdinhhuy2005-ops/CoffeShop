.rv-modal{background:#fff;border-radius:24px;width:100%;max-width:500px;max-height:90vh;overflow-y:auto;box-shadow:0 24px 64px rgba(44,54,57,.22);transform:scale(.94) translateY(12px);transition:transform .3s cubic-bezier(.34,1.56,.64,1)}
