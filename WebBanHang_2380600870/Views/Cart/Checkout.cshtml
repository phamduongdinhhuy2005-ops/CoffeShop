@section Scripts {
<script>
(function(){
    var s=document.createElement('style');
    s.textContent='@@keyframes shimmerAnim{0%{background-position:200% 0}100%{background-position:-200% 0}}@@keyframes spinAnim{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}';
    document.head.appendChild(s);
}());

var SHOP_CONFIG={
    accountNo:   '1234567890',
    accountName: 'GOC LANG CAFE',
    template:    'compact2',
    QR_TIMEOUT:  300,
    POLL_INTERVAL:5000
};

var BANKS=[
    {id:'MB',   bin:'970422', name:'MB Bank',       short:'MB',   logo:'https://api.vietqr.io/img/MB.png'},
    {id:'VCB',  bin:'970436', name:'Vietcombank',    short:'VCB',  logo:'https://api.vietqr.io/img/VCB.png'},
    {id:'TCB',  bin:'970407', name:'Techcombank',    short:'TCB',  logo:'https://api.vietqr.io/img/TCB.png'},
    {id:'CTG',  bin:'970415', name:'VietinBank',     short:'VTB',  logo:'https://inkythuatso.com/uploads/images/2021/09/logo-vietinbank-inkythuatso-10-13-22-06.jpg'},
    {id:'BIDV', bin:'970418', name:'BIDV',            short:'BIDV', logo:'https://api.vietqr.io/img/BIDV.png'},
    {id:'ACB',  bin:'970416', name:'ACB',             short:'ACB',  logo:'https://api.vietqr.io/img/ACB.png'},
    {id:'TPB',  bin:'970423', name:'TPBank',          short:'TPB',  logo:'https://api.vietqr.io/img/TPB.png'},
    {id:'STB',  bin:'970403', name:'Sacombank',       short:'STB',  logo:'https://api.vietqr.io/img/STB.png'},
    {id:'VPB',  bin:'970432', name:'VPBank',          short:'VPB',  logo:'https://api.vietqr.io/img/VPB.png'},
    {id:'HDB',  bin:'970437', name:'HDBank',          short:'HDB',  logo:'https://api.vietqr.io/img/HDB.png'},
    {id:'OCB',  bin:'970448', name:'OCB',             short:'OCB',  logo:'https://api.vietqr.io/img/OCB.png'},
    {id:'SHB',  bin:'970443', name:'SHB',             short:'SHB',  logo:'https://api.vietqr.io/img/SHB.png'},
    {id:'MSB',  bin:'970426', name:'MSB',             short:'MSB',  logo:'https://api.vietqr.io/img/MSB.png'},
    {id:'VIB',  bin:'970441', name:'VIB',             short:'VIB',  logo:'https://api.vietqr.io/img/VIB.png'},
    {id:'AGRI', bin:'970405', name:'Agribank',        short:'AGRI', logo:'https://upload.wikimedia.org/wikipedia/vi/thumb/3/3d/Argibank_logo.svg/3840px-Argibank_logo.svg.png'},
    {id:'SEAB', bin:'970440', name:'SeABank',         short:'SEAB', logo:'https://api.vietqr.io/img/SEAB.png'},
    {id:'NAB',  bin:'970428', name:'Nam A Bank',      short:'NAB',  logo:'https://api.vietqr.io/img/NAB.png'},
    {id:'EIB',  bin:'970431', name:'Eximbank',        short:'EIB',  logo:'https://api.vietqr.io/img/EIB.png'},
    {id:'KLB',  bin:'970452', name:'Kiên Long Bank', short:'KLB',  logo:'https://api.vietqr.io/img/KLB.png'},
    {id:'BAB',  bin:'970409', name:'Bắc Á Bank',     short:'BAB',  logo:'https://api.vietqr.io/img/BAB.png'},
    {id:'NCB',  bin:'970419', name:'NCB',             short:'NCB',  logo:'https://api.vietqr.io/img/NCB.png'},
    {id:'CAKE', bin:'546034', name:'CAKE by VPBank', short:'CAKE', logo:'https://api.vietqr.io/img/CAKE.png'},
];

var selectedBank=null, qrCountTimer=null, qrPollTimer=null;
var qrSecondsLeft=SHOP_CONFIG.QR_TIMEOUT, isPaid=false, _pollCount=0;
var currentOrderContent='', autoCloseTimer=null;

/* ══ REVIEW ══ */
function openReviewModal(){
    var n=document.getElementById('fieldFullName').value.trim(),
        p=document.getElementById('fieldPhone').value.trim(),
        a=document.getElementById('fieldAddress').value.trim();
    if(!n||!p||!a){document.getElementById('checkoutForm').reportValidity();return;}
    document.getElementById('rvName').textContent=n;
    document.getElementById('rvPhone').textContent=p;
    document.getElementById('rvAddress').textContent=a;
    var note=document.getElementById('fieldNote').value.trim();
    document.getElementById('rvNoteRow').style.display=note?'':'none';
    if(note)document.getElementById('rvNote').textContent=note;
    var isT=document.querySelector('input[name="PaymentMethod"]:checked').value==='Transfer';
    document.getElementById('rvPayment').textContent=isT?'Chuyển khoản VietQR':'Tiền mặt (COD)';
    document.getElementById('rvConfirmBtn').innerHTML=isT
        ?'<span class="material-symbols-outlined" style="font-size:17px;">qr_code_2</span> Chọn ngân hàng & Tạo QR'
        :'<span class="material-symbols-outlined" style="font-size:17px;">check_circle</span> Xác Nhận Đặt Hàng';
    document.getElementById('rvOverlay').classList.add('open');
    document.body.style.overflow='hidden';
}
function closeReviewModal(){document.getElementById('rvOverlay').classList.remove('open');document.body.style.overflow='';}
function handleConfirm(){
    var isT=document.querySelector('input[name="PaymentMethod"]:checked').value==='Transfer';
    closeReviewModal();
    if(isT)openBankPicker();
    else{document.body.style.overflow='';document.getElementById('checkoutForm').submit();}
}

/* ══ BANK PICKER ══ */
var _bankPage=0, _bankPageSize=9, _bankFiltered=BANKS.slice();

function openBankPicker(){
    _bankFiltered=BANKS.slice();
    _bankPage=0;
    document.getElementById('bankSearch').value='';
    renderBankPage();
    document.getElementById('vqOverlay').classList.add('open');
    document.body.style.overflow='hidden';
}
function closeVqModal(){document.getElementById('vqOverlay').classList.remove('open');document.body.style.overflow='';}

function renderBankPage(){
    var grid=document.getElementById('bankGrid');
    var pager=document.getElementById('bankPager');
    var total=_bankFiltered.length;
    var pages=Math.max(1,Math.ceil(total/_bankPageSize));
    if(_bankPage>=pages)_bankPage=pages-1;
    var start=_bankPage*_bankPageSize;
    var slice=_bankFiltered.slice(start,start+_bankPageSize);
    grid.innerHTML=slice.map(function(b){
        var sel=selectedBank&&selectedBank.id===b.id;
        var uid='bl_'+b.id;
        var logoHtml='<div class="vq-bank-logo-wrap">'
            +'<img src="'+b.logo+'" alt="'+b.short+'" '
            +'onerror="this.style.display=\'none\';document.getElementById(\''+uid+'\').style.display=\'flex\';" />'
            +'<div id="'+uid+'" class="vq-bank-logo-fallback" style="display:none;">'+b.short+'</div>'
            +'</div>';
        return '<button type="button" class="vq-bank-btn'+(sel?' selected':'')+'"'
            +' data-id="'+b.id+'" onclick="selectBank(\''+b.id+'\')">'
            +logoHtml
            +'<div><div class="vq-bank-name">'+b.name+'</div>'
            +'<div class="vq-bank-shortname">'+b.short+'</div></div>'
            +'</button>';
    }).join('');
    if(pages<=1){pager.style.display='none';return;}
    pager.style.display='flex';
    var html='<button class="vq-arrow" onclick="goBankPage('+(_bankPage-1)+')"'
        +(_bankPage===0?' disabled':'')+'>'
        +'<span class="material-symbols-outlined" style="font-size:16px;">chevron_left</span></button>';
    for(var i=0;i<pages;i++){
        html+='<button class="vq-dot'+(i===_bankPage?' active':'')+'\" onclick="goBankPage('+i+')" title="Trang '+(i+1)+'"></button>';
    }
    html+='<span class="vq-page-label">'+(_bankPage+1)+'/'+pages+'</span>';
    html+='<button class="vq-arrow" onclick="goBankPage('+(_bankPage+1)+')"'
        +(_bankPage>=pages-1?' disabled':'')+'>'
        +'<span class="material-symbols-outlined" style="font-size:16px;">chevron_right</span></button>';
    pager.innerHTML=html;
}

function goBankPage(page){
    var pages=Math.ceil(_bankFiltered.length/_bankPageSize);
    if(page<0||page>=pages)return;
    _bankPage=page;
    renderBankPage();
}

function filterBanks(){
    var q=document.getElementById('bankSearch').value.toLowerCase();
    _bankFiltered=q?BANKS.filter(function(b){return b.name.toLowerCase().includes(q)||b.short.toLowerCase().includes(q);}):BANKS.slice();
    _bankPage=0;
    renderBankPage();
}
function selectBank(id){
    selectedBank=BANKS.find(function(b){return b.id===id;})||null;
    document.querySelectorAll('.vq-bank-btn').forEach(function(btn){btn.classList.toggle('selected',btn.dataset.id===id);});
    document.getElementById('vqSelectBtn').disabled=!selectedBank;
}
function confirmBankSelection(){if(!selectedBank)return;closeVqModal();openQrModal();}

/* ══ QR MODAL ══ */
function openQrModal(){
    var totalNum=@((long)Model.Cart.TotalAmount);
    currentOrderContent='GOCLANG'+Math.floor(100000+Math.random()*900000);
    isPaid=false; _pollCount=0;
    document.getElementById('qrTopAmount').textContent=totalNum.toLocaleString('vi-VN')+'đ';
    var bankBin=selectedBank.bin;
    var isUnsupported=!bankBin||bankBin==='';
    document.getElementById('qrUnsupported').style.display=isUnsupported?'flex':'none';
    document.getElementById('qrNormalContent').style.display=isUnsupported?'none':'block';
    document.getElementById('qrBtnDone').style.display='none';
    document.getElementById('qrBtnCancel').style.display='';
    document.getElementById('qrBtnCancel').textContent=isUnsupported?'Đóng':'Hủy';
    document.getElementById('qrAutoCloseBar').classList.remove('show');
    if(!isUnsupported){
        var chipLogo=document.getElementById('qrBankChipLogo');
        chipLogo.src=selectedBank.logo; chipLogo.style.display='';
        document.getElementById('qrBankChipName').textContent=selectedBank.name;
        document.getElementById('qrAccName').textContent=SHOP_CONFIG.accountName;
        document.getElementById('qrAccNo').textContent=SHOP_CONFIG.accountNo;
        document.getElementById('qrContentText').textContent=currentOrderContent;
        document.getElementById('qrCopyBtn').dataset.content=currentOrderContent;
        document.getElementById('qrAmountVal').textContent=totalNum.toLocaleString('vi-VN')+'đ';
        var qrUrl='https://img.vietqr.io/image/'
            +bankBin+'-'+SHOP_CONFIG.accountNo+'-'+SHOP_CONFIG.template+'.png'
            +'?amount='+encodeURIComponent(totalNum)
            +'&addInfo='+encodeURIComponent(currentOrderContent)
            +'&accountName='+encodeURIComponent(SHOP_CONFIG.accountName);
        var sk=document.getElementById('qrSkeleton'), img=document.getElementById('qrImage');
        sk.style.display='block'; img.style.display='none'; img.src='';
        img.onload=function(){ sk.style.display='none'; img.style.display='block'; };
        img.onerror=function(){
            sk.style.display='none';
            img.style.display='block';
            img.src='https://api.qrserver.com/v1/create-qr-code/?size=265x265&data='+encodeURIComponent(
                'https://vietqr.io/'+bankBin+'/'+SHOP_CONFIG.accountNo+'/'+totalNum+'/'+currentOrderContent
            );
        };
        setTimeout(function(){ if(sk.style.display!=='none'){ img.onerror(); } }, 4000);
        img.src=qrUrl;
        setQrStatus('pending');
        qrSecondsLeft=SHOP_CONFIG.QR_TIMEOUT;
        updateCountdownUI(qrSecondsLeft);
        clearInterval(qrCountTimer); clearInterval(qrPollTimer); clearTimeout(autoCloseTimer);
        qrCountTimer=setInterval(function(){
            qrSecondsLeft--;
            updateCountdownUI(qrSecondsLeft);
            if(qrSecondsLeft<=0){clearInterval(qrCountTimer);clearInterval(qrPollTimer);if(!isPaid)setQrStatus('expired');}
        },1000);
        startPolling();
    }
    document.getElementById('qrModalBox').scrollTop=0;
    document.getElementById('qrOverlay').classList.add('open');
    document.body.style.overflow='hidden';
}

function closeQrModal(){
    clearInterval(qrCountTimer); clearInterval(qrPollTimer); clearTimeout(autoCloseTimer);
    document.getElementById('qrOverlay').classList.remove('open');
    document.body.style.overflow='';
}

function updateCountdownUI(sec){
    if(sec<0)sec=0;
    var m=Math.floor(sec/60),s=sec%60;
    document.getElementById('qrCountdownNum').textContent=m+':'+(s<10?'0':'')+s;
    var total=SHOP_CONFIG.QR_TIMEOUT, circum=150.8;
    var prog=document.getElementById('qrCountdownCircle');
    prog.style.strokeDashoffset=circum*(1-sec/total);
    var color=sec>total*.5?'#A27B5C':sec>total*.2?'#f59e0b':'#ef4444';
    prog.style.stroke=color;
    document.getElementById('qrCountdownNum').style.color=color;
}

function setQrStatus(state){
    var badge=document.getElementById('qrStatusBadge'), sub=document.getElementById('qrStatusSub');
    badge.className='qr-status-badge '+state;
    if(state==='pending'){
        badge.innerHTML='<span class="material-symbols-outlined spin-anim" style="font-size:13px;">sync</span> Chờ thanh toán';
        sub.textContent='Tự động xác nhận sau khi chuyển khoản thành công';
    }else if(state==='success'){
        badge.innerHTML='<span class="material-symbols-outlined" style="font-size:13px;">check_circle</span> Đã thanh toán!';
        sub.textContent='Tự động đóng sau 5 giây...';
        document.getElementById('qrBtnCancel').style.display='none';
        document.getElementById('qrBtnDone').style.display='flex';
        clearInterval(qrCountTimer); clearInterval(qrPollTimer);
        isPaid=true;
        startAutoClose();
    }else if(state==='expired'){
        badge.innerHTML='<span class="material-symbols-outlined" style="font-size:13px;">timer_off</span> Hết thời gian';
        sub.textContent='QR đã hết hạn. Vui lòng thử lại.';
        document.getElementById('qrBtnCancel').textContent='Đóng';
    }
}

function startAutoClose(){
    var bar=document.getElementById('qrAutoCloseBar'),prog=document.getElementById('qrAutoCloseProgress');
    bar.classList.add('show');
    prog.style.transition='none';prog.style.width='100%';
    requestAnimationFrame(function(){requestAnimationFrame(function(){prog.style.transition='width 5s linear';prog.style.width='0%';});});
    autoCloseTimer=setTimeout(completeOrder,5000);
}

function startPolling(){
    qrPollTimer=setInterval(function(){
        if(isPaid||qrSecondsLeft<=0){clearInterval(qrPollTimer);return;}
        _pollCount++;
        checkPaymentStatus();
    },SHOP_CONFIG.POLL_INTERVAL);
}
function checkPaymentStatus(){
    /* == DEMO: xóa khi có API thật == */
    if(_pollCount>=3){setQrStatus('success');return;}
}

function completeOrder(){clearTimeout(autoCloseTimer);closeQrModal();document.body.style.overflow='';document.getElementById('checkoutForm').submit();}

function copyContent(){
    var txt=document.getElementById('qrCopyBtn').dataset.content;
    if(navigator.clipboard){navigator.clipboard.writeText(txt).then(showCopyToast);}
    else{var el=document.createElement('textarea');el.value=txt;document.body.appendChild(el);el.select();document.execCommand('copy');el.remove();showCopyToast();}
}
function showCopyToast(){
    var t=document.getElementById('copyToast');
    t.style.opacity='1';t.style.transform='translateX(-50%) translateY(0)';
    setTimeout(function(){t.style.opacity='0';t.style.transform='translateX(-50%) translateY(20px)';},2000);
}
function updatePMStyle(){
    var cod=document.querySelector('input[value="COD"]').checked;
    document.getElementById('pmCOD').style.borderColor=cod?'#A27B5C':'#DCD7C9';
    document.getElementById('pmCOD').style.backgroundColor=cod?'#FDF9F5':'transparent';
    document.getElementById('pmTransfer').style.borderColor=!cod?'#A27B5C':'#DCD7C9';
    document.getElementById('pmTransfer').style.backgroundColor=!cod?'#FDF9F5':'transparent';
}
document.addEventListener('keydown',function(e){if(e.key==='Escape'){closeReviewModal();closeVqModal();}});
</script>
}
