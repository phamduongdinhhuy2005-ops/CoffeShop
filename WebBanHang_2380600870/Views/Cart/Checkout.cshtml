.vq-modal-header{background:linear-gradient(135deg,#2C3639,#3F4E4F);padding:1.25rem 1.75rem;border-radius:24px 24px 0 0;flex-shrink:0;display:flex;justify-content:space-between;align-items:flex-start}
.vq-modal-header-title{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:800;color:#F2EFE9;display:flex;align-items:center;gap:.5rem}
.vq-modal-header-sub{font-size:.75rem;color:rgba(220,215,201,.6);margin-top:.2rem}
.vq-modal-body{flex:1;overflow:hidden;padding:1.25rem 1.75rem 0;display:flex;flex-direction:column;min-height:0;}
.vq-modal-body::-webkit-scrollbar{display:none}.vq-search-wrap{position:relative;margin-bottom:1rem;flex-shrink:0;}
.vq-search-wrap .material-symbols-outlined{position:absolute;left:.875rem;top:50%;transform:translateY(-50%);font-size:17px;color:rgba(162,123,92,.6);pointer-events:none}
.vq-search-wrap input{width:100%;padding:.7rem 1rem .7rem 2.6rem;border:1.5px solid rgba(162,123,92,.25);border-radius:12px;font-family:'Work Sans',sans-serif;font-size:.875rem;color:#2C3639;outline:none;background:#FAFAF9;box-sizing:border-box;transition:border-color .15s}
.vq-search-wrap input:focus{border-color:#A27B5C;background:#fff}
.vq-bank-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.6rem;}
.vq-bank-btn{display:flex;align-items:center;gap:.6rem;padding:.7rem .875rem;border:1.5px solid rgba(162,123,92,.15);border-radius:12px;background:#FAFAF9;cursor:pointer;transition:all .15s;text-align:left;width:100%}
.vq-bank-btn:hover{border-color:#A27B5C;background:rgba(162,123,92,.05)}
.vq-bank-btn.selected{border-color:#A27B5C;background:rgba(162,123,92,.1);box-shadow:0 0 0 3px rgba(162,123,92,.12)}
.vq-bank-logo-wrap{width:38px;height:38px;border-radius:8px;background:#fff;border:1px solid rgba(0,0,0,.07);padding:3px;flex-shrink:0;display:flex;align-items:center;justify-content:center;overflow:hidden}
.vq-bank-logo-wrap img{width:100%;height:100%;object-fit:contain}
.vq-bank-logo-fallback{font-size:.62rem;font-weight:800;color:#A27B5C;text-align:center;line-height:1.1;word-break:break-all}
.vq-bank-name{font-size:.78rem;font-weight:700;color:#2C3639;line-height:1.25}
.vq-bank-shortname{font-size:.62rem;color:rgba(63,78,79,.5);margin-top:1px}
.vq-pager{display:flex;align-items:center;justify-content:center;gap:.375rem;padding:.875rem 0 .5rem;flex-shrink:0;}
.vq-dot{width:6px;height:6px;border-radius:50%;background:rgba(162,123,92,.25);cursor:pointer;transition:background .2s,transform .2s;border:none;padding:0;flex-shrink:0;}
.vq-dot.active{background:#A27B5C;transform:scale(1.3);}
.vq-arrow{width:28px;height:28px;border-radius:50%;border:1.5px solid rgba(162,123,92,.3);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#A27B5C;transition:background .15s,border-color .15s;font-size:16px;flex-shrink:0;}
.vq-arrow:hover:not(:disabled){background:rgba(162,123,92,.08);border-color:#A27B5C;}
.vq-arrow:disabled{opacity:.3;cursor:default;}
.vq-page-label{font-family:'Playfair Display',serif;font-style:italic;font-size:.78rem;color:rgba(162,123,92,.6);margin:0 .3rem;white-space:nowrap;}
.vq-modal-footer{padding:1rem 1.75rem 1.25rem;border-top:1px solid rgba(162,123,92,.1);flex-shrink:0}
.vq-btn-select{width:100%;padding:.8rem;border:none;border-radius:12px;background:#A27B5C;color:#fff;font-family:'Work Sans',sans-serif;font-size:.9rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.5rem;box-shadow:0 4px 14px rgba(162,123,92,.28)}
.vq-btn-select:hover{background:#8d6a4d}
.vq-btn-select:disabled{opacity:.4;cursor:not-allowed}

/* ══ QR MODAL ══ */
.qr-overlay{position:fixed;inset:0;z-index:10000;background:rgba(22,17,12,.78);backdrop-filter:blur(10px);display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;pointer-events:none;transition:opacity .3s}
.qr-overlay.open{opacity:1;pointer-events:all}
.qr-modal{background:#fff;border-radius:24px;width:100%;max-width:390px;max-height:92vh;overflow-y:auto;overflow-x:hidden;box-shadow:0 32px 80px rgba(44,54,57,.32);transform:scale(.9) translateY(24px);transition:transform .4s cubic-bezier(.34,1.56,.64,1);scrollbar-width:none}
.qr-modal::-webkit-scrollbar{display:none}
.qr-overlay.open .qr-modal{transform:scale(1) translateY(0)}
.qr-top-bar{position:sticky;top:0;z-index:2;padding:1.25rem 1.5rem 1rem;border-radius:24px 24px 0 0;text-align:center;overflow:hidden;position:relative;}
.qr-top-bar::before{content:'';position:absolute;inset:0;background-image:url('https://lh3.googleusercontent.com/aida-public/AB6AXuCPbbxfASi-rYqxHYCVtSGTQZ--TMdNj0FDJXsoBmVNsIrwIgCkDv76iaZtRyoSzvUU7ec7JZaEksl2kYREjaoay-G9FrYRwkszVe_Ey30DncbScTSARonXPv-ngaFaREZRO4F3fVb0UA2PWvnzQrsUPppz5XyGqLDfGEqwSrFSrVZlL5ox9Cl-10U2epsiMo819tJ9LIE6TLVxFhPg0YudTrnNV1qTPu5GDjny5_-oJA3qbLwu9X5Eg18Eb2939imxAWVNPu9DfREz');background-size:cover;background-position:center;border-radius:24px 24px 0 0;z-index:0;}
.qr-top-bar::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,rgba(22,18,14,.72) 0%,rgba(28,22,16,.82) 100%);z-index:1;}
.qr-top-bar>*{position:relative;z-index:2;}
.qr-top-badge{display:inline-flex;align-items:center;gap:.35rem;background:rgba(162,123,92,.28);border:1px solid rgba(162,123,92,.5);border-radius:99px;padding:.2rem .7rem;font-size:.62rem;font-weight:700;letter-spacing:.1em;color:#DCD7C9;text-transform:uppercase;margin-bottom:.6rem}
.qr-top-amount{font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:900;color:#A27B5C;line-height:1}
.qr-top-label{font-size:.7rem;color:rgba(220,215,201,.5);margin-top:.25rem;letter-spacing:.06em}
.qr-x-btn{position:absolute;top:1rem;right:1rem;z-index:10;width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.14);border:none;cursor:pointer;color:#DCD7C9;display:flex;align-items:center;justify-content:center;transition:background .15s}
.qr-x-btn:hover{background:rgba(255,255,255,.28)}
.qr-x-btn .material-symbols-outlined{font-size:17px}
.qr-img-section{padding:1.5rem 1.5rem .875rem;display:flex;flex-direction:column;align-items:center;gap:.75rem}
.qr-img-frame{width:265px;height:265px;border-radius:18px;overflow:hidden;border:3px solid rgba(162,123,92,.2);box-shadow:0 8px 32px rgba(44,54,57,.12),0 0 0 6px rgba(162,123,92,.05);background:#f5f0ea;display:flex;align-items:center;justify-content:center}
.qr-img-frame img{width:100%;height:100%;object-fit:contain;display:block}
.qr-skeleton-inner{width:100%;height:100%;background:linear-gradient(90deg,#f0ece6 25%,#e4ded6 50%,#f0ece6 75%);background-size:200% 100%}
.qr-bank-chip{display:inline-flex;align-items:center;gap:.5rem;background:rgba(162,123,92,.07);border:1px solid rgba(162,123,92,.18);border-radius:99px;padding:.35rem .875rem}
.qr-bank-chip-logo{width:24px;height:24px;border-radius:5px;object-fit:contain;background:#fff;border:1px solid rgba(0,0,0,.06)}
.qr-bank-chip span{font-size:.78rem;font-weight:700;color:#2C3639}
.qr-info-section{padding:0 1.25rem .875rem}
.qr-info-card{background:#FAFAF9;border:1px solid rgba(162,123,92,.14);border-radius:14px;overflow:hidden;margin-bottom:.75rem}
.qr-info-row{display:flex;justify-content:space-between;align-items:center;padding:.6rem 1rem;border-bottom:1px solid rgba(162,123,92,.08);gap:.5rem}
.qr-info-row:last-child{border-bottom:none}
.qr-info-lbl{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:rgba(63,78,79,.45);flex-shrink:0}
.qr-info-val{font-size:.85rem;font-weight:700;color:#2C3639;text-align:right;word-break:break-all;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.qr-info-val.accent{color:#A27B5C}
.qr-copy-btn{display:flex;align-items:center;gap:.35rem;cursor:pointer;color:#A27B5C;font-size:.85rem;font-weight:700;background:none;border:none;padding:0;font-family:'Work Sans',sans-serif;text-align:right;flex-shrink:1;min-width:0;max-width:200px;word-break:break-all}
.qr-copy-btn:hover{opacity:.75}
.qr-copy-btn .material-symbols-outlined{font-size:14px;flex-shrink:0}
.qr-status-row{display:flex;align-items:center;gap:1rem;background:#FAFAF9;border:1px solid rgba(162,123,92,.12);border-radius:14px;padding:.875rem 1.1rem}
.qr-countdown-ring{position:relative;width:56px;height:56px;flex-shrink:0}
.qr-countdown-ring svg{transform:rotate(-90deg)}
.qr-countdown-ring circle.track{fill:none;stroke:rgba(162,123,92,.15);stroke-width:4}
.qr-countdown-ring circle.prog{fill:none;stroke:#A27B5C;stroke-width:4;stroke-linecap:round;transition:stroke-dashoffset .9s linear}
.qr-countdown-num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:1rem;font-weight:800;color:#2C3639}
.qr-status-info{flex:1;min-width:0}
.qr-status-badge{display:inline-flex;align-items:center;gap:.35rem;padding:.28rem .75rem;border-radius:99px;font-size:.68rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-bottom:.3rem}
.qr-status-badge.pending{background:rgba(234,179,8,.12);color:#b45309;border:1px solid rgba(234,179,8,.28)}
.qr-status-badge.success{background:rgba(16,185,129,.12);color:#065f46;border:1px solid rgba(16,185,129,.28)}
.qr-status-badge.expired{background:rgba(239,68,68,.1);color:#b91c1c;border:1px solid rgba(239,68,68,.22)}
.qr-status-sub{font-size:.7rem;color:rgba(63,78,79,.45);line-height:1.5}
.qr-autoclose-bar{height:3px;background:rgba(162,123,92,.12);display:none}
.qr-autoclose-bar.show{display:block}
.qr-autoclose-progress{height:100%;background:linear-gradient(90deg,#059669,#34d399);width:100%;transition:width 5s linear}
.qr-footer{padding:.875rem 1.25rem 1.25rem;display:flex;gap:.75rem;position:sticky;bottom:0;background:#fff;border-top:1px solid rgba(162,123,92,.08)}
.qr-btn-cancel{flex:1;padding:.65rem;border:1.5px solid rgba(162,123,92,.22);border-radius:12px;background:transparent;color:#3F4E4F;font-family:'Work Sans',sans-serif;font-size:.82rem;font-weight:600;cursor:pointer}
.qr-btn-done{flex:2;padding:.65rem;border:none;border-radius:12px;background:#059669;color:#fff;font-family:'Work Sans',sans-serif;font-size:.82rem;font-weight:700;cursor:pointer;display:none;align-items:center;justify-content:center;gap:.4rem}
.qr-unsupported{margin:0 1.25rem .875rem;background:rgba(234,179,8,.07);border:1px solid rgba(234,179,8,.3);border-radius:14px;padding:1rem 1.1rem;display:flex;align-items:flex-start;gap:.75rem}
.qr-unsupported .material-symbols-outlined{font-size:20px;color:#d97706;flex-shrink:0;margin-top:1px}
.qr-unsupported-text{font-size:.8rem;color:#92400e;line-height:1.65}
.qr-unsupported-text strong{display:block;font-weight:800;margin-bottom:.15rem;font-size:.82rem}
.spin-anim{animation:spinAnim 1.5s linear infinite}
.shimmer-anim{animation:shimmerAnim 1.4s infinite}
</style>

    <!-- ══ HERO — cinematic (CSS-only, không cần ảnh ngoài) ══ -->
    <div style="
        position:relative;
        overflow:hidden;
        display:flex;
        align-items:center;
        justify-content:center;
        min-height:520px;
        background:#1C1916;
        width:100%;
    ">
        <!-- Layered gradient background -->
        <div style="
            position:absolute;inset:0;
            background:
                radial-gradient(ellipse 75% 65% at 15% 45%, rgba(162,123,92,.32) 0%, transparent 58%),
                radial-gradient(ellipse 55% 75% at 85% 25%, rgba(162,123,92,.18) 0%, transparent 55%),
                radial-gradient(ellipse 40% 50% at 50% 90%, rgba(63,78,79,.4) 0%, transparent 60%),
                linear-gradient(135deg, #1C1916 0%, #2C3639 40%, #3F4E4F 68%, #2C3639 100%);
