            opacity:.055;pointer-events:none;
            background-image:
                repeating-linear-gradient(0deg, rgba(162,123,92,1) 0, rgba(162,123,92,1) 1px, transparent 1px, transparent 52px),
                repeating-linear-gradient(90deg, rgba(162,123,92,1) 0, rgba(162,123,92,1) 1px, transparent 1px, transparent 52px);
        "></div>
        <!-- Grain texture -->
        <div style="
            position:absolute;inset:0;pointer-events:none;opacity:.55;
            background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.75%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22 opacity=%220.045%22/%3E%3C/svg%3E');
        "></div>
