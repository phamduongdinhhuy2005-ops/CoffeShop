.rv-total-label{font-size:.875rem;font-weight:600;color:#3F4E4F}
.rv-total-amount{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:800;color:#A27B5C}
.rv-footer{padding:1rem 1.75rem 1.5rem;display:flex;gap:.75rem;position:sticky;bottom:0;background:#fff;border-top:1px solid rgba(162,123,92,.1)}
.rv-btn-back{flex:1;padding:.7rem;border:1.5px solid rgba(162,123,92,.3);border-radius:12px;background:transparent;color:#3F4E4F;font-family:'Work Sans',sans-serif;font-size:.85rem;font-weight:600;cursor:pointer}
.rv-btn-confirm{flex:2;padding:.7rem;border:none;border-radius:12px;background:#A27B5C;color:#fff;font-family:'Work Sans',sans-serif;font-size:.85rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.5rem;box-shadow:0 4px 14px rgba(162,123,92,.3)}
.rv-btn-confirm:hover{background:#8d6a4d}

/* ══ BANK PICKER ══ */
.vq-overlay{position:fixed;inset:0;z-index:9500;background:rgba(28,22,16,.6);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;pointer-events:none;transition:opacity .25s}
