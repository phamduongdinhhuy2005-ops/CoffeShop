@* Views/Booking/MyBookings.cshtml *@
@* SOURCE: Lấy chính xác từ dump mới nhất *@
@* BUG FIX: File cũ có regex pattern trong Razor bị lỗi RZ1005. File này đã sửa. *@
@model IEnumerable<WebBanHang_2380600870.Models.Booking>
@{
    ViewData["Title"] = "Lịch Sử Đặt Chỗ | Góc Lặng";
    Layout = "_Layout";
}

<section class="min-h-screen pt-28 pb-20" style="background: #F7F7F6;">
    <div class="max-w-3xl mx-auto px-4">

        <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
            <div>
                <p class="text-sm tracking-[0.2em] uppercase mb-1" style="color: #A27B5C;">Tài Khoản</p>
                <h1 class="text-3xl font-bold" style="font-family: 'Playfair Display', serif; color: #2C3639;">Lịch Sử Đặt Chỗ</h1>
            </div>
            <a asp-controller="Booking" asp-action="Index"
                   class="flex items-center gap-2 px-5 py-2.5 rounded-full text-white text-sm font-semibold transition-opacity hover:opacity-85"
                   style="background: #A27B5C;">
                <span class="material-symbols-outlined" style="font-size: 18px;">add</span>
                Đặt Chỗ Mới
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="mb-6 px-5 py-4 rounded-xl flex items-center gap-3 text-sm font-medium"
                 style="background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.25); color: #065f46;">
                <span class="material-symbols-outlined" style="font-size: 20px; color: #10b981;">check_circle</span>
                @TempData["Success"]
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-24 bg-white rounded-2xl" style="border: 1px solid rgba(162,123,92,0.12);">
                <span class="material-symbols-outlined" style="font-size: 64px; color: rgba(162,123,92,0.3);">event_seat</span>
                <h2 class="text-xl font-bold mt-4 mb-3" style="font-family: 'Playfair Display', serif; color: #2C3639;">Chưa có lịch đặt chỗ nào</h2>
                <p class="text-sm mb-8" style="color: rgba(63,78,79,0.55);">Hãy đặt chỗ trước để có trải nghiệm tốt nhất tại Góc Lặng.</p>
                <a asp-controller="Booking" asp-action="Index"
                       class="inline-block px-8 py-3 rounded-full text-white font-semibold transition-opacity hover:opacity-85"
                       style="background: #A27B5C;">
                    Đặt Chỗ Ngay
                </a>
            </div>
        }
        else
        {
            <div class="space-y-4">
                @foreach (var booking in Model)
                {
                    var (statusLabel, statusBg, statusClr) = booking.Status switch
                    {
                        WebBanHang_2380600870.Models.BookingStatus.Pending => ("Chờ xác nhận", "rgba(234,179,8,0.12)", "#b45309"),
                        WebBanHang_2380600870.Models.BookingStatus.Confirmed => ("Đã xác nhận", "rgba(16,185,129,0.12)", "#065f46"),
                        WebBanHang_2380600870.Models.BookingStatus.Cancelled => ("Đã hủy", "rgba(239,68,68,0.1)", "#b91c1c"),
                        _ => ("Không xác định", "rgba(100,116,139,0.1)", "#64748b")
                    };
                    <div class="bg-white rounded-2xl border p-5 transition-colors" style="border-color: rgba(162,123,92,0.15);">
                        <div class="flex items-start justify-between mb-4 flex-wrap gap-2">
                            <div>
                                <span class="font-bold text-base" style="color: #2C3639;">
                                    @booking.BookingDate.ToString("dd/MM/yyyy") lúc @booking.BookingTime
                                </span>
                                <span class="text-xs ml-2" style="color: rgba(63,78,79,0.45);">
                                    (đặt lúc @booking.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))
                                </span>
                            </div>
                            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide"
                                  style="background: @statusBg; color: @statusClr;">@statusLabel</span>
                        </div>

                        <div class="grid grid-cols-2 gap-x-6 gap-y-2 text-sm mb-3">
                            <div>
                                <span style="color: rgba(63,78,79,0.5);">Họ tên:</span>
                                <span class="ml-1 font-medium" style="color: #2C3639;">@booking.FullName</span>
                            </div>
                            <div>
                                <span style="color: rgba(63,78,79,0.5);">Số khách:</span>
                                <span class="ml-1 font-medium" style="color: #2C3639;">@booking.GuestCount người</span>
                            </div>
                            <div>
                                <span style="color: rgba(63,78,79,0.5);">SĐT:</span>
                                <span class="ml-1 font-medium" style="color: #2C3639;">@booking.Phone</span>
                            </div>
                            @if (!string.IsNullOrEmpty(booking.Occasion))
                            {
                                <div>
                                    <span style="color: rgba(63,78,79,0.5);">Dịp:</span>
                                    <span class="ml-1 font-medium" style="color: #2C3639;">@booking.Occasion</span>
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(booking.SpecialRequest))
                        {
                            <div class="mt-2 px-3 py-2 rounded-lg text-xs" style="background: rgba(162,123,92,0.06); color: rgba(63,78,79,0.7);">
                                💬 @booking.SpecialRequest
                            </div>
                        }
                    </div>
                }
            </div>
        }
        }

        <div class="mt-8 text-center">
            <a asp-controller="Account" asp-action="UserAccount"
                   class="text-sm font-semibold transition-colors hover:opacity-70"
                   style="color: #A27B5C;">
                ← Quay lại Cài Đặt Tài Khoản
            </a>
        </div>
    </div>
</section>
