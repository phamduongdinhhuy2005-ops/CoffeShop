@* FILE: Views/GiftCard/Index.cshtml *@
@{
    ViewData["Title"] = "Gift Card";
}

<div class="min-h-screen bg-cream-custom py-16">
    <div class="max-w-6xl mx-auto px-4">
        <!-- Header -->
        <div class="text-center mb-12">
            <h1 class="text-5xl font-bold text-slate-custom mb-4">Gift Card Góc Lặng</h1>
            <div class="w-24 h-1 bg-primary mx-auto mb-6"></div>
            <p class="text-xl text-teal-custom">Tặng quà yêu thương - Gửi gắm tình cảm</p>
        </div>

        <!-- Gift Card Options -->
        <div class="grid md:grid-cols-3 gap-8 mb-12">
            <!-- Gift Card 100k -->
            <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-2xl transition-all transform hover:-translate-y-2">
                <div class="bg-gradient-to-br from-primary to-teal-custom text-white rounded-xl p-8 mb-4 relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -mr-16 -mt-16"></div>
                    <div class="absolute bottom-0 left-0 w-24 h-24 bg-white/10 rounded-full -ml-12 -mb-12"></div>
                    <div class="relative z-10">
                        <p class="text-sm uppercase tracking-wide mb-2 opacity-90">Góc Lặng Café</p>
                        <p class="text-4xl font-bold mb-1">100.000đ</p>
                        <div class="flex items-center gap-2 mt-3">
                            <span class="material-symbols-outlined text-2xl">card_giftcard</span>
                            <span class="text-sm">Gift Card</span>
                        </div>
                    </div>
                </div>
                <h3 class="font-bold text-xl mb-2 text-slate-custom">Gói Khởi Đầu</h3>
                <p class="text-sm text-teal-custom mb-4">Hoàn hảo cho những buổi cà phê nhẹ nhàng cùng bạn bè</p>
                <ul class="text-sm text-teal-custom space-y-2 mb-6">
                    <li class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-lg">check</span>
                        Đủ cho 2-3 ly cà phê
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-lg">check</span>
                        Không giới hạn sử dụng
                    </li>
                </ul>
                <button onclick="purchaseGiftCard(100000)" class="w-full bg-primary text-white py-3 rounded-lg hover:bg-primary/90 transition-colors font-bold flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">add_shopping_cart</span>
                    Mua Ngay
                </button>
            </div>

            <!-- Gift Card 200k - POPULAR -->
            <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-2xl transition-all transform hover:-translate-y-2 border-2 border-primary relative">
                <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-primary text-white px-4 py-1 rounded-full text-sm font-bold">
                    PHỔ BIẾN NHẤT
                </div>
                <div class="bg-gradient-to-br from-amber-400 to-orange-500 text-white rounded-xl p-8 mb-4 relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -mr-16 -mt-16"></div>
                    <div class="absolute bottom-0 left-0 w-24 h-24 bg-white/10 rounded-full -ml-12 -mb-12"></div>
                    <div class="relative z-10">
                        <p class="text-sm uppercase tracking-wide mb-2 opacity-90">Góc Lặng Café</p>
                        <p class="text-4xl font-bold mb-1">200.000đ</p>
                        <div class="flex items-center gap-2 mt-3">
                            <span class="material-symbols-outlined text-2xl">card_giftcard</span>
                            <span class="text-sm">Gift Card</span>
                        </div>
                    </div>
                </div>
                <h3 class="font-bold text-xl mb-2 text-slate-custom">Gói Đặc Biệt</h3>
                <p class="text-sm text-teal-custom mb-4">Lựa chọn yêu thích của khách hàng, giá trị tốt nhất</p>
                <ul class="text-sm text-teal-custom space-y-2 mb-6">
                    <li class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-lg">check</span>
                        Đủ cho 4-5 ly cà phê
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-lg">check</span>
                        Kèm bánh ngọt
                    </li>
                </ul>
                <button onclick="purchaseGiftCard(200000)" class="w-full bg-primary text-white py-3 rounded-lg hover:bg-primary/90 transition-colors font-bold flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">add_shopping_cart</span>
                    Mua Ngay
                </button>
            </div>

            <!-- Gift Card 500k -->
            <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-2xl transition-all transform hover:-translate-y-2">
                <div class="bg-gradient-to-br from-purple-500 to-pink-500 text-white rounded-xl p-8 mb-4 relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -mr-16 -mt-16"></div>
                    <div class="absolute bottom-0 left-0 w-24 h-24 bg-white/10 rounded-full -ml-12 -mb-12"></div>
                    <div class="relative z-10">
                        <p class="text-sm uppercase tracking-wide mb-2 opacity-90">Góc Lặng Café</p>
                        <p class="text-4xl font-bold mb-1">500.000đ</p>
                        <div class="flex items-center gap-2 mt-3">
                            <span class="material-symbols-outlined text-2xl">card_giftcard</span>
                            <span class="text-sm">Premium Gift Card</span>
                        </div>
                    </div>
                </div>
                <h3 class="font-bold text-xl mb-2 text-slate-custom">Gói Cao Cấp</h3>
                <p class="text-sm text-teal-custom mb-4">Trải nghiệm trọn vẹn tại Góc Lặng cho người đặc biệt</p>
                <ul class="text-sm text-teal-custom space-y-2 mb-6">
                    <li class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-lg">check</span>
                        Đủ cho 10+ lần ghé thăm
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary text-lg">check</span>
                        Ưu đãi đặc biệt
                    </li>
                </ul>
                <button onclick="purchaseGiftCard(500000)" class="w-full bg-primary text-white py-3 rounded-lg hover:bg-primary/90 transition-colors font-bold flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">add_shopping_cart</span>
                    Mua Ngay
                </button>
            </div>
        </div>

        <!-- Features -->
        <div class="grid md:grid-cols-4 gap-6 mb-12">
            <div class="text-center bg-white rounded-xl p-6 shadow">
                <span class="material-symbols-outlined text-primary text-5xl mb-3 block">schedule</span>
                <h3 class="font-bold text-slate-custom mb-2">Hiệu Lực 12 Tháng</h3>
                <p class="text-sm text-teal-custom">Sử dụng trong vòng 1 năm</p>
            </div>
            <div class="text-center bg-white rounded-xl p-6 shadow">
                <span class="material-symbols-outlined text-primary text-5xl mb-3 block">redeem</span>
                <h3 class="font-bold text-slate-custom mb-2">Quà Tặng Ý Nghĩa</h3>
                <p class="text-sm text-teal-custom">Gửi tặng người thân yêu</p>
            </div>
            <div class="text-center bg-white rounded-xl p-6 shadow">
                <span class="material-symbols-outlined text-primary text-5xl mb-3 block">storefront</span>
                <h3 class="font-bold text-slate-custom mb-2">Dùng Mọi Sản Phẩm</h3>
                <p class="text-sm text-teal-custom">Áp dụng toàn menu</p>
            </div>
            <div class="text-center bg-white rounded-xl p-6 shadow">
                <span class="material-symbols-outlined text-primary text-5xl mb-3 block">email</span>
                <h3 class="font-bold text-slate-custom mb-2">Giao Qua Email</h3>
                <p class="text-sm text-teal-custom">Nhận ngay sau khi mua</p>
            </div>
        </div>

        <!-- Terms & Conditions -->
        <div class="bg-white rounded-2xl p-8 shadow-lg">
            <h2 class="text-2xl font-bold text-slate-custom mb-6 flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-3xl">description</span>
                Điều Khoản Sử Dụng
            </h2>
            <div class="grid md:grid-cols-2 gap-8">
                <div>
                    <h3 class="font-bold text-lg text-slate-custom mb-3">Quy Định Chung</h3>
                    <ul class="space-y-3 text-teal-custom">
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary text-xl mt-0.5">check_circle</span>
                            <span>Gift Card có hiệu lực sử dụng trong vòng 12 tháng kể từ ngày mua</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary text-xl mt-0.5">check_circle</span>
                            <span>Có thể sử dụng cho tất cả sản phẩm tại Góc Lặng Café</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary text-xl mt-0.5">check_circle</span>
                            <span>Không giới hạn số lần sử dụng cho đến khi hết giá trị</span>
                        </li>
                    </ul>
                </div>
                <div>
                    <h3 class="font-bold text-lg text-slate-custom mb-3">Lưu Ý Quan Trọng</h3>
                    <ul class="space-y-3 text-teal-custom">
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-orange-500 text-xl mt-0.5">info</span>
                            <span>Không áp dụng đổi lại thành tiền mặt</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-orange-500 text-xl mt-0.5">info</span>
                            <span>Mỗi hóa đơn chỉ sử dụng được một Gift Card</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-orange-500 text-xl mt-0.5">info</span>
                            <span>Vui lòng giữ mã Gift Card cẩn thận, không chia sẻ với người lạ</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function purchaseGiftCard(amount) {
            // TODO: Implement proper cart/purchase flow
            if (confirm(`Bạn muốn mua Gift Card trị giá ${amount.toLocaleString('vi-VN')}đ?`)) {
                fetch('@Url.Action("Purchase", "GiftCard")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: `amount=${amount}`
                })
                .then(response => {
                    if (response.ok) {
                        window.location.href = '@Url.Action("Index", "Cart")';
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Có lỗi xảy ra. Vui lòng thử lại!');
                });
            }
        }
    </script>
}
