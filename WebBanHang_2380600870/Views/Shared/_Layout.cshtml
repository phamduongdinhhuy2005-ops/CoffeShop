@* FILE: Views/Shared/_Layout.cshtml *@
@* THAY THẾ TOÀN BỘ FILE CŨ *@
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Work+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary":          "#A27B5C",
                        "slate-custom":     "#2C3639",
                        "teal-custom":      "#3F4E4F",
                        "cream-custom":     "#DCD7C9",
                        "background-light": "#F7F7F6",
                        "background-dark":  "#1C1916",
                    },
                    fontFamily: {
                        "display": ["Work Sans", "sans-serif"],
                        "serif":   ["Playfair Display", "serif"],
                    },
                    borderRadius: {
                        "DEFAULT": "0.5rem",
                        "lg":      "1rem",
                        "xl":      "1.5rem",
                        "full":    "9999px"
                    },
                },
            },
        }
    </script>

    <style>
        .vn-heading {
            font-family: 'Playfair Display',serif;
            line-height: 58px;
        }

        .vn-heading-xl {
            font-family: 'Playfair Display',serif;
            line-height: 68px;
        }

        .vn-body {
            line-height: 2.0;
        }

        @@media (min-width:768px) {
            .vn-heading {
                line-height: 68px;
            }
        }

        @@media (min-width:768px) {
            .vn-heading-xl {
                line-height: 88px;
            }
        }

        .user-menu {
            position: relative;
        }

        .user-menu-dropdown {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            padding-top: 8px;
            min-width: 220px;
            z-index: 999;
        }

        .user-menu:hover .user-menu-dropdown {
            display: block;
        }

        .user-menu-dropdown-inner {
            background: #fff;
            border: 1px solid rgba(162,123,92,0.25);
            border-radius: 14px;
            box-shadow: 0 12px 40px rgba(44,54,57,0.15);
            overflow: hidden;
        }

        /* Khi có admin-page class trên body: ẩn scroll ngoài */
        body.admin-page {
            overflow: hidden;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-background-light font-display text-slate-custom @(IsSectionDefined("AdminPage") ? "admin-page" : "")">

    @* Nếu là admin page: chỉ render header + body, KHÔNG render footer, body = flex column full-height *@
    @if (IsSectionDefined("AdminPage"))
    {
        <div style="display:flex; flex-direction:column; height:100vh; overflow:hidden;">

            <!-- ===== HEADER (ADMIN PAGE) ===== -->
            <header style="flex-shrink:0;" class="flex items-center justify-between whitespace-nowrap border-b border-primary/20 bg-background-light/90 backdrop-blur-md px-6 md:px-20 py-4 sticky top-0 z-50">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 text-slate-custom hover:opacity-80 transition-opacity">
                    <span class="material-symbols-outlined text-primary text-3xl" style="line-height:1;display:block;">local_cafe</span>
                    <div class="flex flex-col justify-center">
                        <h2 class="text-slate-custom font-bold text-lg tracking-widest uppercase"
                            style="font-family:'Playfair Display',serif;line-height:1.3;margin:0;">
                            Góc Lặng
                        </h2>
                        <p class="text-teal-custom text-[9px] tracking-[0.22em] uppercase font-medium" style="margin-top:2px;line-height:1;">Café & Nghệ Thuật Cổ Điển</p>
                    </div>
                </a>
                <nav class="hidden md:flex flex-1 justify-center gap-10">
                    <a asp-controller="Menu" asp-action="Index" class="text-teal-custom hover:text-primary transition-colors text-sm font-semibold uppercase tracking-wider">Thực Đơn</a>
                    <a asp-controller="Story" asp-action="Index" class="text-teal-custom hover:text-primary transition-colors text-sm font-semibold uppercase tracking-wider">Câu Chuyện</a>
                    <a asp-controller="Booking" asp-action="Index" class="text-teal-custom hover:text-primary transition-colors text-sm font-semibold uppercase tracking-wider">Đặt Chỗ</a>
                    <a href="#footer-location" class="text-teal-custom hover:text-primary transition-colors text-sm font-semibold uppercase tracking-wider">Tìm Chúng Mình</a>
                </nav>
                <div class="flex items-center gap-2">
                    <a asp-controller="Product" asp-action="Index"
                       class="flex items-center justify-center rounded-full h-10 w-10 bg-cream-custom/50 text-teal-custom hover:bg-primary hover:text-white transition-all">
                        <span class="material-symbols-outlined text-[20px]">shopping_bag</span>
                    </a>
                    <div class="user-menu">
                        <button class="flex items-center justify-center rounded-full h-10 w-10 bg-cream-custom/50 text-teal-custom hover:bg-primary hover:text-white transition-all">
                            <span class="material-symbols-outlined text-[20px]">person</span>
                        </button>
                        <div class="user-menu-dropdown">
                            <div class="user-menu-dropdown-inner">
                                @if (User.Identity != null && User.Identity.IsAuthenticated)
                                {
                                    <div class="px-5 py-4 border-b" style="border-color:rgba(162,123,92,0.15); background:rgba(162,123,92,0.05);">
                                        <div class="flex items-center gap-3">
                                            <div class="w-9 h-9 rounded-full flex items-center justify-center text-white text-sm font-bold shrink-0" style="background:#A27B5C;">
                                                @User.Identity.Name?.Substring(0, 1).ToUpper()
                                            </div>
                                            <div class="min-w-0">
                                                <p class="text-slate-custom font-bold text-sm truncate">@User.Identity.Name</p>
                                                @if (User.IsInRole("Admin"))
                                                {
                                                    <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(162,123,92,0.2); color:#A27B5C;">Admin</span>
                                                }
                                                else
                                                {
                                                    <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(63,78,79,0.15); color:#3F4E4F;">Thành viên</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div class="py-2">
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-controller="Admin" asp-action="Index" class="flex items-center gap-3 px-5 py-3 text-sm text-teal-custom hover:text-primary transition-colors">
                                                <span class="material-symbols-outlined text-primary" style="font-size:18px;">dashboard</span>
                                                Dashboard Admin
                                            </a>
                                            <a asp-controller="Admin" asp-action="Users" class="flex items-center gap-3 px-5 py-3 text-sm text-teal-custom hover:text-primary transition-colors">
                                                <span class="material-symbols-outlined text-primary" style="font-size:18px;">group</span>
                                                Quản Lý Người Dùng
                                            </a>
                                        }
                                        <a asp-controller="Booking" asp-action="Index" class="flex items-center gap-3 px-5 py-3 text-sm text-teal-custom hover:text-primary transition-colors">
                                            <span class="material-symbols-outlined text-primary" style="font-size:18px;">event_seat</span>
                                            Đặt Chỗ
                                        </a>
                                    </div>
                                    <div class="border-t py-2" style="border-color:rgba(162,123,92,0.15);">
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="flex items-center gap-3 w-full px-5 py-3 text-sm text-left transition-colors" style="color:#b91c1c;"
                                                    onmouseover="this.style.background='rgba(239,68,68,0.07)'" onmouseout="this.style.background=''">
                                                <span class="material-symbols-outlined" style="font-size:18px; color:#b91c1c;">logout</span>
                                                Đăng Xuất
                                            </button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <div class="p-4 flex flex-col gap-2">
                                        <a asp-controller="Account" asp-action="Login"
                                           class="flex items-center justify-center gap-2 w-full py-2.5 rounded-full text-sm font-bold text-white transition-all hover:opacity-90"
                                           style="background:#2C3639;">
                                            <span class="material-symbols-outlined text-[16px]">login</span>Đăng Nhập
                                        </a>
                                        <a asp-controller="Account" asp-action="Register"
                                           class="flex items-center justify-center gap-2 w-full py-2.5 rounded-full text-sm font-bold transition-all hover:opacity-90"
                                           style="border:1.5px solid #A27B5C; color:#A27B5C;">
                                            <span class="material-symbols-outlined text-[16px]">person_add</span>Đăng Ký
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            @* Body chiếm phần còn lại, scroll bên trong *@
            <div style="flex:1; overflow:hidden;">
                @RenderBody()
            </div>

        </div>
    }
    else
    {
        @* === NORMAL PAGES (non-admin): giữ nguyên layout cũ === *@
        <div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden">
            <div class="layout-container flex h-full grow flex-col">

                <!-- ===== HEADER (NORMAL PAGE) ===== -->
                <header class="flex items-center justify-between whitespace-nowrap border-b border-primary/20 bg-background-light/90 backdrop-blur-md px-6 md:px-20 py-4 sticky top-0 z-50">
                    <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 text-slate-custom hover:opacity-80 transition-opacity">
                        <span class="material-symbols-outlined text-primary text-3xl" style="line-height:1;display:block;">local_cafe</span>
                        <div class="flex flex-col justify-center">
                            <h2 class="text-slate-custom font-bold text-lg tracking-widest uppercase"
                                style="font-family:'Playfair Display',serif;line-height:1.3;margin:0;">
                                Góc Lặng
                            </h2>
                            <p class="text-teal-custom text-[9px] tracking-[0.22em] uppercase font-medium" style="margin-top:2px;line-height:1;">Café & Nghệ Thuật Cổ Điển</p>
                        </div>
                    </a>
                    <nav class="hidden md:flex flex-1 justify-center gap-10">
                        <a asp-controller="Menu" asp-action="Index" class="text-teal-custom hover:text-primary transition-colors text-sm font-semibold uppercase tracking-wider">Thực Đơn</a>
                        <a asp-controller="Story" asp-action="Index" class="text-teal-custom hover:text-primary transition-colors text-sm font-semibold uppercase tracking-wider">Câu Chuyện</a>
                        <a asp-controller="Booking" asp-action="Index" class="text-teal-custom hover:text-primary transition-colors text-sm font-semibold uppercase tracking-wider">Đặt Chỗ</a>
                        <a href="#footer-location" class="text-teal-custom hover:text-primary transition-colors text-sm font-semibold uppercase tracking-wider">Tìm Chúng Mình</a>
                    </nav>
                    <div class="flex items-center gap-2">
                        <a asp-controller="Product" asp-action="Index"
                           class="flex items-center justify-center rounded-full h-10 w-10 bg-cream-custom/50 text-teal-custom hover:bg-primary hover:text-white transition-all">
                            <span class="material-symbols-outlined text-[20px]">shopping_bag</span>
                        </a>
                        <div class="user-menu">
                            <button class="flex items-center justify-center rounded-full h-10 w-10 bg-cream-custom/50 text-teal-custom hover:bg-primary hover:text-white transition-all">
                                <span class="material-symbols-outlined text-[20px]">person</span>
                            </button>
                            <div class="user-menu-dropdown">
                                <div class="user-menu-dropdown-inner">
                                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                                    {
                                        <div class="px-5 py-4 border-b" style="border-color:rgba(162,123,92,0.15); background:rgba(162,123,92,0.05);">
                                            <div class="flex items-center gap-3">
                                                <div class="w-9 h-9 rounded-full flex items-center justify-center text-white text-sm font-bold shrink-0" style="background:#A27B5C;">
                                                    @User.Identity.Name?.Substring(0, 1).ToUpper()
                                                </div>
                                                <div class="min-w-0">
                                                    <p class="text-slate-custom font-bold text-sm truncate">@User.Identity.Name</p>
                                                    @if (User.IsInRole("Admin"))
                                                    {
                                                        <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(162,123,92,0.2); color:#A27B5C;">Admin</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full" style="background:rgba(63,78,79,0.15); color:#3F4E4F;">Thành viên</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        <div class="py-2">
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a asp-controller="Admin" asp-action="Index" class="flex items-center gap-3 px-5 py-3 text-sm text-teal-custom hover:text-primary transition-colors">
                                                    <span class="material-symbols-outlined text-primary" style="font-size:18px;">dashboard</span>
                                                    Dashboard Admin
                                                </a>
                                                <a asp-controller="Admin" asp-action="Users" class="flex items-center gap-3 px-5 py-3 text-sm text-teal-custom hover:text-primary transition-colors">
                                                    <span class="material-symbols-outlined text-primary" style="font-size:18px;">group</span>
                                                    Quản Lý Người Dùng
                                                </a>
                                            }
                                            <a asp-controller="Booking" asp-action="Index" class="flex items-center gap-3 px-5 py-3 text-sm text-teal-custom hover:text-primary transition-colors">
                                                <span class="material-symbols-outlined text-primary" style="font-size:18px;">event_seat</span>
                                                Đặt Chỗ
                                            </a>
                                        </div>
                                        <div class="border-t py-2" style="border-color:rgba(162,123,92,0.15);">
                                            <form asp-controller="Account" asp-action="Logout" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="flex items-center gap-3 w-full px-5 py-3 text-sm text-left transition-colors" style="color:#b91c1c;"
                                                        onmouseover="this.style.background='rgba(239,68,68,0.07)'" onmouseout="this.style.background=''">
                                                    <span class="material-symbols-outlined" style="font-size:18px; color:#b91c1c;">logout</span>
                                                    Đăng Xuất
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="p-4 flex flex-col gap-2">
                                            <a asp-controller="Account" asp-action="Login"
                                               class="flex items-center justify-center gap-2 w-full py-2.5 rounded-full text-sm font-bold text-white transition-all hover:opacity-90"
                                               style="background:#2C3639;">
                                                <span class="material-symbols-outlined text-[16px]">login</span>Đăng Nhập
                                            </a>
                                            <a asp-controller="Account" asp-action="Register"
                                               class="flex items-center justify-center gap-2 w-full py-2.5 rounded-full text-sm font-bold transition-all hover:opacity-90"
                                               style="border:1.5px solid #A27B5C; color:#A27B5C;">
                                                <span class="material-symbols-outlined text-[16px]">person_add</span>Đăng Ký
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </header>

                @RenderBody()

                <!-- ===== FOOTER ===== -->
                <footer class="bg-background-light py-16 px-6 md:px-20 border-t border-primary/10">
                    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
                        <div>
                            <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 mb-2 hover:opacity-80 transition-opacity">
                                <span class="material-symbols-outlined text-primary text-3xl">local_cafe</span>
                                <h2 class="text-slate-custom font-bold text-lg uppercase" style="font-family:'Playfair Display',serif;">Góc Lặng</h2>
                            </a>
                            <p class="text-primary text-xs tracking-widest uppercase mb-5">Café & Nghệ Thuật Cổ Điển</p>
                            <p class="vn-body text-teal-custom text-sm mb-6">Một nơi chúng mình tạo ra vì niềm đam mê — dành cho những ai muốn dừng lại, thở sâu, và thưởng thức buổi sáng đúng nghĩa.</p>
                            <div class="flex gap-4">
                                <a class="text-teal-custom hover:text-primary transition-colors" href="#"><span class="material-symbols-outlined">public</span></a>
                                <a class="text-teal-custom hover:text-primary transition-colors" href="#"><span class="material-symbols-outlined">camera</span></a>
                                <a class="text-teal-custom hover:text-primary transition-colors" href="#"><span class="material-symbols-outlined">share</span></a>
                            </div>
                        </div>
                        <div>
                            <h4 class="text-slate-custom font-bold uppercase tracking-widest text-sm mb-6">Khám Phá</h4>
                            <ul class="flex flex-col gap-4 text-teal-custom text-sm">
                                <li><a asp-controller="Story" asp-action="Index" class="hover:text-primary transition-colors">Câu Chuyện Của Chúng Mình</a></li>
                                <li><a asp-controller="Menu" asp-action="Index" class="hover:text-primary transition-colors">Thực Đơn</a></li>
                                <li><a asp-controller="Booking" asp-action="Index" class="hover:text-primary transition-colors">Đặt Chỗ</a></li>
                                <li><a asp-controller="GiftCard" asp-action="Index" class="hover:text-primary transition-colors">Gift Card</a></li>
                            </ul>
                        </div>
                        <div id="footer-location">
                            <h4 class="text-slate-custom font-bold uppercase tracking-widest text-sm mb-6">Ghé Thăm</h4>
                            <ul class="flex flex-col gap-4 text-teal-custom text-sm">
                                <li class="flex gap-2 items-start">
                                    <span class="material-symbols-outlined text-primary text-lg shrink-0">location_on</span>
                                    124 Đường Hoài Cổ, Quận 3, TP.HCM
                                </li>
                                <li class="flex gap-2 items-center">
                                    <span class="material-symbols-outlined text-primary text-lg shrink-0">schedule</span>
