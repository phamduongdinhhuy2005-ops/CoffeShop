                            <h4 class="text-slate-custom font-bold uppercase tracking-widest text-sm mb-6">Vị Trí</h4>
                            <div class="rounded-xl overflow-hidden h-40 bg-cream-custom/40">
                                <img alt="Bản đồ Góc Lặng" class="w-full h-full object-cover grayscale opacity-60"
                                     src="https://lh3.googleusercontent.com/aida-public/AB6AXuCPTaYoGRzPS3HzjX1qkNfvn5L-33NWlXGgvN8ErZNOIgDCHZlEwxKKZZsudgd_Z0rfGjpSN17Mr5FLB1gU7rHtIdVqfJ6HTCEzOihtzl5_2lg-N8s0nHF20VjyMQVTxurl0JeJuNiCiI9gKeFx7csGJcMEXUbI239gBhv-g0VvgEmKcEI_xiqKu2P2SPmlfBLurzkAWCEiYUT4j3htSa7cn-MR82jTb2u_lLw_q8VL0i8zR2rnhCCA9gJgVVyNxR4ej71-Go3jgF2w" />
                            </div>
                        </div>
                    </div>
                    <div class="max-w-7xl mx-auto mt-16 pt-8 border-t border-primary/10 text-center text-teal-custom text-xs uppercase tracking-[0.2em]">
                        &copy; 2024 Góc Lặng Café. Được làm với tình yêu và cà phê. ☕
                    </div>
                </footer>

            </div>
        </div>
    }

    <script>
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    e.preventDefault();
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>

    @await RenderSectionAsync("AdminPage", required: false)
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
