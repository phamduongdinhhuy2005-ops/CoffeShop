                                </li>
                                <li class="flex gap-2 items-center">
                                    <span class="material-symbols-outlined text-primary text-lg shrink-0">schedule</span>
                                    Thứ 7 – CN: 8:00 – 20:00
                                </li>
                                <li class="flex gap-2 items-center">
                                    <span class="material-symbols-outlined text-primary text-lg shrink-0">call</span>
                                    (028) 1234 5678
                                </li>
                            </ul>
                        </div>
